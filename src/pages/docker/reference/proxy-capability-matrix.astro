---
import Layout from '../../../layouts/Layout.astro';
import services from '../../../data/services.json';
import { pickSeoTitle } from '../../../data/seoExperiment';

const totalRoutes = services.apps.reduce((total, app) => {
  const compatibleDatabases = services.databases.filter((db) => app.supported_dbs.includes(db.id)).length;
  return total + compatibleDatabases * services.proxies.length;
}, 0);

const routesPerProxy = Math.floor(totalRoutes / services.proxies.length);

const pageTitle = pickSeoTitle(
  'Docker Reverse Proxy Capability Matrix | Nginx vs Caddy vs Traefik',
  'Nginx Caddy Traefik Matrix for Docker | Capability Comparison'
);

const conclusions = [
  `Coverage baseline: ${totalRoutes} valid app-db-proxy routes are generated from the current catalog, with about ${routesPerProxy} routes per proxy engine.`,
  'Nginx provides the strongest low-level tuning control, suitable for teams that want explicit config ownership.',
  'Caddy minimizes operational overhead with automatic HTTPS and simpler defaults, ideal for small teams.',
  'Traefik is strongest for dynamic multi-service routing and label-driven automation in larger Docker estates.'
];

const matrixRows = [
  {
    dimension: 'TLS and certificate lifecycle',
    nginx: 'Manual ACME integration or external certbot workflow',
    caddy: 'Built-in automatic HTTPS and renewal',
    traefik: 'ACME resolver automation with configurable storage'
  },
  {
    dimension: 'Service discovery model',
    nginx: 'Mostly static upstream definitions',
    caddy: 'Static plus lightweight dynamic updates',
    traefik: 'Native dynamic discovery via Docker labels'
  },
  {
    dimension: 'Granular traffic control',
    nginx: 'Very strong directives for buffering and limits',
    caddy: 'Moderate, opinionated defaults',
    traefik: 'Strong middleware chains and routing rules'
  },
  {
    dimension: 'Operational complexity',
    nginx: 'Higher, config-heavy',
    caddy: 'Lower, concise config',
    traefik: 'Medium-high, label and middleware planning'
  },
  {
    dimension: 'Best-fit deployment profile',
    nginx: 'Performance tuning and strict policy control',
    caddy: 'Fast launch and low-maintenance hosting',
    traefik: 'Multi-service platforms and frequent routing change'
  }
] as const;
---

<Layout
  title={pageTitle}
  description="Citation-ready matrix for choosing Nginx, Caddy, or Traefik in Docker Compose based on TLS automation, routing model, and operations overhead."
  canonical="/docker/reference/proxy-capability-matrix/"
>
  <main class="mx-auto w-full max-w-7xl px-6 py-10 md:px-8 md:py-14">
    <a href="/docker/" class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-300 transition hover:bg-white/10">
      <span>&larr;</span>
      <span>Docker Hub</span>
    </a>

    <header class="mb-8 rounded-3xl border border-white/15 bg-white/[0.03] p-6 md:p-8">
      <p class="mb-3 inline-flex items-center rounded-full border border-cyan-400/35 bg-cyan-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-cyan-100">Week 5 Citation Asset</p>
      <h1 class="text-3xl font-semibold tracking-tight text-white md:text-5xl">Docker Reverse Proxy Capability Matrix</h1>
      <p class="mt-4 max-w-4xl text-sm leading-7 text-zinc-300 md:text-base">
        This page is designed as a quotable reference for architecture notes and migration discussions. All rows use one consistent baseline from the current route catalog.
      </p>
    </header>

    <section class="rounded-3xl border border-cyan-300/20 bg-cyan-500/[0.06] p-6 md:p-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-cyan-100">Directly Quotable Conclusions</h2>
      <ul class="space-y-2 text-sm leading-7 text-zinc-200">
        {conclusions.map((item) => (
          <li class="rounded-xl border border-white/10 bg-black/25 px-4 py-3">{item}</li>
        ))}
      </ul>
    </section>

    <section class="mt-8 rounded-3xl border border-white/10 bg-white/[0.02] p-6 md:p-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-300">Capability Matrix</h2>
      <div class="overflow-x-auto">
        <table class="w-full min-w-[980px] text-left text-sm">
          <thead>
            <tr class="border-b border-white/10 text-xs uppercase tracking-[0.12em] text-zinc-400">
              <th class="py-3">Dimension</th>
              <th class="py-3">Nginx</th>
              <th class="py-3">Caddy</th>
              <th class="py-3">Traefik</th>
            </tr>
          </thead>
          <tbody class="text-zinc-200">
            {matrixRows.map((row) => (
              <tr class="border-b border-white/5">
                <td class="py-3 font-medium text-white">{row.dimension}</td>
                <td class="py-3">{row.nginx}</td>
                <td class="py-3">{row.caddy}</td>
                <td class="py-3">{row.traefik}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-8 rounded-3xl border border-cyan-300/20 bg-cyan-500/[0.06] p-6 md:p-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-cyan-100">Docker Cluster Navigation</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/docker/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Docker Hub</a>
        <a href="/docker/reference/deployment-quick-reference/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Deployment Quick Reference</a>
        <a href="/docker/compare/reverse-proxy-comparison/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Proxy Comparison Page</a>
        <a href="/docker/decision/stack-selector/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Stack Selector</a>
        <a href="/docker/faq/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Docker FAQ</a>
        <a href="/reverse-proxy/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Reverse Proxy Generator</a>
      </div>
    </section>
  </main>
</Layout>
