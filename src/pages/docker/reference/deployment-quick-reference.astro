---
import Layout from '../../../layouts/Layout.astro';
import services from '../../../data/services.json';
import { pickSeoTitle } from '../../../data/seoExperiment';

type App = (typeof services.apps)[number];
type Database = (typeof services.databases)[number];
type Proxy = (typeof services.proxies)[number];

type QuickRoute = {
  scenario: string;
  app: App;
  db: Database;
  proxy: Proxy;
  href: string;
  reason: string;
};

function pickDb(app: App, dbId?: string): Database {
  if (dbId) {
    const matched = services.databases.find((db) => db.id === dbId && app.supported_dbs.includes(db.id));
    if (matched) return matched;
  }
  return services.databases.find((db) => app.supported_dbs.includes(db.id)) ?? services.databases[0];
}

function pickProxy(proxyId: string): Proxy {
  return services.proxies.find((proxy) => proxy.id === proxyId) ?? services.proxies[0];
}

const routeSeeds: Array<{ scenario: string; appId: string; proxyId: string; dbId?: string; reason: string }> = [
  {
    scenario: 'Small content site needing quick HTTPS',
    appId: 'ghost',
    proxyId: 'caddy',
    dbId: 'mysql',
    reason: 'Lower operational burden and automatic certificates.'
  },
  {
    scenario: 'WordPress stack with fine-grained cache tuning',
    appId: 'wordpress',
    proxyId: 'nginx',
    dbId: 'mariadb',
    reason: 'More explicit ingress controls for plugin-heavy workloads.'
  },
  {
    scenario: 'Multi-service internal platform growth',
    appId: 'directus',
    proxyId: 'traefik',
    dbId: 'postgres',
    reason: 'Label-driven routing scales with additional services.'
  },
  {
    scenario: 'Team wiki with low ops bandwidth',
    appId: 'wikijs',
    proxyId: 'caddy',
    dbId: 'postgres',
    reason: 'Simple defaults reduce ongoing maintenance overhead.'
  },
  {
    scenario: 'Developer git service with predictable traffic',
    appId: 'gitea',
    proxyId: 'nginx',
    dbId: 'postgres',
    reason: 'Solid baseline for long-lived services and predictable routing.'
  }
];

const quickRoutes: QuickRoute[] = routeSeeds.flatMap((seed) => {
  const app = services.apps.find((item) => item.id === seed.appId);
  if (!app) return [];

  const db = pickDb(app, seed.dbId);
  const proxy = pickProxy(seed.proxyId);

  return [{
    scenario: seed.scenario,
    app,
    db,
    proxy,
    href: `/docker/${app.id}-${db.id}-${proxy.id}/`,
    reason: seed.reason
  }];
});

const preflightChecklist = [
  'Pin image tags before production rollout to reduce surprise updates.',
  'Map APP_DB_* and DB_* environment variables in one documented place.',
  'Ensure persistent volumes are on stable storage and included in backup jobs.',
  'Define health endpoint and restart policy before first deployment.'
];

const goLiveChecklist = [
  'Confirm 80/443 ingress and DNS resolution before enabling public traffic.',
  'Enable access and error log rotation with retention policy.',
  'Validate TLS renewal path and fallback alerting.',
  'Run one rollback drill using the fallback proxy route.'
];

const pageTitle = pickSeoTitle(
  'Docker Compose Deployment Quick Reference | Preflight to Go-Live',
  'Docker Deployment Cheat Sheet | Compose Production Checklist'
);
---

<Layout
  title={pageTitle}
  description="Citation-ready Docker deployment quick reference: scenario-based stack routes, preflight checks, go-live controls, and rollback guardrails."
  canonical="/docker/reference/deployment-quick-reference/"
>
  <main class="mx-auto w-full max-w-7xl px-6 py-10 md:px-8 md:py-14">
    <a href="/docker/" class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-300 transition hover:bg-white/10">
      <span>&larr;</span>
      <span>Docker Hub</span>
    </a>

    <header class="mb-8 rounded-3xl border border-white/15 bg-white/[0.03] p-6 md:p-8">
      <p class="mb-3 inline-flex items-center rounded-full border border-cyan-400/35 bg-cyan-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-cyan-100">Week 5 Citation Asset</p>
      <h1 class="text-3xl font-semibold tracking-tight text-white md:text-5xl">Docker Deployment Quick Reference</h1>
      <p class="mt-4 max-w-4xl text-sm leading-7 text-zinc-300 md:text-base">
        A short operational sheet that teams can quote in implementation docs, incident postmortems, and rollout runbooks.
      </p>
    </header>

    <section class="rounded-3xl border border-white/10 bg-white/[0.02] p-6 md:p-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-300">Scenario-to-Route Reference</h2>
      <div class="overflow-x-auto">
        <table class="w-full min-w-[980px] text-left text-sm">
          <thead>
            <tr class="border-b border-white/10 text-xs uppercase tracking-[0.12em] text-zinc-400">
              <th class="py-3">Scenario</th>
              <th class="py-3">Recommended Route</th>
              <th class="py-3">Why This Route</th>
            </tr>
          </thead>
          <tbody class="text-zinc-200">
            {quickRoutes.map((row) => (
              <tr class="border-b border-white/5">
                <td class="py-3 font-medium text-white">{row.scenario}</td>
                <td class="py-3">
                  <a href={row.href} class="rounded-lg border border-white/10 bg-black/30 px-3 py-1.5 text-xs text-zinc-200 transition hover:border-cyan-300/40 hover:text-white">
                    {row.app.name} + {row.db.name} + {row.proxy.name}
                  </a>
                </td>
                <td class="py-3">{row.reason}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-2">
      <article class="rounded-3xl border border-cyan-300/20 bg-cyan-500/[0.06] p-6 md:p-8">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-cyan-100">Preflight Checklist</h2>
        <ul class="space-y-2 text-sm leading-7 text-zinc-200">
          {preflightChecklist.map((item) => (
            <li class="rounded-xl border border-white/10 bg-black/25 px-4 py-3">{item}</li>
          ))}
        </ul>
      </article>

      <article class="rounded-3xl border border-emerald-300/20 bg-emerald-500/[0.06] p-6 md:p-8">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-emerald-100">Go-Live and Rollback Checklist</h2>
        <ul class="space-y-2 text-sm leading-7 text-zinc-200">
          {goLiveChecklist.map((item) => (
            <li class="rounded-xl border border-white/10 bg-black/25 px-4 py-3">{item}</li>
          ))}
        </ul>
      </article>
    </section>

    <section class="mt-8 rounded-3xl border border-cyan-300/20 bg-cyan-500/[0.06] p-6 md:p-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-cyan-100">Docker Cluster Navigation</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/docker/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Docker Hub</a>
        <a href="/docker/reference/proxy-capability-matrix/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Proxy Capability Matrix</a>
        <a href="/docker/compare/reverse-proxy-comparison/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Proxy Comparison Page</a>
        <a href="/docker/decision/stack-selector/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Stack Selector</a>
        <a href="/docker/faq/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Docker FAQ</a>
        <a href="/reverse-proxy/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Reverse Proxy Generator</a>
      </div>
    </section>
  </main>
</Layout>
