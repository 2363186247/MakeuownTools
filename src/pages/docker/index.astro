---
import Layout from '../../layouts/Layout.astro';
import services from '../../data/services.json';

type App = (typeof services.apps)[number];
type Database = (typeof services.databases)[number];
type Proxy = (typeof services.proxies)[number];

type Combo = { app: App; db: Database; proxy: Proxy; href: string };

const combinations: Combo[] = [];

services.apps.forEach((app) => {
  services.databases.forEach((db) => {
    if (!Array.isArray(app.supported_dbs) || !app.supported_dbs.includes(db.id)) return;

    services.proxies.forEach((proxy) => {
      combinations.push({
        app,
        db,
        proxy,
        href: `/docker/${app.id}-${db.id}-${proxy.id}/`
      });
    });
  });
});

const appGroups = services.apps
  .map((app) => ({
    app,
    combinations: combinations.filter((item) => item.app.id === app.id)
  }))
  .filter((group) => group.combinations.length > 0);

const totalCombinations = combinations.length;
---

<Layout
  title="The Ultimate Docker Compose Generator"
  description={`Generate ${totalCombinations} production-ready docker-compose presets for popular self-hosted apps with compatible databases and reverse proxies.`}
  canonical="/docker/"
>
  <main class="mx-auto w-full max-w-7xl px-6 py-14 md:px-8 md:py-20">
    <a
      href="/"
      class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-200 transition hover:border-white/30 hover:bg-white/10"
    >
      <span>←</span>
      <span>Home</span>
    </a>

      <section class="mb-12 text-center md:mb-16">
        <p class="mx-auto mb-4 inline-flex items-center rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-[11px] uppercase tracking-[0.2em] text-zinc-300">
          Production-Ready Config Navigation
        </p>
        <h1 class="text-4xl font-semibold tracking-tight text-white md:text-6xl">
          The Ultimate Docker Compose Generator
        </h1>
        <p class="mx-auto mt-5 max-w-3xl text-sm leading-7 text-zinc-300 md:text-base">
          Explore all valid deployment routes generated from your services catalog. Every route below is an explicit anchor link,
          so crawlers can discover and index the full app-database-proxy graph.
        </p>

        <div class="mx-auto mt-7 grid max-w-2xl grid-cols-3 gap-3 text-left md:gap-4">
          <div class="rounded-xl border border-white/10 bg-white/[0.04] p-4">
            <p class="text-xs uppercase tracking-[0.14em] text-zinc-400">Apps</p>
            <p class="mt-1 text-2xl font-semibold text-white">{services.apps.length}</p>
          </div>
          <div class="rounded-xl border border-white/10 bg-white/[0.04] p-4">
            <p class="text-xs uppercase tracking-[0.14em] text-zinc-400">Databases</p>
            <p class="mt-1 text-2xl font-semibold text-white">{services.databases.length}</p>
          </div>
          <div class="rounded-xl border border-white/10 bg-white/[0.04] p-4">
            <p class="text-xs uppercase tracking-[0.14em] text-zinc-400">Routes</p>
            <p class="mt-1 text-2xl font-semibold text-white">{totalCombinations}</p>
          </div>
        </div>
      </section>

      <section class="mb-8 rounded-3xl border border-cyan-300/20 bg-cyan-500/[0.06] p-6 md:p-8">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-cyan-100">Docker Cluster Guides</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <a href="/docker/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">
            Docker Hub
          </a>
          <a href="/docker/compare/reverse-proxy-comparison/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">
            Compare: Nginx vs Caddy vs Traefik
          </a>
          <a href="/docker/decision/stack-selector/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">
            Decision: Stack Selector
          </a>
          <a href="/docker/faq/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">
            FAQ: Deployment Playbook
          </a>
        </div>
      </section>

      <section class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {appGroups.map((group) => (
          <details class="group overflow-hidden rounded-2xl border border-white/10 bg-black/20 backdrop-blur-sm open:border-white/20">
            <summary class="flex cursor-pointer list-none items-center justify-between px-5 py-5 transition hover:bg-white/[0.03]">
              <div>
                <h2 class="text-xl font-semibold text-white">{group.app.name}</h2>
                <p class="mt-1 font-mono text-xs text-zinc-400">{group.app.image}</p>
              </div>
              <div class="ml-4 flex items-center gap-3">
                <span class="rounded-md border border-white/10 bg-white/[0.04] px-2 py-1 text-xs text-zinc-300">
                  {group.combinations.length} links
                </span>
                <span class="text-zinc-400 transition group-open:rotate-180">⌄</span>
              </div>
            </summary>

            <div class="border-t border-white/10 bg-black/10 px-4 py-4">
              <ul class="space-y-2">
                {group.combinations.map((combo) => (
                  <li>
                    <a
                      href={combo.href}
                      class="flex items-center justify-between rounded-lg border border-white/10 bg-white/[0.03] px-3 py-2.5 text-sm text-zinc-200 transition hover:border-white/25 hover:bg-white/[0.08]"
                    >
                      <span class="truncate">
                        {group.app.name} + {combo.db.name} + {combo.proxy.name}
                      </span>
                      <span class="ml-3 font-mono text-xs text-zinc-400">/{combo.app.id}-{combo.db.id}-{combo.proxy.id}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))}
      </section>

      <section class="mt-8 rounded-3xl border border-white/12 bg-white/[0.02] p-6 md:p-7">
        <div class="mb-4 flex items-center justify-between gap-3">
          <h3 class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-zinc-300">
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-cyan-200" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 12h16"/><path d="M12 4v16"/></svg>
            Ingress Layer Tools
          </h3>
          <span class="text-xs uppercase tracking-[0.14em] text-zinc-500">New Utility</span>
        </div>
        <a href="/reverse-proxy/" class="group block rounded-2xl border border-cyan-300/25 bg-gradient-to-br from-cyan-300/12 to-blue-500/10 p-5 transition hover:border-cyan-200/40">
          <p class="text-xs uppercase tracking-[0.16em] text-cyan-100">Reverse Proxy Config Generator</p>
          <h4 class="mt-2 text-xl font-semibold tracking-tight text-white">Generate Nginx, Caddy, and Traefik Configs</h4>
          <p class="mt-2 text-sm leading-7 text-zinc-200">Configure HTTPS, websocket, CORS, compression, and upload limits without hand-writing proxy files.</p>
          <p class="mt-3 inline-flex items-center gap-1 text-xs font-semibold uppercase tracking-[0.14em] text-cyan-100">Open Tool <span class="transition group-hover:translate-x-0.5">→</span></p>
        </a>
      </section>
  </main>
</Layout>
