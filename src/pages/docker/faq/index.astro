---
import Layout from '../../../layouts/Layout.astro';
import services from '../../../data/services.json';

const faqItems = [
  {
    question: 'How do I pick the first database for an app stack?',
    answer: 'Start with the officially supported database for that app and your team familiarity. If both MySQL and PostgreSQL are available, prioritize operational consistency with your existing backups and monitoring.'
  },
  {
    question: 'When should I use Traefik instead of Nginx or Caddy?',
    answer: 'Use Traefik when you run many services and want label-driven routing with dynamic discovery. Nginx and Caddy are often simpler for a small number of static routes.'
  },
  {
    question: 'Do generated stacks include production security defaults?',
    answer: 'The generated stacks are deployment-ready baselines. You should still set strong secrets, isolate networks, configure TLS certificates, and add container resource limits.'
  },
  {
    question: 'Can I add Redis, workers, or object storage to these stacks?',
    answer: 'Yes. Treat each generated stack as a core template, then append additional services for queue workers, caches, and backups based on your workload.'
  },
  {
    question: 'How should I version-control docker-compose output?',
    answer: 'Commit generated compose files with environment placeholders, then keep secrets outside git. Use one directory per environment and review changes via pull requests.'
  },
  {
    question: 'What is the safest migration path between proxies?',
    answer: 'Deploy the target proxy in parallel, mirror routing and health checks, validate headers and websocket behavior, then cut traffic and remove old ingress.'
  }
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};

const sampleStacks = services.apps
  .slice(0, 9)
  .flatMap((app) => {
    const db = services.databases.find((candidate) => app.supported_dbs.includes(candidate.id));
    const proxy = services.proxies[0];
    if (!db || !proxy) return [];

    return [{
      label: `${app.name} + ${db.name} + ${proxy.name}`,
      href: `/docker/${app.id}-${db.id}-${proxy.id}/`
    }];
  });
---

<Layout
  title="Docker Compose FAQ | Stack, Proxy, and Deployment Questions"
  description="Practical Docker Compose FAQ for stack selection, reverse proxy choice, migration strategy, and deployment hardening."
  canonical="/docker/faq/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>
  </Fragment>

  <main class="mx-auto w-full max-w-7xl px-6 py-10 md:px-8 md:py-14">
    <a href="/docker/" class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-300 transition hover:bg-white/10">
      <span>&larr;</span>
      <span>Docker Hub</span>
    </a>

    <header class="mb-8 rounded-3xl border border-white/15 bg-white/[0.03] p-6 md:p-8">
      <p class="mb-3 inline-flex items-center rounded-full border border-cyan-400/35 bg-cyan-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-cyan-100">Cluster FAQ Page</p>
      <h1 class="text-3xl font-semibold tracking-tight text-white md:text-5xl">Docker Compose FAQ</h1>
      <p class="mt-4 max-w-4xl text-sm leading-7 text-zinc-300 md:text-base">
        High-frequency implementation questions from teams deploying application, database, and reverse proxy stacks in production.
      </p>
    </header>

    <section class="space-y-3">
      {faqItems.map((item) => (
        <article class="rounded-2xl border border-white/10 bg-black/30 p-5">
          <h2 class="text-sm font-semibold text-white md:text-base">{item.question}</h2>
          <p class="mt-2 text-sm leading-7 text-zinc-300">{item.answer}</p>
        </article>
      ))}
    </section>

    <section class="mt-8 rounded-3xl border border-white/10 bg-white/[0.02] p-6 md:p-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-300">Sample Stack Routes</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {sampleStacks.map((item) => (
          <a href={item.href} class="rounded-xl border border-white/10 bg-black/25 px-3 py-2 text-sm text-zinc-200 transition hover:border-cyan-300/40 hover:text-white">
            {item.label}
          </a>
        ))}
      </div>
    </section>

    <section class="mt-8 rounded-3xl border border-cyan-300/20 bg-cyan-500/[0.06] p-6 md:p-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-cyan-100">Docker Cluster Navigation</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/docker/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Docker Hub</a>
        <a href="/docker/compare/reverse-proxy-comparison/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Comparison Page</a>
        <a href="/docker/decision/stack-selector/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Decision Page</a>
        <a href="/reverse-proxy/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/45 hover:text-white">Reverse Proxy Generator</a>
      </div>
    </section>
  </main>
</Layout>
