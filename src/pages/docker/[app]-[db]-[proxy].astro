---
// src/pages/docker/[app]-[db]-[proxy].astro
import Layout from '../../layouts/Layout.astro';
import services from '../../data/services.json';

type App = (typeof services.apps)[number];
type Database = (typeof services.databases)[number];
type Proxy = (typeof services.proxies)[number];

type StaticPathItem = {
  params: { app: string; db: string; proxy: string };
  props: { app: App; db: Database; proxy: Proxy };
};

type StackRoute = {
  app: App;
  db: Database;
  proxy: Proxy;
};

function buildAllStackRoutes(): StackRoute[] {
  const routes: StackRoute[] = [];

  services.apps.forEach((app) => {
    services.databases.forEach((db) => {
      if (!Array.isArray(app.supported_dbs) || !app.supported_dbs.includes(db.id)) return;

      services.proxies.forEach((proxy) => {
        routes.push({ app, db, proxy });
      });
    });
  });

  return routes;
}

// getStaticPaths is an Astro core hook and runs at build time.
// Build all valid route combinations by multiplying compatible options.
export function getStaticPaths() {
  const paths: StaticPathItem[] = [];

  services.apps.forEach(app => {
    services.databases.forEach(db => {
      if (!Array.isArray(app.supported_dbs) || !app.supported_dbs.includes(db.id)) return;

      services.proxies.forEach(proxy => {
        // Generate a unique URL path and pass matching data as props.
        paths.push({
          params: { app: app.id, db: db.id, proxy: proxy.id },
          props: { app, db, proxy }
        });
      });
    });
  });
  
  return paths;
}

// Receive the single-page props from getStaticPaths.
const { app, db, proxy } = Astro.props as { app: App; db: Database; proxy: Proxy };

const appDbMapping = app.db_env_mapping ?? {};
const dbInitMapping = db.init_env_mapping ?? {};

const sharedDbValues = {
  host: `\${APP_DB_HOST:-${db.id}}`,
  user: `\${APP_DB_USER:-app_user}`,
  password: `\${APP_DB_PASSWORD:-change_me_app_password}`,
  name: `\${APP_DB_NAME:-${app.id}_db}`
};

const appDbEnvEntries = [
  [appDbMapping.host, sharedDbValues.host],
  [appDbMapping.user, sharedDbValues.user],
  [appDbMapping.password, sharedDbValues.password],
  [appDbMapping.name, sharedDbValues.name]
].filter(([key]) => Boolean(key));

const dbInitEnvEntries = [
  [dbInitMapping.root_password, `\${DB_ROOT_PASSWORD:-change_me_root_password}`],
  [dbInitMapping.user, sharedDbValues.user],
  [dbInitMapping.password, sharedDbValues.password],
  [dbInitMapping.name, sharedDbValues.name]
].filter(([key]) => Boolean(key));

const appEnvBlock = appDbEnvEntries.length
  ? `\n    environment:\n${appDbEnvEntries.map(([key, value]) => `      ${key}: ${value}`).join('\n')}`
  : '';

const dbEnvBlock = dbInitEnvEntries.length
  ? `\n    environment:\n${dbInitEnvEntries.map(([key, value]) => `      ${key}: ${value}`).join('\n')}`
  : '';

const proxyHttpPort = proxy.http_port ?? '80';
const proxyHttpsPort = proxy.https_port ?? '443';
const dbVolumePath = db.volume_path ?? '/var/lib/data';

const proxyExtraBlock = proxy.id === 'traefik'
  ? `\n    command:\n      - --providers.docker=true\n      - --entrypoints.web.address=:80\n      - --entrypoints.websecure.address=:443\n    volumes:\n      - /var/run/docker.sock:/var/run/docker.sock:ro`
  : '';

const relatedStacks = [
  ...services.apps
    .filter((entry) => entry.id !== app.id)
    .slice(0, 3)
    .flatMap((entry) => {
      const compatibleDb = services.databases.find((candidate) => entry.supported_dbs.includes(candidate.id));
      if (!compatibleDb) return [];
      return [{
        label: `${entry.name} + ${compatibleDb.name} + ${proxy.name}`,
        href: `/docker/${entry.id}-${compatibleDb.id}-${proxy.id}/`
      }];
    }),
  ...services.proxies
    .filter((entry) => entry.id !== proxy.id)
    .slice(0, 2)
    .map((entry) => ({
      label: `${app.name} + ${db.name} + ${entry.name}`,
      href: `/docker/${app.id}-${db.id}-${entry.id}/`
    }))
].slice(0, 6);

const allStacks = buildAllStackRoutes();
const currentStackIndex = allStacks.findIndex(
  (entry) => entry.app.id === app.id && entry.db.id === db.id && entry.proxy.id === proxy.id
);
const hasStackRing = currentStackIndex !== -1;
const prevStack = hasStackRing
  ? allStacks[(currentStackIndex - 1 + allStacks.length) % allStacks.length]
  : null;
const nextStack = hasStackRing
  ? allStacks[(currentStackIndex + 1) % allStacks.length]
  : null;

// Compose YAML is generated from template strings.
// Keep indentation aligned so the output remains valid YAML.
const composeYml = `
version: '3.8'
services:
  ${app.id}:
    image: ${app.image}
    ports:
      - "${app.port}:${app.port}"
    depends_on:
      - ${db.id}
${appEnvBlock}
    restart: always

  ${db.id}:
    image: ${db.image}
    ports:
      - "${db.port}:${db.port}"
${dbEnvBlock}
    volumes:
      - ${db.id}_data:${dbVolumePath}
    restart: always

  ${proxy.id}:
    image: ${proxy.image}
    ports:
      - "${proxyHttpPort}:80"
      - "${proxyHttpsPort}:443"
    depends_on:
      - ${app.id}
${proxyExtraBlock}
    restart: always

volumes:
  ${db.id}_data:
`.trim();
---

<Layout
  title={`${app.name} + ${db.name} + ${proxy.name} Docker Compose`}
  description={`Generate a production-ready docker-compose.yml for ${app.name}, ${db.name}, and ${proxy.name}.`}
>
  <main class="mx-auto w-full max-w-7xl px-6 py-16 md:px-8 md:py-20">
      <!-- Header -->
      <div class="mb-12 flex flex-col items-start gap-2">
        <a href="/docker/" class="text-xs font-medium uppercase tracking-[0.16em] text-zinc-400 hover:text-zinc-200 transition">← Back</a>
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-white">
          Your Stack
        </h1>
      </div>

      <!-- Stack Overview (Inline Badges) -->
      <div class="mb-12 flex flex-wrap items-center gap-3">
        <!-- App Badge -->
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl border border-zinc-700 bg-zinc-800/50 backdrop-blur-sm hover:border-zinc-600 transition">
          <div class="w-2 h-2 rounded-full bg-blue-400"></div>
          <span class="font-mono text-xs font-semibold text-zinc-300">App:</span>
          <span class="font-medium text-white">{app.name}</span>
          <span class="px-2 py-0.5 rounded-md bg-zinc-700/50 font-mono text-[11px] text-zinc-400 ml-1">
            {app.image.includes(':') ? app.image.split(':').pop() : 'latest'}
          </span>
        </div>

        <!-- Connector -->
        <div class="hidden sm:block text-zinc-600 select-none">→</div>

        <!-- Database Badge -->
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl border border-zinc-700 bg-zinc-800/50 backdrop-blur-sm hover:border-zinc-600 transition">
          <div class="w-2 h-2 rounded-full bg-amber-400"></div>
          <span class="font-mono text-xs font-semibold text-zinc-300">DB:</span>
          <span class="font-medium text-white">{db.name}</span>
          <span class="px-2 py-0.5 rounded-md bg-zinc-700/50 font-mono text-[11px] text-zinc-400 ml-1">
            {db.image.includes(':') ? db.image.split(':').pop() : 'latest'}
          </span>
        </div>

        <!-- Connector -->
        <div class="hidden sm:block text-zinc-600 select-none">→</div>

        <!-- Proxy Badge -->
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl border border-zinc-700 bg-zinc-800/50 backdrop-blur-sm hover:border-zinc-600 transition">
          <div class="w-2 h-2 rounded-full bg-purple-400"></div>
          <span class="font-mono text-xs font-semibold text-zinc-300">Proxy:</span>
          <span class="font-medium text-white">{proxy.name}</span>
          <span class="px-2 py-0.5 rounded-md bg-zinc-700/50 font-mono text-[11px] text-zinc-400 ml-1">
            {proxy.image.includes(':') ? proxy.image.split(':').pop() : 'latest'}
          </span>
        </div>
      </div>

      <!-- Description -->
      <p class="mb-8 text-lg text-zinc-300 md:text-base leading-relaxed max-w-2xl">
        Production-ready <span class="font-mono text-zinc-200">docker-compose.yml</span> for your stack.
        Copy it, customize variables in <span class="font-mono text-zinc-200">.env</span>, and deploy.
      </p>

      <!-- Code Block -->
      <div class="relative group">
        <!-- Glow Effect -->
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-600/20 to-purple-600/20 rounded-2xl blur opacity-75 group-hover:opacity-100 transition duration-300"></div>

        <!-- Code Container -->
        <section class="relative overflow-hidden rounded-2xl border border-zinc-700/50 bg-zinc-900/80 backdrop-blur-xl shadow-2xl">
          <!-- Header -->
          <header class="flex items-center justify-between border-b border-zinc-700/50 px-5 py-4 md:px-6">
            <div class="flex items-center gap-3">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
                <div class="w-3 h-3 rounded-full bg-amber-500/70"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
              </div>
              <span class="font-mono text-xs font-semibold text-zinc-400">docker-compose.yml</span>
            </div>
            <div class="flex items-center gap-2">
              <button
                id="downloadButton"
                type="button"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border border-zinc-600 bg-zinc-800/50 text-zinc-300 hover:border-zinc-500 hover:bg-zinc-700/50 hover:text-zinc-100 transition"
                title="Download as file"
              >
                ↓ Download
              </button>
              <button
                id="copyButton"
                type="button"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border border-blue-500/50 bg-blue-500/10 text-blue-300 hover:border-blue-400 hover:bg-blue-500/20 hover:text-blue-100 transition"
              >
                📋 Copy
              </button>
            </div>
          </header>

          <!-- Code -->
          <pre class="max-h-[70vh] overflow-auto p-5 md:p-6 text-sm leading-relaxed text-zinc-200 font-mono"><code id="composeCode">{composeYml}</code></pre>
        </section>
      </div>

      <!-- Footer Note -->
      <div class="mt-8 pt-8 border-t border-zinc-700/30 text-center text-sm text-zinc-400">
        <p>Customize <span class="font-mono text-zinc-300">APP_DB_*</span> and <span class="font-mono text-zinc-300">DB_*</span> variables in your <span class="font-mono text-zinc-300">.env</span> file.</p>
      </div>

      <section class="mt-8 rounded-3xl border border-cyan-300/20 bg-cyan-500/[0.06] p-6 md:p-8">
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-widest text-cyan-100">Docker Cluster Guides</h3>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <a href="/docker/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-3 py-2 text-sm text-zinc-200 transition hover:border-cyan-300/40 hover:text-white">
            Docker Hub
          </a>
          <a href="/docker/compare/reverse-proxy-comparison/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-3 py-2 text-sm text-zinc-200 transition hover:border-cyan-300/40 hover:text-white">
            Compare Proxies
          </a>
          <a href="/docker/decision/stack-selector/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-3 py-2 text-sm text-zinc-200 transition hover:border-cyan-300/40 hover:text-white">
            Stack Selector
          </a>
          <a href="/docker/faq/" class="rounded-xl border border-cyan-200/25 bg-black/30 px-3 py-2 text-sm text-zinc-200 transition hover:border-cyan-300/40 hover:text-white">
            Docker FAQ
          </a>
        </div>
      </section>

      <section class="mt-8 rounded-3xl border border-white/10 bg-white/[0.02] p-6 md:p-8">
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-300">Related Docker Compose Stacks</h3>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {relatedStacks.map((stack) => (
            <a href={stack.href} class="rounded-xl border border-white/10 bg-black/30 px-3 py-2 text-sm text-zinc-200 transition hover:border-cyan-300/40 hover:text-white">
              {stack.label}
            </a>
          ))}
        </div>
      </section>

      {hasStackRing && prevStack && nextStack && (
        <section class="mt-8 rounded-3xl border border-cyan-300/20 bg-cyan-500/[0.06] p-6 md:p-8">
          <h3 class="mb-4 text-sm font-semibold uppercase tracking-widest text-cyan-100">Stack Ring Navigation</h3>
          <div class="grid gap-3 md:grid-cols-2">
            <a
              href={`/docker/${prevStack.app.id}-${prevStack.db.id}-${prevStack.proxy.id}/`}
              class="rounded-xl border border-cyan-200/20 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/40 hover:text-white"
            >
              ← Previous: {prevStack.app.name} + {prevStack.db.name} + {prevStack.proxy.name}
            </a>
            <a
              href={`/docker/${nextStack.app.id}-${nextStack.db.id}-${nextStack.proxy.id}/`}
              class="rounded-xl border border-cyan-200/20 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-cyan-200/40 hover:text-white"
            >
              Next: {nextStack.app.name} + {nextStack.db.name} + {nextStack.proxy.name} →
            </a>
          </div>
        </section>
      )}
  </main>

  <script>
      const copyButton = document.getElementById('copyButton');
      const downloadButton = document.getElementById('downloadButton');
      const composeCode = document.getElementById('composeCode');

      if (copyButton && composeCode) {
        copyButton.addEventListener('click', async () => {
          const originalText = copyButton.textContent;
          try {
            await navigator.clipboard.writeText(composeCode.textContent || '');
            copyButton.textContent = '✓ Copied!';
            copyButton.classList.add('border-emerald-500/50', 'bg-emerald-500/20', 'text-emerald-300');
            copyButton.classList.remove('border-blue-500/50', 'bg-blue-500/10', 'text-blue-300');
            setTimeout(() => {
              copyButton.textContent = originalText;
              copyButton.classList.remove('border-emerald-500/50', 'bg-emerald-500/20', 'text-emerald-300');
              copyButton.classList.add('border-blue-500/50', 'bg-blue-500/10', 'text-blue-300');
            }, 2000);
          } catch (err) {
            copyButton.textContent = '✗ Failed';
            copyButton.classList.add('border-rose-500/50', 'bg-rose-500/20', 'text-rose-300');
            setTimeout(() => {
              copyButton.textContent = originalText;
              copyButton.classList.remove('border-rose-500/50', 'bg-rose-500/20', 'text-rose-300');
            }, 2000);
          }
        });
      }

      if (downloadButton && composeCode) {
        downloadButton.addEventListener('click', () => {
          const content = composeCode.textContent || '';
          const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
          const link = document.createElement('a');
          link.href = URL.createObjectURL(blob);
          link.download = 'docker-compose.yml';
          link.click();
          URL.revokeObjectURL(link.href);
        });
      }
  </script>
</Layout>