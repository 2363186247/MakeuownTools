---
import Layout from '../../../layouts/Layout.astro';
import {
  RAID_LABEL,
  calculateNasRaid,
  getNasRaidSeoEntries,
  getScenarioEntries,
  type ComparisonEntry,
  type NasRaidSeoEntry,
  type RaidLevel,
  type ScenarioEntry
} from '../../../data/nasRaidSeo';

export function getStaticPaths() {
  return getNasRaidSeoEntries().map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

type Props = { entry: NasRaidSeoEntry };
const { entry } = Astro.props as Props;

const allNasEntries = getNasRaidSeoEntries();
const currentNasIndex = allNasEntries.findIndex((item) => item.slug === entry.slug);
const prevNasEntry = currentNasIndex >= 0
  ? allNasEntries[(currentNasIndex - 1 + allNasEntries.length) % allNasEntries.length]
  : null;
const nextNasEntry = currentNasIndex >= 0
  ? allNasEntries[(currentNasIndex + 1) % allNasEntries.length]
  : null;

const popularScenarios = getScenarioEntries().slice(0, 16);

function fmtTb(value: number): string {
  return `${value.toFixed(2)} TB`;
}

function levelAdvice(level: RaidLevel): string {
  switch (level) {
    case 'raid0': return 'Maximum capacity and speed, but any single disk failure loses the whole array.';
    case 'raid1': return 'Strong redundancy but low capacity efficiency. Great for small, critical datasets.';
    case 'raid5': return 'Balanced capacity and redundancy, but rebuild stress can be high on large disks.';
    case 'raid6': return 'Safer for larger arrays with dual parity, at the cost of one extra parity disk.';
    case 'raid10': return 'Excellent random I/O and rebuild behavior; capacity is typically 50% of raw.';
    case 'raidz1': return 'ZFS single-parity equivalent of RAID 5; common for smaller homelab pools.';
    case 'raidz2': return 'Popular TrueNAS default for medium arrays; dual-parity with good safety margin.';
    case 'raidz3': return 'High resiliency for big pools and long rebuild windows, but lowest efficiency.';
  }
}

const pageTitle = entry.title;
const pageDescription = entry.description;
const siteOrigin = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://makeyourowntools.com';
const canonicalUrl = `${siteOrigin}/calculator/nas-raid/${entry.slug}/`;

let scenarioResult: ReturnType<typeof calculateNasRaid> | null = null;
let comparisonRows: Array<{ drives: number; left: ReturnType<typeof calculateNasRaid>; right: ReturnType<typeof calculateNasRaid> }> = [];
let scenarioTable: Array<{ level: RaidLevel; result: ReturnType<typeof calculateNasRaid> }> = [];
let faqItems: Array<{ question: string; answer: string }> = [];
let brandRegionHeadline = '';
let brandRegionBody = '';
let brandRegionTips: string[] = [];
let glossaryTerms: Array<{ term: string; definition: string }> = [];

const BRAND_CONTENT: Record<string, { headline: string; body: string; tips: string[] }> = {
  synology: {
    headline: 'Synology Planning Notes',
    body: 'Synology users usually optimize for predictable rebuild behavior and conservative free-space policies, especially when using large-capacity SHR/RAID pools for media and backup workloads.',
    tips: [
      'Keep spare bays in your growth plan so expansions do not force emergency migrations.',
      'Budget extra free space for snapshot retention and background indexing tasks.',
      'Prefer dual-parity style layouts for larger pools with long rebuild windows.'
    ]
  },
  qnap: {
    headline: 'QNAP Planning Notes',
    body: 'QNAP buyers often compare capacity efficiency against service consolidation needs, where VM storage, containers, and media serving all compete for IOPS and free space.',
    tips: [
      'Model around mixed workloads: media throughput plus VM random I/O.',
      'Reserve enough headroom so thin-provisioned services do not overrun the array.',
      'When in doubt, prioritize safer parity for arrays above 6 drives.'
    ]
  },
  truenas: {
    headline: 'TrueNAS / ZFS Planning Notes',
    body: 'TrueNAS and ZFS planners usually care about parity width, scrub cadence, and healthy operating headroom. Capacity is only one part of pool durability.',
    tips: [
      'Treat RAID-Z2 as a common baseline for medium and large homelab pools.',
      'Keep meaningful free space to reduce fragmentation pressure under snapshots.',
      'Plan vdev growth strategy early, since expansion paths affect long-term efficiency.'
    ]
  },
  unraid: {
    headline: 'Unraid Planning Notes',
    body: 'Unraid users often optimize for incremental growth and flexible disk replacement, where parity planning and usable capacity targets evolve over time rather than all at once.',
    tips: [
      'Capacity plans should include phased drive upgrades, not only day-one layout.',
      'Use parity-protected growth steps to avoid risky bulk migrations.',
      'Track cache and parity pressure separately from archive data growth.'
    ]
  }
};

const REGION_CONTENT: Record<string, { headline: string; body: string; tips: string[] }> = {
  us: {
    headline: 'US Buyer Context',
    body: 'US buyers often evaluate frequent pricing swings and promo cycles. Capacity planning should account for staged purchases instead of one-time all-disk upgrades.',
    tips: ['Use parity layouts that remain valid during phased expansions.', 'Compare total usable-per-dollar across multiple disk sizes, not only one SKU.']
  },
  uk: {
    headline: 'UK Buyer Context',
    body: 'UK homelab planners commonly balance higher per-drive pricing with power and chassis constraints, so efficient but resilient layouts become more valuable.',
    tips: ['Model dual-parity options early if rebuild time is a concern.', 'Include reserve headroom to avoid running pools at high fill percentages.']
  },
  eu: {
    headline: 'EU Buyer Context',
    body: 'EU deployments often place additional emphasis on energy efficiency and predictable lifecycle upgrades, especially for always-on NAS fleets.',
    tips: ['Choose a layout that minimizes emergency rebuild risk under continuous operation.', 'Prefer capacity plans that survive one upgrade cycle without pool redesign.']
  },
  apac: {
    headline: 'APAC Buyer Context',
    body: 'APAC builders frequently compare availability windows and procurement variance, which makes robust fallback capacity and staged scaling useful in practice.',
    tips: ['Plan a spare strategy alongside RAID level selection.', 'Validate that chosen parity can tolerate delayed disk replacement windows.']
  }
};

const GLOSSARY_BY_BRAND: Record<string, Array<{ term: string; definition: string }>> = {
  synology: [
    { term: 'SHR', definition: 'Synology Hybrid RAID that improves flexibility when mixing drive sizes.' },
    { term: 'Btrfs Snapshots', definition: 'Point-in-time snapshots used for rollback and data protection policies.' },
    { term: 'Storage Pool', definition: 'Logical disk group where RAID layout is created before volumes are provisioned.' }
  ],
  qnap: [
    { term: 'Qtier', definition: 'QNAP auto-tiering system that moves hot and cold data across storage classes.' },
    { term: 'Storage & Snapshots', definition: 'QTS module for RAID pool management, volume control, and snapshots.' },
    { term: 'Thin Provisioning', definition: 'Allocates logical space first and consumes physical capacity over time.' }
  ],
  truenas: [
    { term: 'vdev', definition: 'A virtual device group in ZFS; multiple vdevs form a storage pool.' },
    { term: 'Scrub', definition: 'Background integrity scan that verifies checksums and repairs parity mismatches.' },
    { term: 'RAID-Z Expansion', definition: 'ZFS feature set and planning topic for growing parity groups safely.' }
  ],
  unraid: [
    { term: 'Parity Disk', definition: 'Dedicated parity disk(s) protecting data disks in the Unraid array model.' },
    { term: 'Cache Pool', definition: 'Fast SSD/NVMe pool used for writes and application workloads.' },
    { term: 'Mover', definition: 'Scheduled process that migrates data between cache and array tiers.' }
  ]
};

const GLOSSARY_BY_REGION: Record<string, Array<{ term: string; definition: string }>> = {
  us: [
    { term: 'Cost-per-Usable-TB', definition: 'Planning metric that compares real usable capacity after reserve and parity.' },
    { term: 'Promo Window', definition: 'Seasonal pricing period used for phased drive purchasing strategies.' }
  ],
  uk: [
    { term: 'Power Budget', definition: 'Expected always-on energy usage cost factored into NAS layout decisions.' },
    { term: 'Rebuild Window', definition: 'Estimated time exposure while replacing a failed drive and restoring parity.' }
  ],
  eu: [
    { term: 'Lifecycle Planning', definition: 'Capacity and reliability strategy across multiple hardware refresh cycles.' },
    { term: 'Operational Headroom', definition: 'Intentional free-space margin to protect performance and snapshot behavior.' }
  ],
  apac: [
    { term: 'Procurement Variance', definition: 'Regional differences in disk availability and replacement lead times.' },
    { term: 'Spare Strategy', definition: 'Policy of keeping spare disks available to reduce recovery delay risk.' }
  ]
};

function slugSeed(slug: string): number {
  let seed = 0;
  for (let i = 0; i < slug.length; i += 1) {
    seed = (seed * 31 + slug.charCodeAt(i)) % 1000003;
  }
  return seed;
}

function pickBySeed<T>(items: T[], count: number, seed: number): T[] {
  const copy = [...items];
  const picked: T[] = [];
  let current = seed;

  while (copy.length > 0 && picked.length < count) {
    const index = current % copy.length;
    picked.push(copy.splice(index, 1)[0]);
    current = (current * 131 + 17) % 1000003;
  }

  return picked;
}

function keywordPrefixText(item: NasRaidSeoEntry): string {
  if (!item.keywordLabel) return 'This NAS planning scenario';
  if (item.keywordKind === 'brand') return `For ${item.keywordLabel} users, this NAS planning scenario`;
  return `For ${item.keywordLabel} homelab buyers, this NAS planning scenario`;
}

function synonymOf(key: 'choose' | 'compare' | 'usable' | 'capacity' | 'risk' | 'practical', seed: number): string {
  const map: Record<string, string[]> = {
    choose: ['choose', 'pick', 'select'],
    compare: ['compare', 'evaluate', 'benchmark'],
    usable: ['usable', 'real-world usable', 'effective'],
    capacity: ['capacity', 'storage headroom', 'available space'],
    risk: ['risk', 'failure exposure', 'rebuild risk'],
    practical: ['practical', 'worth deploying', 'viable']
  };
  const list = map[key];
  return list[seed % list.length];
}

function applyFaqVariants(items: Array<{ question: string; answer: string }>, slug: string): Array<{ question: string; answer: string }> {
  const seed = slugSeed(slug);
  return items.map((item, index) => {
    const localSeed = seed + index * 97;
    const q = item.question
      .replace('usable', synonymOf('usable', localSeed + 1))
      .replace('capacity', synonymOf('capacity', localSeed + 2))
      .replace('compare', synonymOf('compare', localSeed + 3))
      .replace('choose', synonymOf('choose', localSeed + 4))
      .replace('risk', synonymOf('risk', localSeed + 5))
      .replace('practical', synonymOf('practical', localSeed + 6));
    return { ...item, question: q };
  });
}

if (entry.type === 'scenario') {
  const scenario = entry as ScenarioEntry;
  scenarioResult = calculateNasRaid(scenario.level, scenario.drives, scenario.sizeTb, scenario.reservePct);

  const compareLevels: RaidLevel[] = ['raid5', 'raid6', 'raid10', 'raidz1', 'raidz2'];
  scenarioTable = compareLevels.map((level) => ({
    level,
    result: calculateNasRaid(level, scenario.drives, scenario.sizeTb, scenario.reservePct)
  }));

  const prefix = keywordPrefixText(entry);
  const scenarioFaqPool = [
    {
      question: `How much usable storage does ${scenario.drives}x ${scenario.sizeTb}TB ${RAID_LABEL[scenario.level]} provide?`,
      answer: `${prefix} estimates ${scenarioResult.usableAfterReserve.toFixed(2)} TB usable after a ${scenario.reservePct}% reserve from ${scenarioResult.raw.toFixed(2)} TB raw.`
    },
    {
      question: `How many disk failures can ${RAID_LABEL[scenario.level]} tolerate in this setup?`,
      answer: `This setup can tolerate ${scenarioResult.tolerance}. Real-world survivability depends on mirror placement, rebuild stress, and drive health.`
    },
    {
      question: `Why include a ${scenario.reservePct}% reserve when planning NAS capacity?`,
      answer: `Keeping free space improves filesystem behavior for snapshots, metadata, and write performance. Full arrays often perform worse and rebuild more slowly.`
    },
    {
      question: `Is ${RAID_LABEL[scenario.level]} still practical with ${scenario.sizeTb}TB drives?`,
      answer: `It can be practical, but larger drives increase rebuild windows. Validate parity choice and backup policy before committing to the final layout.`
    },
    {
      question: `Should I optimize this ${scenario.drives}-drive plan for capacity or resiliency first?`,
      answer: `For long-lived NAS pools, resiliency first is usually safer. Capacity can be expanded later, while a risky parity choice can force migration sooner.`
    },
    {
      question: `Can this calculator replace real-world benchmark and rebuild testing?`,
      answer: `No. Use this page for pre-purchase sizing, then validate with workload benchmarks, SMART health policy, and a tested restore plan.`
    }
  ];

  faqItems = applyFaqVariants(pickBySeed(scenarioFaqPool, 4, slugSeed(entry.slug)), entry.slug);
}

if (entry.type === 'comparison') {
  const comparison = entry as ComparisonEntry;
  const driveSet = [4, 6, 8, 10, 12];
  const sizeTb = 8;
  comparisonRows = driveSet.map((drives) => ({
    drives,
    left: calculateNasRaid(comparison.left, drives, sizeTb, 10),
    right: calculateNasRaid(comparison.right, drives, sizeTb, 10)
  }));

  const prefix = keywordPrefixText(entry);
  const comparisonFaqPool = [
    {
      question: `Which has more usable capacity: ${RAID_LABEL[comparison.left]} or ${RAID_LABEL[comparison.right]}?`,
      answer: `${prefix} compares both modes at fixed drive sizes so you can see usable capacity differences before buying disks.`
    },
    {
      question: `How should I choose between ${RAID_LABEL[comparison.left]} and ${RAID_LABEL[comparison.right]}?`,
      answer: `Choose based on your risk tolerance, rebuild window, and performance profile. Higher parity usually lowers capacity but improves resilience.`
    },
    {
      question: 'Does this comparison include filesystem reserve?',
      answer: 'Yes. The comparison table applies a 10% reserve baseline to reflect realistic operating headroom in NAS and homelab environments.'
    },
    {
      question: `Does ${RAID_LABEL[comparison.left]} rebuild faster than ${RAID_LABEL[comparison.right]}?`,
      answer: 'Rebuild behavior depends on array width, disk size, and workload pressure. This page focuses on capacity and tolerance; benchmark your actual platform before final choice.'
    },
    {
      question: `Which option is usually better for long-term homelab growth?`,
      answer: 'The better option is the one that keeps acceptable usable capacity while preserving safety margins during future disk expansions.'
    },
    {
      question: `Can two layouts with similar capacity still have very different risk?`,
      answer: 'Yes. Similar usable TB does not imply similar failure tolerance or rebuild exposure. Capacity and resiliency should be evaluated together.'
    }
  ];

  faqItems = applyFaqVariants(pickBySeed(comparisonFaqPool, 4, slugSeed(entry.slug)), entry.slug);
}

if (entry.keywordKind === 'brand' && entry.keywordKey) {
  const brand = BRAND_CONTENT[entry.keywordKey];
  if (brand) {
    brandRegionHeadline = brand.headline;
    brandRegionBody = brand.body;
    brandRegionTips = brand.tips;
    glossaryTerms = GLOSSARY_BY_BRAND[entry.keywordKey] ?? [];
  }
}

if (entry.keywordKind === 'region' && entry.keywordKey) {
  const region = REGION_CONTENT[entry.keywordKey];
  if (region) {
    brandRegionHeadline = region.headline;
    brandRegionBody = region.body;
    brandRegionTips = region.tips;
    glossaryTerms = GLOSSARY_BY_REGION[entry.keywordKey] ?? [];
  }
}

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `${siteOrigin}/`
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Calculator Hub',
      item: `${siteOrigin}/calculator/`
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'NAS & RAID Storage Calculator',
      item: `${siteOrigin}/calculator/nas-raid/`
    },
    {
      '@type': 'ListItem',
      position: 4,
      name: pageTitle,
      item: canonicalUrl
    }
  ]
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>
  </Fragment>
  <main class="mx-auto w-full max-w-7xl px-6 py-10 md:px-8 md:py-14">
    <a href="/calculator/nas-raid/" class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-300 transition hover:bg-white/10">
      <span>←</span>
      <span>NAS & RAID Calculator</span>
    </a>

    <header class="mb-8 rounded-3xl border border-white/15 bg-white/[0.03] p-6 md:p-8">
      <p class="mb-3 inline-flex items-center rounded-full border border-sky-400/35 bg-sky-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-sky-100">
        NAS pSEO Landing
      </p>
      {entry.keywordLabel && (
        <p class="ml-2 mb-3 inline-flex items-center rounded-full border border-emerald-400/35 bg-emerald-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-emerald-100">
          {entry.keywordKind === 'brand' ? 'Brand Focus' : 'Region Focus'} · {entry.keywordLabel}
        </p>
      )}
      <h1 class="text-3xl font-semibold tracking-tight text-white md:text-4xl">{pageTitle.replace(' | NAS Capacity', '')}</h1>
      <p class="mt-4 max-w-4xl text-sm leading-7 text-zinc-300 md:text-base">{pageDescription}</p>
    </header>

    {entry.type === 'scenario' && scenarioResult && (
      <section class="grid gap-6 lg:grid-cols-[1fr_1.2fr]">
        <article class="rounded-3xl border border-sky-300/20 bg-gradient-to-br from-sky-400/10 to-cyan-500/5 p-6 md:p-7">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-sky-200">Capacity Snapshot</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            <div class="rounded-2xl border border-white/10 bg-black/25 p-4">
              <p class="text-xs uppercase tracking-[0.12em] text-zinc-400">Raw Capacity</p>
              <p class="mt-1 font-mono text-2xl text-white">{fmtTb(scenarioResult.raw)}</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-black/25 p-4">
              <p class="text-xs uppercase tracking-[0.12em] text-zinc-400">Usable Capacity</p>
              <p class="mt-1 font-mono text-2xl text-sky-200">{fmtTb(scenarioResult.usableAfterReserve)}</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-black/25 p-4">
              <p class="text-xs uppercase tracking-[0.12em] text-zinc-400">Fault Tolerance</p>
              <p class="mt-1 font-mono text-xl text-emerald-200">{scenarioResult.tolerance}</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-black/25 p-4">
              <p class="text-xs uppercase tracking-[0.12em] text-zinc-400">Efficiency</p>
              <p class="mt-1 font-mono text-xl text-amber-200">{scenarioResult.efficiency.toFixed(1)}%</p>
            </div>
          </div>
          <p class="mt-4 text-sm leading-7 text-zinc-300">
            {levelAdvice((entry as ScenarioEntry).level)} This scenario applies a {(entry as ScenarioEntry).reservePct}% filesystem reserve.
          </p>
          <a href="/calculator/nas-raid/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-sky-200/35 bg-sky-100/10 px-4 py-2 text-sm font-semibold text-sky-100 transition hover:bg-sky-100/20">
            Run Interactive Calculator
            <span>→</span>
          </a>
        </article>

        <article class="rounded-3xl border border-white/10 bg-black/35 p-6 md:p-7">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-300">Alternative Mode Comparison</h2>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[560px] text-left text-sm">
              <thead>
                <tr class="border-b border-white/10 text-xs uppercase tracking-[0.12em] text-zinc-400">
                  <th class="py-3">Mode</th>
                  <th class="py-3">Usable</th>
                  <th class="py-3">Tolerance</th>
                  <th class="py-3">Efficiency</th>
                </tr>
              </thead>
              <tbody class="text-zinc-200">
                {scenarioTable.map((row) => (
                  <tr class="border-b border-white/5">
                    <td class="py-3 font-medium text-white">{RAID_LABEL[row.level]}</td>
                    {row.result.valid ? (
                      <>
                        <td class="py-3 font-mono text-sky-200">{fmtTb(row.result.usableAfterReserve)}</td>
                        <td class="py-3">{row.result.tolerance}</td>
                        <td class="py-3 font-mono">{row.result.efficiency.toFixed(1)}%</td>
                      </>
                    ) : (
                      <>
                        <td class="py-3 text-zinc-500">N/A</td>
                        <td class="py-3 text-zinc-500">N/A</td>
                        <td class="py-3 text-zinc-500">N/A</td>
                      </>
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </article>
      </section>
    )}

    {entry.type === 'comparison' && (
      <section class="grid gap-6 lg:grid-cols-[1fr_1.2fr]">
        <article class="rounded-3xl border border-amber-300/20 bg-gradient-to-br from-amber-300/10 to-orange-500/8 p-6 md:p-7">
          <h2 class="mb-3 text-sm font-semibold uppercase tracking-widest text-amber-200">Comparison Notes</h2>
          <p class="text-sm leading-7 text-zinc-200">
            This page compares {RAID_LABEL[(entry as ComparisonEntry).left]} and {RAID_LABEL[(entry as ComparisonEntry).right]} on identical hardware assumptions to help homelab builders choose between capacity efficiency and fault tolerance.
          </p>
          <ul class="mt-4 space-y-2 text-sm text-zinc-300">
            <li>Disk size baseline: 8TB drives</li>
            <li>Reserve policy: 10% filesystem headroom</li>
            <li>Use the interactive tool for exact real-world constraints</li>
          </ul>
          <a href="/calculator/nas-raid/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-amber-200/35 bg-amber-100/10 px-4 py-2 text-sm font-semibold text-amber-100 transition hover:bg-amber-100/20">
            Open Interactive Planner
            <span>→</span>
          </a>
        </article>

        <article class="rounded-3xl border border-white/10 bg-black/35 p-6 md:p-7">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-300">Storage Capacity Table</h2>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[640px] text-left text-sm">
              <thead>
                <tr class="border-b border-white/10 text-xs uppercase tracking-[0.12em] text-zinc-400">
                  <th class="py-3">Drives</th>
                  <th class="py-3">{RAID_LABEL[(entry as ComparisonEntry).left]}</th>
                  <th class="py-3">{RAID_LABEL[(entry as ComparisonEntry).right]}</th>
                  <th class="py-3">Delta</th>
                </tr>
              </thead>
              <tbody class="text-zinc-200">
                {comparisonRows.map((row) => {
                  const leftUsable = row.left.valid ? row.left.usableAfterReserve : 0;
                  const rightUsable = row.right.valid ? row.right.usableAfterReserve : 0;
                  const delta = leftUsable - rightUsable;
                  return (
                    <tr class="border-b border-white/5">
                      <td class="py-3 font-medium text-white">{row.drives}x 8TB</td>
                      <td class="py-3 font-mono text-sky-200">{row.left.valid ? fmtTb(leftUsable) : 'N/A'}</td>
                      <td class="py-3 font-mono text-cyan-200">{row.right.valid ? fmtTb(rightUsable) : 'N/A'}</td>
                      <td class={`py-3 font-mono ${delta >= 0 ? 'text-emerald-200' : 'text-amber-200'}`}>
                        {row.left.valid && row.right.valid ? `${delta >= 0 ? '+' : ''}${fmtTb(delta)}` : 'N/A'}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </article>
      </section>
    )}

    {brandRegionHeadline && (
      <section class="mt-8 rounded-3xl border border-emerald-300/25 bg-gradient-to-br from-emerald-400/10 to-cyan-500/8 p-6 md:p-8">
        <h2 class="mb-3 text-sm font-semibold uppercase tracking-widest text-emerald-200">{brandRegionHeadline}</h2>
        <p class="text-sm leading-7 text-zinc-200">{brandRegionBody}</p>
        {brandRegionTips.length > 0 && (
          <ul class="mt-4 space-y-2 text-sm text-zinc-300">
            {brandRegionTips.map((tip) => (
              <li>• {tip}</li>
            ))}
          </ul>
        )}
      </section>
    )}

    {glossaryTerms.length > 0 && (
      <section class="mt-8 rounded-3xl border border-cyan-300/20 bg-white/[0.02] p-6 md:p-8">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-cyan-200">Brand / Region Glossary</h2>
        <div class="grid gap-3 md:grid-cols-2">
          {glossaryTerms.map((item) => (
            <article class="rounded-2xl border border-white/10 bg-black/25 p-4">
              <h3 class="text-sm font-semibold text-white">{item.term}</h3>
              <p class="mt-2 text-sm leading-7 text-zinc-300">{item.definition}</p>
            </article>
          ))}
        </div>
      </section>
    )}

    <section class="mt-8 rounded-3xl border border-sky-300/20 bg-sky-500/[0.06] p-6 md:p-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-sky-100">NAS Cluster Guides</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/calculator/nas-raid/" class="rounded-xl border border-sky-200/25 bg-black/30 px-3 py-2 text-sm text-zinc-200 transition hover:border-sky-300/40 hover:text-white">
          NAS Hub
        </a>
        <a href="/calculator/nas-raid/compare/raid-level-comparison/" class="rounded-xl border border-sky-200/25 bg-black/30 px-3 py-2 text-sm text-zinc-200 transition hover:border-sky-300/40 hover:text-white">
          RAID Level Compare
        </a>
        <a href="/calculator/nas-raid/reference/raid-capacity-matrix/" class="rounded-xl border border-sky-200/25 bg-black/30 px-3 py-2 text-sm text-zinc-200 transition hover:border-sky-300/40 hover:text-white">
          RAID Capacity Matrix
        </a>
        <a href="/calculator/nas-raid/reference/planning-quick-reference/" class="rounded-xl border border-sky-200/25 bg-black/30 px-3 py-2 text-sm text-zinc-200 transition hover:border-sky-300/40 hover:text-white">
          Planning Quick Sheet
        </a>
        <a href="/calculator/nas-raid/decision/raid-level-selector/" class="rounded-xl border border-sky-200/25 bg-black/30 px-3 py-2 text-sm text-zinc-200 transition hover:border-sky-300/40 hover:text-white">
          RAID Selector
        </a>
        <a href="/calculator/nas-raid/faq/" class="rounded-xl border border-sky-200/25 bg-black/30 px-3 py-2 text-sm text-zinc-200 transition hover:border-sky-300/40 hover:text-white">
          NAS FAQ
        </a>
      </div>
    </section>

    <section class="mt-8 rounded-3xl border border-white/10 bg-white/[0.02] p-6 md:p-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-300">Related Long-Tail Calculators</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {popularScenarios.map((scenario) => (
          <a href={`/calculator/nas-raid/${scenario.slug}/`} class="rounded-xl border border-white/10 bg-black/25 px-3 py-2 text-sm text-zinc-200 transition hover:border-sky-300/40 hover:text-white">
            {scenario.drives}x {scenario.sizeTb}TB {RAID_LABEL[scenario.level]}
          </a>
        ))}
      </div>
    </section>

    {(prevNasEntry && nextNasEntry) && (
      <section class="mt-8 rounded-3xl border border-white/10 bg-black/25 p-6 md:p-8">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-300">Sequential Long-Tail Navigation</h2>
        <div class="grid gap-3 sm:grid-cols-2">
          <a href={`/calculator/nas-raid/${prevNasEntry.slug}/`} class="rounded-xl border border-white/10 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-sky-300/40 hover:text-white">
            ← Previous: {prevNasEntry.title}
          </a>
          <a href={`/calculator/nas-raid/${nextNasEntry.slug}/`} class="rounded-xl border border-white/10 bg-black/30 px-4 py-3 text-sm text-zinc-200 transition hover:border-sky-300/40 hover:text-white">
            Next: {nextNasEntry.title} →
          </a>
        </div>
      </section>
    )}

    <section class="mt-8 rounded-3xl border border-white/10 bg-black/25 p-6 md:p-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-300">FAQ</h2>
      <div class="space-y-3">
        {faqItems.map((item) => (
          <article class="rounded-2xl border border-white/10 bg-black/30 p-4">
            <h3 class="text-sm font-semibold text-white">{item.question}</h3>
            <p class="mt-2 text-sm leading-7 text-zinc-300">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>
