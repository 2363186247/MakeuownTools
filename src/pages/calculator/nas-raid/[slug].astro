---
import Layout from '../../../layouts/Layout.astro';
import {
  RAID_LABEL,
  calculateNasRaid,
  getNasRaidSeoEntries,
  getScenarioEntries,
  type ComparisonEntry,
  type NasRaidSeoEntry,
  type RaidLevel,
  type ScenarioEntry
} from '../../../data/nasRaidSeo';

export function getStaticPaths() {
  return getNasRaidSeoEntries().map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

type Props = { entry: NasRaidSeoEntry };
const { entry } = Astro.props as Props;

const popularScenarios = getScenarioEntries().slice(0, 16);

function fmtTb(value: number): string {
  return `${value.toFixed(2)} TB`;
}

function levelAdvice(level: RaidLevel): string {
  switch (level) {
    case 'raid0': return 'Maximum capacity and speed, but any single disk failure loses the whole array.';
    case 'raid1': return 'Strong redundancy but low capacity efficiency. Great for small, critical datasets.';
    case 'raid5': return 'Balanced capacity and redundancy, but rebuild stress can be high on large disks.';
    case 'raid6': return 'Safer for larger arrays with dual parity, at the cost of one extra parity disk.';
    case 'raid10': return 'Excellent random I/O and rebuild behavior; capacity is typically 50% of raw.';
    case 'raidz1': return 'ZFS single-parity equivalent of RAID 5; common for smaller homelab pools.';
    case 'raidz2': return 'Popular TrueNAS default for medium arrays; dual-parity with good safety margin.';
    case 'raidz3': return 'High resiliency for big pools and long rebuild windows, but lowest efficiency.';
  }
}

const pageTitle = entry.title;
const pageDescription = entry.description;

let scenarioResult: ReturnType<typeof calculateNasRaid> | null = null;
let comparisonRows: Array<{ drives: number; left: ReturnType<typeof calculateNasRaid>; right: ReturnType<typeof calculateNasRaid> }> = [];
let scenarioTable: Array<{ level: RaidLevel; result: ReturnType<typeof calculateNasRaid> }> = [];

if (entry.type === 'scenario') {
  const scenario = entry as ScenarioEntry;
  scenarioResult = calculateNasRaid(scenario.level, scenario.drives, scenario.sizeTb, scenario.reservePct);

  const compareLevels: RaidLevel[] = ['raid5', 'raid6', 'raid10', 'raidz1', 'raidz2'];
  scenarioTable = compareLevels.map((level) => ({
    level,
    result: calculateNasRaid(level, scenario.drives, scenario.sizeTb, scenario.reservePct)
  }));
}

if (entry.type === 'comparison') {
  const comparison = entry as ComparisonEntry;
  const driveSet = [4, 6, 8, 10, 12];
  const sizeTb = 8;
  comparisonRows = driveSet.map((drives) => ({
    drives,
    left: calculateNasRaid(comparison.left, drives, sizeTb, 10),
    right: calculateNasRaid(comparison.right, drives, sizeTb, 10)
  }));
}
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="mx-auto w-full max-w-7xl px-6 py-10 md:px-8 md:py-14">
    <a href="/calculator/nas-raid/" class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-300 transition hover:bg-white/10">
      <span>←</span>
      <span>NAS & RAID Calculator</span>
    </a>

    <header class="mb-8 rounded-3xl border border-white/15 bg-white/[0.03] p-6 md:p-8">
      <p class="mb-3 inline-flex items-center rounded-full border border-sky-400/35 bg-sky-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-sky-100">
        NAS pSEO Landing
      </p>
      <h1 class="text-3xl font-semibold tracking-tight text-white md:text-4xl">{pageTitle.replace(' | NAS Capacity', '')}</h1>
      <p class="mt-4 max-w-4xl text-sm leading-7 text-zinc-300 md:text-base">{pageDescription}</p>
    </header>

    {entry.type === 'scenario' && scenarioResult && (
      <section class="grid gap-6 lg:grid-cols-[1fr_1.2fr]">
        <article class="rounded-3xl border border-sky-300/20 bg-gradient-to-br from-sky-400/10 to-cyan-500/5 p-6 md:p-7">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-sky-200">Capacity Snapshot</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            <div class="rounded-2xl border border-white/10 bg-black/25 p-4">
              <p class="text-xs uppercase tracking-[0.12em] text-zinc-400">Raw Capacity</p>
              <p class="mt-1 font-mono text-2xl text-white">{fmtTb(scenarioResult.raw)}</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-black/25 p-4">
              <p class="text-xs uppercase tracking-[0.12em] text-zinc-400">Usable Capacity</p>
              <p class="mt-1 font-mono text-2xl text-sky-200">{fmtTb(scenarioResult.usableAfterReserve)}</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-black/25 p-4">
              <p class="text-xs uppercase tracking-[0.12em] text-zinc-400">Fault Tolerance</p>
              <p class="mt-1 font-mono text-xl text-emerald-200">{scenarioResult.tolerance}</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-black/25 p-4">
              <p class="text-xs uppercase tracking-[0.12em] text-zinc-400">Efficiency</p>
              <p class="mt-1 font-mono text-xl text-amber-200">{scenarioResult.efficiency.toFixed(1)}%</p>
            </div>
          </div>
          <p class="mt-4 text-sm leading-7 text-zinc-300">
            {levelAdvice((entry as ScenarioEntry).level)} This scenario applies a {(entry as ScenarioEntry).reservePct}% filesystem reserve.
          </p>
          <a href="/calculator/nas-raid/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-sky-200/35 bg-sky-100/10 px-4 py-2 text-sm font-semibold text-sky-100 transition hover:bg-sky-100/20">
            Run Interactive Calculator
            <span>→</span>
          </a>
        </article>

        <article class="rounded-3xl border border-white/10 bg-black/35 p-6 md:p-7">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-300">Alternative Mode Comparison</h2>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[560px] text-left text-sm">
              <thead>
                <tr class="border-b border-white/10 text-xs uppercase tracking-[0.12em] text-zinc-400">
                  <th class="py-3">Mode</th>
                  <th class="py-3">Usable</th>
                  <th class="py-3">Tolerance</th>
                  <th class="py-3">Efficiency</th>
                </tr>
              </thead>
              <tbody class="text-zinc-200">
                {scenarioTable.map((row) => (
                  <tr class="border-b border-white/5">
                    <td class="py-3 font-medium text-white">{RAID_LABEL[row.level]}</td>
                    {row.result.valid ? (
                      <>
                        <td class="py-3 font-mono text-sky-200">{fmtTb(row.result.usableAfterReserve)}</td>
                        <td class="py-3">{row.result.tolerance}</td>
                        <td class="py-3 font-mono">{row.result.efficiency.toFixed(1)}%</td>
                      </>
                    ) : (
                      <>
                        <td class="py-3 text-zinc-500">N/A</td>
                        <td class="py-3 text-zinc-500">N/A</td>
                        <td class="py-3 text-zinc-500">N/A</td>
                      </>
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </article>
      </section>
    )}

    {entry.type === 'comparison' && (
      <section class="grid gap-6 lg:grid-cols-[1fr_1.2fr]">
        <article class="rounded-3xl border border-amber-300/20 bg-gradient-to-br from-amber-300/10 to-orange-500/8 p-6 md:p-7">
          <h2 class="mb-3 text-sm font-semibold uppercase tracking-widest text-amber-200">Comparison Notes</h2>
          <p class="text-sm leading-7 text-zinc-200">
            This page compares {RAID_LABEL[(entry as ComparisonEntry).left]} and {RAID_LABEL[(entry as ComparisonEntry).right]} on identical hardware assumptions to help homelab builders choose between capacity efficiency and fault tolerance.
          </p>
          <ul class="mt-4 space-y-2 text-sm text-zinc-300">
            <li>Disk size baseline: 8TB drives</li>
            <li>Reserve policy: 10% filesystem headroom</li>
            <li>Use the interactive tool for exact real-world constraints</li>
          </ul>
          <a href="/calculator/nas-raid/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-amber-200/35 bg-amber-100/10 px-4 py-2 text-sm font-semibold text-amber-100 transition hover:bg-amber-100/20">
            Open Interactive Planner
            <span>→</span>
          </a>
        </article>

        <article class="rounded-3xl border border-white/10 bg-black/35 p-6 md:p-7">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-300">Storage Capacity Table</h2>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[640px] text-left text-sm">
              <thead>
                <tr class="border-b border-white/10 text-xs uppercase tracking-[0.12em] text-zinc-400">
                  <th class="py-3">Drives</th>
                  <th class="py-3">{RAID_LABEL[(entry as ComparisonEntry).left]}</th>
                  <th class="py-3">{RAID_LABEL[(entry as ComparisonEntry).right]}</th>
                  <th class="py-3">Delta</th>
                </tr>
              </thead>
              <tbody class="text-zinc-200">
                {comparisonRows.map((row) => {
                  const leftUsable = row.left.valid ? row.left.usableAfterReserve : 0;
                  const rightUsable = row.right.valid ? row.right.usableAfterReserve : 0;
                  const delta = leftUsable - rightUsable;
                  return (
                    <tr class="border-b border-white/5">
                      <td class="py-3 font-medium text-white">{row.drives}x 8TB</td>
                      <td class="py-3 font-mono text-sky-200">{row.left.valid ? fmtTb(leftUsable) : 'N/A'}</td>
                      <td class="py-3 font-mono text-cyan-200">{row.right.valid ? fmtTb(rightUsable) : 'N/A'}</td>
                      <td class={`py-3 font-mono ${delta >= 0 ? 'text-emerald-200' : 'text-amber-200'}`}>
                        {row.left.valid && row.right.valid ? `${delta >= 0 ? '+' : ''}${fmtTb(delta)}` : 'N/A'}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </article>
      </section>
    )}

    <section class="mt-8 rounded-3xl border border-white/10 bg-white/[0.02] p-6 md:p-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-300">Related Long-Tail Calculators</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {popularScenarios.map((scenario) => (
          <a href={`/calculator/nas-raid/${scenario.slug}/`} class="rounded-xl border border-white/10 bg-black/25 px-3 py-2 text-sm text-zinc-200 transition hover:border-sky-300/40 hover:text-white">
            {scenario.drives}x {scenario.sizeTb}TB {RAID_LABEL[scenario.level]}
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>
