---
import Layout from '../../layouts/Layout.astro';
import filaments from '../../data/filaments.json';
import satisfactoryData from '../../data/satisfactory.json';
import { NAS_RAID_TOTAL_ROUTES } from '../../data/nasRaidSeo';
import { OFFGRID_SOLAR_TOTAL_ROUTES } from '../../data/offGridSolarSeo';

type Material = { id: string; name: string };
type Diameter = { id: string; name: string; common?: boolean };
type FilamentsData = { materials: Material[]; diameters: Diameter[] };
type SatisfactoryItem = {
	id: string;
	name: string;
	category: string;
	machine: string;
	tier: number;
};
type SatisfactoryDataset = {
	items: SatisfactoryItem[];
	mvp_targets: string[];
};

const filamentData = filaments as FilamentsData;
const satData = satisfactoryData as SatisfactoryDataset;

const filamentRoutes = filamentData.materials.length * filamentData.diameters.length;
const satisfactoryTargets = satData.mvp_targets.length;
const vramRoutes = 1;
const nasRaidRoutes = NAS_RAID_TOTAL_ROUTES;
const offGridSolarRoutes = OFFGRID_SOLAR_TOTAL_ROUTES;
const allCalculatorRoutes = filamentRoutes + satData.items.length + vramRoutes + nasRaidRoutes + offGridSolarRoutes;

const preferredDiameter = filamentData.diameters.find((d) => d.common) ?? filamentData.diameters[0];
const filamentFeatured = filamentData.materials.slice(0, 3).map((material) => ({
	name: `${material.name} · ${preferredDiameter.name}`,
	href: `/calculator/3d-printing/${material.id}-${preferredDiameter.id}`
}));

const satFeatured = satData.mvp_targets.slice(0, 4)
	.map((id) => satData.items.find((item) => item.id === id))
	.filter((item): item is SatisfactoryItem => Boolean(item));
---

<Layout
	title="Calculator Hub | Make Your Own Tools"
	description="Unified calculator hub for 3D printing planning and Satisfactory factory production modeling."
>
	<main class="mx-auto w-full max-w-7xl px-6 py-12 md:px-8 md:py-16">
		<a href="/" class="mb-7 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-300 transition hover:border-white/30 hover:bg-white/10">
			<span>←</span>
			<span>Home</span>
		</a>

		<section class="relative overflow-hidden rounded-3xl border border-white/15 bg-white/[0.03] p-7 md:p-9">
			<div class="pointer-events-none absolute -top-24 -right-16 h-64 w-64 rounded-full bg-emerald-400/15 blur-3xl"></div>
			<div class="pointer-events-none absolute -bottom-24 -left-16 h-64 w-64 rounded-full bg-cyan-400/15 blur-3xl"></div>

			<div class="relative grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
				<div>
					<div class="mb-4 flex flex-wrap gap-2">
						<span class="inline-flex items-center gap-2 rounded-full border border-cyan-300/30 bg-cyan-300/10 px-3 py-1 text-xs font-medium text-cyan-100">
							<svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M12 5v14"/></svg>
							AI
						</span>
						<span class="inline-flex items-center gap-2 rounded-full border border-sky-300/30 bg-sky-300/10 px-3 py-1 text-xs font-medium text-sky-100">
							<svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
							Storage
						</span>
						<span class="inline-flex items-center gap-2 rounded-full border border-amber-300/30 bg-amber-300/10 px-3 py-1 text-xs font-medium text-amber-100">
							<svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3v18M3 12h18"/><circle cx="12" cy="12" r="3"/></svg>
							Power
						</span>
						<span class="inline-flex items-center gap-2 rounded-full border border-emerald-300/30 bg-emerald-300/10 px-3 py-1 text-xs font-medium text-emerald-100">
							<svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 19h16M7 16l3-8 4 6 3-4"/></svg>
							Fabrication
						</span>
					</div>
					<p class="mb-3 inline-flex items-center rounded-full border border-white/20 bg-black/30 px-3 py-1 text-xs font-medium uppercase tracking-[0.18em] text-zinc-200">
						Calculator Hub
					</p>
					<h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">Production & Fabrication Calculators</h1>
					<p class="mt-4 max-w-3xl text-sm leading-7 text-zinc-300 md:text-base">
						One hub for multiple domains: VRAM capacity planning for LLM deployment, 3D printing filament estimation, and Satisfactory factory reverse planning.
					</p>
				</div>

				<div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
					<div class="rounded-2xl border border-white/15 bg-black/25 p-4">
						<p class="text-xs uppercase tracking-[0.16em] text-zinc-400">All Calculator Pages</p>
						<p class="mt-1 text-3xl font-semibold text-white">{allCalculatorRoutes}</p>
					</div>
					<div class="rounded-2xl border border-white/15 bg-black/25 p-4">
						<p class="text-xs uppercase tracking-[0.16em] text-zinc-400">AI VRAM Tools</p>
						<p class="mt-1 text-3xl font-semibold text-white">{vramRoutes}</p>
					</div>
					<div class="rounded-2xl border border-white/15 bg-black/25 p-4">
						<p class="text-xs uppercase tracking-[0.16em] text-zinc-400">NAS / RAID Tools</p>
						<p class="mt-1 text-3xl font-semibold text-white">{nasRaidRoutes}</p>
					</div>
					<div class="rounded-2xl border border-white/15 bg-black/25 p-4">
						<p class="text-xs uppercase tracking-[0.16em] text-zinc-400">Off-Grid Solar Tools</p>
						<p class="mt-1 text-3xl font-semibold text-white">{offGridSolarRoutes}</p>
					</div>
					<div class="rounded-2xl border border-white/15 bg-black/25 p-4">
						<p class="text-xs uppercase tracking-[0.16em] text-zinc-400">3D Printing Profiles</p>
						<p class="mt-1 text-3xl font-semibold text-white">{filamentRoutes}</p>
					</div>
					<div class="rounded-2xl border border-white/15 bg-black/25 p-4">
						<p class="text-xs uppercase tracking-[0.16em] text-zinc-400">Satisfactory Targets</p>
						<p class="mt-1 text-3xl font-semibold text-white">{satisfactoryTargets}</p>
					</div>
				</div>
			</div>
		</section>

		<section class="mt-7 grid gap-5 lg:grid-cols-2 xl:grid-cols-5">
			<article class="group rounded-3xl border border-cyan-300/25 bg-gradient-to-br from-cyan-300/12 to-blue-500/10 p-6 shadow-2xl shadow-cyan-900/15 transition hover:border-cyan-200/40 md:p-7">
				<div class="mb-4 flex items-center justify-between">
					<p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-cyan-100"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3v18M3 12h18"/></svg>AI / LLM</p>
					<span class="rounded-full border border-cyan-200/35 bg-cyan-100/10 px-2.5 py-0.5 text-xs font-semibold text-cyan-100">Priority</span>
				</div>
				<h2 class="text-2xl font-semibold tracking-tight text-white">LLM VRAM Calculator</h2>
				<p class="mt-3 text-sm leading-7 text-zinc-200">
					Fetch real Hugging Face configs and estimate VRAM for vLLM, Ollama, and LoRA scenarios with hardware matching.
				</p>
				<a href="/calculator/vram/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-cyan-200/35 bg-cyan-100/10 px-4 py-2 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-100/20">
					Open VRAM Calculator
					<span>→</span>
				</a>
			</article>

			<article class="group rounded-3xl border border-sky-300/25 bg-gradient-to-br from-sky-300/12 to-indigo-500/10 p-6 shadow-2xl shadow-sky-900/15 transition hover:border-sky-200/40 md:p-7">
				<div class="mb-4 flex items-center justify-between">
					<p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-sky-100"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M4 12h16M4 17h16"/></svg>NAS / Homelab</p>
					<span class="rounded-full border border-sky-200/35 bg-sky-100/10 px-2.5 py-0.5 text-xs font-semibold text-sky-100">New</span>
				</div>
				<h2 class="text-2xl font-semibold tracking-tight text-white">NAS & RAID Storage Calculator</h2>
				<p class="mt-3 text-sm leading-7 text-zinc-200">
					Estimate usable capacity, fault tolerance, and efficiency for RAID 0/1/5/6/10 and ZFS RAID-Z arrays before buying drives.
				</p>
				<a href="/calculator/nas-raid/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-sky-200/35 bg-sky-100/10 px-4 py-2 text-sm font-semibold text-sky-100 transition hover:bg-sky-100/20">
					Open NAS / RAID Calculator
					<span>→</span>
				</a>
			</article>

			<article class="group rounded-3xl border border-amber-300/25 bg-gradient-to-br from-amber-300/12 to-yellow-500/10 p-6 shadow-2xl shadow-amber-900/15 transition hover:border-amber-200/40 md:p-7">
				<div class="mb-4 flex items-center justify-between">
					<p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-amber-100"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v20M5 9h14M7 16h10"/></svg>RV / Off-Grid</p>
					<span class="rounded-full border border-amber-200/35 bg-amber-100/10 px-2.5 py-0.5 text-xs font-semibold text-amber-100">SEO Scale</span>
				</div>
				<h2 class="text-2xl font-semibold tracking-tight text-white">RV Solar & Battery Calculator</h2>
				<p class="mt-3 text-sm leading-7 text-zinc-200">
					Estimate daily load, LiFePO4 battery Ah, panel wattage, and inverter baseline for 12V, 24V, and 48V off-grid systems.
				</p>
				<a href="/calculator/off-grid-solar/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-amber-200/35 bg-amber-100/10 px-4 py-2 text-sm font-semibold text-amber-100 transition hover:bg-amber-100/20">
					Open Off-Grid Calculator
					<span>→</span>
				</a>
			</article>

			<article class="group rounded-3xl border border-emerald-300/25 bg-gradient-to-br from-emerald-300/12 to-lime-500/10 p-6 shadow-2xl shadow-emerald-900/15 transition hover:border-emerald-200/40 md:p-7">
				<div class="mb-4 flex items-center justify-between">
					<p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-emerald-100"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 8h12v8H6z"/><path d="M8 8V5h8v3"/></svg>3D Printing</p>
					<span class="rounded-full border border-emerald-200/35 bg-emerald-100/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-100">Live</span>
				</div>
				<h2 class="text-2xl font-semibold tracking-tight text-white">Filament Length Navigator</h2>
				<p class="mt-3 text-sm leading-7 text-zinc-200">
					Jump into dedicated profiles by material and diameter to estimate remaining printable length in real time, with print temperature guidance.
				</p>
				<a href="/calculator/3d-printing/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-emerald-200/35 bg-emerald-100/10 px-4 py-2 text-sm font-semibold text-emerald-100 transition hover:bg-emerald-100/20">
					Open 3D Printing Calculators
					<span>→</span>
				</a>
				<ul class="mt-5 space-y-2 text-sm text-zinc-200">
					{filamentFeatured.map((item) => (
						<li>
							<a href={item.href} class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white">
								<span class="h-1.5 w-1.5 rounded-full bg-emerald-200"></span>
								<span>{item.name}</span>
							</a>
						</li>
					))}
				</ul>
			</article>

			<article class="group rounded-3xl border border-amber-300/25 bg-gradient-to-br from-amber-300/12 to-orange-500/10 p-6 shadow-2xl shadow-amber-900/15 transition hover:border-amber-200/40 md:p-7">
				<div class="mb-4 flex items-center justify-between">
					<p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-amber-100"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 18h16"/><path d="M6 18v-6h4v6M14 18v-9h4v9"/></svg>Satisfactory</p>
					<span class="rounded-full border border-amber-200/35 bg-amber-100/10 px-2.5 py-0.5 text-xs font-semibold text-amber-100">Live</span>
				</div>
				<h2 class="text-2xl font-semibold tracking-tight text-white">Factory Reverse Planner</h2>
				<p class="mt-3 text-sm leading-7 text-zinc-200">
					Set a target output rate and automatically reverse-calculate machine counts, power demand, and raw inputs across multi-level dependency chains.
				</p>
				<a href="/calculator/satisfactory/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-amber-200/35 bg-amber-100/10 px-4 py-2 text-sm font-semibold text-amber-100 transition hover:bg-amber-100/20">
					Open Satisfactory Calculators
					<span>→</span>
				</a>
				<ul class="mt-5 space-y-2 text-sm text-zinc-200">
					{satFeatured.map((item) => (
						<li>
							<a href={`/calculator/satisfactory/${item.id}`} class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white">
								<span class="h-1.5 w-1.5 rounded-full bg-amber-200"></span>
								<span>{item.name}</span>
							</a>
						</li>
					))}
				</ul>
			</article>
		</section>

	</main>
</Layout>
