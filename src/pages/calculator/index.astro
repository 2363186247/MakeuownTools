---
import Layout from '../../layouts/Layout.astro';
import filaments from '../../data/filaments.json';
import satisfactoryData from '../../data/satisfactory.json';

type Material = { id: string; name: string };
type Diameter = { id: string; name: string; common?: boolean };
type FilamentsData = { materials: Material[]; diameters: Diameter[] };
type SatisfactoryItem = {
	id: string;
	name: string;
	category: string;
	machine: string;
	tier: number;
};
type SatisfactoryDataset = {
	items: SatisfactoryItem[];
	mvp_targets: string[];
};

const filamentData = filaments as FilamentsData;
const satData = satisfactoryData as SatisfactoryDataset;

const filamentRoutes = filamentData.materials.length * filamentData.diameters.length;
const satisfactoryTargets = satData.mvp_targets.length;
const allCalculatorRoutes = filamentRoutes + satData.items.length;

const preferredDiameter = filamentData.diameters.find((d) => d.common) ?? filamentData.diameters[0];
const filamentFeatured = filamentData.materials.slice(0, 3).map((material) => ({
	name: `${material.name} · ${preferredDiameter.name}`,
	href: `/calculator/3d-printing/${material.id}-${preferredDiameter.id}`
}));

const satFeatured = satData.mvp_targets.slice(0, 4)
	.map((id) => satData.items.find((item) => item.id === id))
	.filter((item): item is SatisfactoryItem => Boolean(item));

const quickFilamentLinks = filamentData.materials.slice(0, 8).map((material) => ({
	id: `filament-${material.id}`,
	name: `${material.name} · ${preferredDiameter.name}`,
	href: `/calculator/3d-printing/${material.id}-${preferredDiameter.id}`,
	domain: '3d-printing',
	level: 'beginner',
	purpose: 'estimation',
	isNew: false
}));

const quickSatLinks = satData.mvp_targets.slice(0, 10)
	.map((id) => satData.items.find((item) => item.id === id))
	.filter((item): item is SatisfactoryItem => Boolean(item))
	.map((item, idx) => ({
		id: `sat-${item.id}`,
		name: item.name,
		href: `/calculator/satisfactory/${item.id}`,
		domain: 'satisfactory',
		level: item.tier >= 4 ? 'advanced' : 'intermediate',
		purpose: 'planning',
		isNew: idx >= 7
	}));

const quickLinks = [...quickFilamentLinks, ...quickSatLinks];
---

<Layout
	title="Calculator Hub | Make Your Own Tools"
	description="Unified calculator hub for 3D printing planning and Satisfactory factory production modeling."
>
	<main class="mx-auto w-full max-w-7xl px-6 py-12 md:px-8 md:py-16">
		<a href="/" class="mb-7 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-300 transition hover:border-white/30 hover:bg-white/10">
			<span>←</span>
			<span>Home</span>
		</a>

		<section class="relative overflow-hidden rounded-3xl border border-white/15 bg-white/[0.03] p-7 md:p-9">
			<div class="pointer-events-none absolute -top-24 -right-16 h-64 w-64 rounded-full bg-emerald-400/15 blur-3xl"></div>
			<div class="pointer-events-none absolute -bottom-24 -left-16 h-64 w-64 rounded-full bg-cyan-400/15 blur-3xl"></div>

			<div class="relative grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
				<div>
					<p class="mb-3 inline-flex items-center rounded-full border border-white/20 bg-black/30 px-3 py-1 text-xs font-medium uppercase tracking-[0.18em] text-zinc-200">
						Calculator Hub
					</p>
					<h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">Production & Fabrication Calculators</h1>
					<p class="mt-4 max-w-3xl text-sm leading-7 text-zinc-300 md:text-base">
						One入口覆盖不同领域: 3D 打印耗材估算和 Satisfactory 工厂逆向规划，统一风格、统一体验、即开即算。
					</p>
				</div>

				<div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
					<div class="rounded-2xl border border-white/15 bg-black/25 p-4">
						<p class="text-xs uppercase tracking-[0.16em] text-zinc-400">All Calculator Pages</p>
						<p class="mt-1 text-3xl font-semibold text-white">{allCalculatorRoutes}</p>
					</div>
					<div class="rounded-2xl border border-white/15 bg-black/25 p-4">
						<p class="text-xs uppercase tracking-[0.16em] text-zinc-400">3D Printing Profiles</p>
						<p class="mt-1 text-3xl font-semibold text-white">{filamentRoutes}</p>
					</div>
					<div class="rounded-2xl border border-white/15 bg-black/25 p-4">
						<p class="text-xs uppercase tracking-[0.16em] text-zinc-400">Satisfactory Targets</p>
						<p class="mt-1 text-3xl font-semibold text-white">{satisfactoryTargets}</p>
					</div>
				</div>
			</div>
		</section>

		<section class="mt-7 grid gap-5 lg:grid-cols-2">
			<article class="group rounded-3xl border border-emerald-300/25 bg-gradient-to-br from-emerald-300/12 to-lime-500/10 p-6 shadow-2xl shadow-emerald-900/15 transition hover:border-emerald-200/40 md:p-7">
				<div class="mb-4 flex items-center justify-between">
					<p class="text-xs uppercase tracking-[0.16em] text-emerald-100">3D Printing</p>
					<span class="rounded-full border border-emerald-200/35 bg-emerald-100/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-100">Live</span>
				</div>
				<h2 class="text-2xl font-semibold tracking-tight text-white">Filament Length Navigator</h2>
				<p class="mt-3 text-sm leading-7 text-zinc-200">
					按材料与线径快速进入专属页面，实时估算剩余可打印长度，并附带打印温度建议。
				</p>
				<a href="/calculator/3d-printing/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-emerald-200/35 bg-emerald-100/10 px-4 py-2 text-sm font-semibold text-emerald-100 transition hover:bg-emerald-100/20">
					Open 3D Printing Calculators
					<span>→</span>
				</a>
				<ul class="mt-5 space-y-2 text-sm text-zinc-200">
					{filamentFeatured.map((item) => (
						<li>
							<a href={item.href} class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white">
								<span class="h-1.5 w-1.5 rounded-full bg-emerald-200"></span>
								<span>{item.name}</span>
							</a>
						</li>
					))}
				</ul>
			</article>

			<article class="group rounded-3xl border border-amber-300/25 bg-gradient-to-br from-amber-300/12 to-orange-500/10 p-6 shadow-2xl shadow-amber-900/15 transition hover:border-amber-200/40 md:p-7">
				<div class="mb-4 flex items-center justify-between">
					<p class="text-xs uppercase tracking-[0.16em] text-amber-100">Satisfactory</p>
					<span class="rounded-full border border-amber-200/35 bg-amber-100/10 px-2.5 py-0.5 text-xs font-semibold text-amber-100">Live</span>
				</div>
				<h2 class="text-2xl font-semibold tracking-tight text-white">Factory Reverse Planner</h2>
				<p class="mt-3 text-sm leading-7 text-zinc-200">
					输入目标产量，自动逆推机器数量、耗电和原料输入，支持多层依赖链分析。
				</p>
				<a href="/calculator/satisfactory/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-amber-200/35 bg-amber-100/10 px-4 py-2 text-sm font-semibold text-amber-100 transition hover:bg-amber-100/20">
					Open Satisfactory Calculators
					<span>→</span>
				</a>
				<ul class="mt-5 space-y-2 text-sm text-zinc-200">
					{satFeatured.map((item) => (
						<li>
							<a href={`/calculator/satisfactory/${item.id}`} class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white">
								<span class="h-1.5 w-1.5 rounded-full bg-amber-200"></span>
								<span>{item.name}</span>
							</a>
						</li>
					))}
				</ul>
			</article>
		</section>

		<section class="mt-7 rounded-3xl border border-white/15 bg-white/[0.03] p-6 md:p-7">
			<div class="mb-5 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
				<div>
					<p class="text-xs uppercase tracking-[0.16em] text-zinc-400">Smart Discovery</p>
					<h2 class="mt-2 text-2xl font-semibold tracking-tight text-white">Filter By Domain, Difficulty, Purpose</h2>
					<p class="mt-2 max-w-3xl text-sm leading-7 text-zinc-300">
						快速筛选你当前阶段最需要的计算器，不用在长列表里来回找。
					</p>
				</div>
				<p id="visibleCounter" class="rounded-full border border-white/15 bg-black/25 px-3 py-1 text-xs uppercase tracking-[0.15em] text-zinc-300">
					Showing {quickLinks.length} / {quickLinks.length}
				</p>
			</div>

			<div class="mb-4 grid gap-3 md:grid-cols-3">
				<div>
					<p class="mb-2 text-[11px] uppercase tracking-[0.15em] text-zinc-400">Domain</p>
					<div class="flex flex-wrap gap-2" data-filter-group="domain">
						<button data-filter-value="all" class="filter-chip active rounded-full border border-cyan-300/40 bg-cyan-300/15 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.13em] text-cyan-100" type="button">All</button>
						<button data-filter-value="3d-printing" class="filter-chip rounded-full border border-white/15 bg-black/25 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.13em] text-zinc-300" type="button">3D Printing</button>
						<button data-filter-value="satisfactory" class="filter-chip rounded-full border border-white/15 bg-black/25 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.13em] text-zinc-300" type="button">Satisfactory</button>
					</div>
				</div>

				<div>
					<p class="mb-2 text-[11px] uppercase tracking-[0.15em] text-zinc-400">Difficulty</p>
					<div class="flex flex-wrap gap-2" data-filter-group="level">
						<button data-filter-value="all" class="filter-chip active rounded-full border border-emerald-300/40 bg-emerald-300/15 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.13em] text-emerald-100" type="button">All</button>
						<button data-filter-value="beginner" class="filter-chip rounded-full border border-white/15 bg-black/25 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.13em] text-zinc-300" type="button">Beginner</button>
						<button data-filter-value="intermediate" class="filter-chip rounded-full border border-white/15 bg-black/25 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.13em] text-zinc-300" type="button">Intermediate</button>
						<button data-filter-value="advanced" class="filter-chip rounded-full border border-white/15 bg-black/25 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.13em] text-zinc-300" type="button">Advanced</button>
					</div>
				</div>

				<div>
					<p class="mb-2 text-[11px] uppercase tracking-[0.15em] text-zinc-400">Purpose</p>
					<div class="flex flex-wrap gap-2" data-filter-group="purpose">
						<button data-filter-value="all" class="filter-chip active rounded-full border border-amber-300/40 bg-amber-300/15 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.13em] text-amber-100" type="button">All</button>
						<button data-filter-value="estimation" class="filter-chip rounded-full border border-white/15 bg-black/25 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.13em] text-zinc-300" type="button">Estimation</button>
						<button data-filter-value="planning" class="filter-chip rounded-full border border-white/15 bg-black/25 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.13em] text-zinc-300" type="button">Planning</button>
					</div>
				</div>
			</div>

			<div id="quickLinksGrid" class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
				{quickLinks.map((item) => (
					<a
						href={item.href}
						class="quick-link group rounded-2xl border border-white/10 bg-black/25 p-4 transition hover:-translate-y-0.5 hover:border-white/25 hover:bg-white/[0.06]"
						data-domain={item.domain}
						data-level={item.level}
						data-purpose={item.purpose}
					>
						<div class="mb-2 flex items-center justify-between gap-2">
							<p class="font-semibold text-zinc-100">{item.name}</p>
							{item.isNew && <span class="rounded-full border border-fuchsia-300/40 bg-fuchsia-300/15 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.13em] text-fuchsia-100">New</span>}
						</div>
						<div class="flex flex-wrap gap-1.5">
							<span class="rounded border border-white/10 bg-white/[0.04] px-2 py-0.5 text-[10px] uppercase tracking-[0.12em] text-zinc-300">{item.domain}</span>
							<span class="rounded border border-white/10 bg-white/[0.04] px-2 py-0.5 text-[10px] uppercase tracking-[0.12em] text-zinc-300">{item.level}</span>
							<span class="rounded border border-white/10 bg-white/[0.04] px-2 py-0.5 text-[10px] uppercase tracking-[0.12em] text-zinc-300">{item.purpose}</span>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</Layout>

<script>
	(() => {
		const validOptions = {
			domain: ['all', '3d-printing', 'satisfactory'],
			level: ['all', 'beginner', 'intermediate', 'advanced'],
			purpose: ['all', 'estimation', 'planning']
		};

		const activeFilters = {
			domain: 'all',
			level: 'all',
			purpose: 'all'
		};
		type FilterKey = keyof typeof activeFilters;

		const chips = Array.from(document.querySelectorAll('.filter-chip'));
		const cards = Array.from(document.querySelectorAll('.quick-link'));
		const visibleCounter = document.getElementById('visibleCounter');

		const readInitialFiltersFromQuery = () => {
			const params = new URLSearchParams(window.location.search);
			(['domain', 'level', 'purpose'] as FilterKey[]).forEach((key) => {
				const value = params.get(key);
				if (value && validOptions[key].includes(value)) {
					activeFilters[key] = value;
				}
			});
		};

		const writeFiltersToQuery = () => {
			const params = new URLSearchParams(window.location.search);
			(['domain', 'level', 'purpose'] as FilterKey[]).forEach((key) => {
				const value = activeFilters[key];
				if (value === 'all') {
					params.delete(key);
				} else {
					params.set(key, value);
				}
			});

			const nextQuery = params.toString();
			const nextUrl = `${window.location.pathname}${nextQuery ? `?${nextQuery}` : ''}`;
			history.replaceState({}, '', nextUrl);
		};

		const colorClasses = {
			domain: ['border-cyan-300/40', 'bg-cyan-300/15', 'text-cyan-100'],
			level: ['border-emerald-300/40', 'bg-emerald-300/15', 'text-emerald-100'],
			purpose: ['border-amber-300/40', 'bg-amber-300/15', 'text-amber-100']
		};

		const setActiveChip = (group: FilterKey, value: string) => {
			const groupContainer = document.querySelector(`[data-filter-group="${group}"]`);
			if (!groupContainer) return;

			const siblings = Array.from(groupContainer.querySelectorAll('.filter-chip'));
			siblings.forEach((button) => {
				button.classList.remove(
					'active',
					'border-cyan-300/40',
					'bg-cyan-300/15',
					'text-cyan-100',
					'border-emerald-300/40',
					'bg-emerald-300/15',
					'text-emerald-100',
					'border-amber-300/40',
					'bg-amber-300/15',
					'text-amber-100'
				);
				button.classList.add('border-white/15', 'bg-black/25', 'text-zinc-300');
			});

			const target = siblings.find((button) => button.getAttribute('data-filter-value') === value);
			if (!target) return;

			target.classList.add('active');
			target.classList.remove('border-white/15', 'bg-black/25', 'text-zinc-300');
			target.classList.add(...colorClasses[group]);
		};

		const applyFilters = () => {
			let visible = 0;
			cards.forEach((card) => {
				const matches =
					(activeFilters.domain === 'all' || card.getAttribute('data-domain') === activeFilters.domain) &&
					(activeFilters.level === 'all' || card.getAttribute('data-level') === activeFilters.level) &&
					(activeFilters.purpose === 'all' || card.getAttribute('data-purpose') === activeFilters.purpose);

				if (matches) {
					card.classList.remove('hidden');
					visible += 1;
				} else {
					card.classList.add('hidden');
				}
			});

			if (visibleCounter) {
				visibleCounter.textContent = `Showing ${visible} / ${cards.length}`;
			}
		};

		chips.forEach((chip) => {
			chip.addEventListener('click', () => {
				const group = chip.parentElement?.getAttribute('data-filter-group');
				const value = chip.getAttribute('data-filter-value');
				if (!group || !value || !['domain', 'level', 'purpose'].includes(group)) return;

				activeFilters[group as FilterKey] = value;
				setActiveChip(group as FilterKey, value);

				applyFilters();
				writeFiltersToQuery();
			});
		});

		readInitialFiltersFromQuery();
		(['domain', 'level', 'purpose'] as FilterKey[]).forEach((group) => {
			setActiveChip(group, activeFilters[group]);
		});
		applyFilters();
		writeFiltersToQuery();
	})();
</script>
