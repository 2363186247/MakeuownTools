---
import Layout from '../../layouts/Layout.astro';
import filaments from '../../data/filaments.json';
import satisfactoryData from '../../data/satisfactory.json';

type Material = { id: string; name: string };
type Diameter = { id: string; name: string; common?: boolean };
type FilamentsData = { materials: Material[]; diameters: Diameter[] };
type SatisfactoryItem = {
	id: string;
	name: string;
	category: string;
	machine: string;
	tier: number;
};
type SatisfactoryDataset = {
	items: SatisfactoryItem[];
	mvp_targets: string[];
};

const filamentData = filaments as FilamentsData;
const satData = satisfactoryData as SatisfactoryDataset;

const preferredDiameter = filamentData.diameters.find((d) => d.common) ?? filamentData.diameters[0];
const filamentFeatured = filamentData.materials.slice(0, 3).map((material) => ({
	name: `${material.name} · ${preferredDiameter.name}`,
	href: `/calculator/3d-printing/${material.id}-${preferredDiameter.id}`
}));

const quickLaunch = [
	{ label: 'LLM VRAM', href: '/calculator/vram/', tone: 'cyan' },
	{ label: 'NAS / RAID', href: '/calculator/nas-raid/', tone: 'sky' },
	{ label: 'Off-Grid Solar', href: '/calculator/off-grid-solar/', tone: 'amber' },
	{ label: '3D Printing', href: '/calculator/3d-printing/', tone: 'emerald' },
	{ label: 'Satisfactory', href: '/calculator/satisfactory/', tone: 'orange' }
] as const;

const satFeatured = satData.mvp_targets.slice(0, 4)
	.map((id) => satData.items.find((item) => item.id === id))
	.filter((item): item is SatisfactoryItem => Boolean(item));
---

<Layout
	title="Calculator Hub | Make Your Own Tools"
	description="Unified calculator hub for 3D printing planning and Satisfactory factory production modeling."
>
	<main class="mx-auto w-full max-w-7xl px-6 py-12 md:px-8 md:py-16">
		<a href="/" class="mb-7 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-300 transition hover:border-white/30 hover:bg-white/10">
			<span>←</span>
			<span>Home</span>
		</a>

		<section class="relative overflow-hidden rounded-3xl border border-white/15 bg-white/[0.03] p-7 md:p-9">
			<div class="pointer-events-none absolute -top-24 -right-16 h-64 w-64 rounded-full bg-emerald-400/15 blur-3xl"></div>
			<div class="pointer-events-none absolute -bottom-24 -left-16 h-64 w-64 rounded-full bg-cyan-400/15 blur-3xl"></div>

			<div class="relative grid gap-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
				<div>
					<div class="mb-4 flex flex-wrap gap-2">
						<span class="inline-flex items-center gap-2 rounded-full border border-cyan-300/30 bg-cyan-300/10 px-3 py-1 text-xs font-medium text-cyan-100">
							<svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M12 5v14"/></svg>
							AI
						</span>
						<span class="inline-flex items-center gap-2 rounded-full border border-sky-300/30 bg-sky-300/10 px-3 py-1 text-xs font-medium text-sky-100">
							<svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
							Storage
						</span>
						<span class="inline-flex items-center gap-2 rounded-full border border-amber-300/30 bg-amber-300/10 px-3 py-1 text-xs font-medium text-amber-100">
							<svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3v18M3 12h18"/><circle cx="12" cy="12" r="3"/></svg>
							Power
						</span>
						<span class="inline-flex items-center gap-2 rounded-full border border-emerald-300/30 bg-emerald-300/10 px-3 py-1 text-xs font-medium text-emerald-100">
							<svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 19h16M7 16l3-8 4 6 3-4"/></svg>
							Fabrication
						</span>
					</div>
					<p class="mb-3 inline-flex items-center rounded-full border border-white/20 bg-black/30 px-3 py-1 text-xs font-medium uppercase tracking-[0.18em] text-zinc-200">
						Calculator Hub
					</p>
					<h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">Production & Fabrication Calculators</h1>
					<p class="mt-4 max-w-3xl text-sm leading-7 text-zinc-300 md:text-base">
						One hub for multiple domains: VRAM capacity planning for LLM deployment, 3D printing filament estimation, and Satisfactory factory reverse planning.
					</p>
					<div class="mt-6">
						<p class="mb-3 text-xs uppercase tracking-[0.16em] text-zinc-400">Quick Launch</p>
						<div class="flex flex-wrap gap-2">
							{quickLaunch.map((item) => (
								<a
									href={item.href}
									class:list={[
										'inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.14em] transition',
										item.tone === 'cyan' && 'border-cyan-300/30 bg-cyan-300/10 text-cyan-100 hover:bg-cyan-300/20',
										item.tone === 'sky' && 'border-sky-300/30 bg-sky-300/10 text-sky-100 hover:bg-sky-300/20',
										item.tone === 'amber' && 'border-amber-300/30 bg-amber-300/10 text-amber-100 hover:bg-amber-300/20',
										item.tone === 'emerald' && 'border-emerald-300/30 bg-emerald-300/10 text-emerald-100 hover:bg-emerald-300/20',
										item.tone === 'orange' && 'border-orange-300/30 bg-orange-300/10 text-orange-100 hover:bg-orange-300/20'
									]}
								>
									<span>{item.label}</span>
									<span>→</span>
								</a>
							))}
						</div>
					</div>
				</div>

				<div class="rounded-2xl border border-white/15 bg-black/25 p-5">
					<p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-zinc-400"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M12 5v14"/></svg>Workflow Starts</p>
					<div class="mt-4 space-y-3 text-sm text-zinc-200">
						<a href="/calculator/vram/" data-tool-link data-tool-name="LLM VRAM Calculator" class="flex items-center justify-between rounded-xl border border-cyan-300/25 bg-cyan-300/10 px-3 py-2 transition hover:bg-cyan-300/20">
							<span>Deploying LLMs?</span>
							<span class="text-cyan-100">Start with VRAM</span>
						</a>
						<a href="/calculator/nas-raid/" data-tool-link data-tool-name="NAS & RAID Storage Calculator" class="flex items-center justify-between rounded-xl border border-sky-300/25 bg-sky-300/10 px-3 py-2 transition hover:bg-sky-300/20">
							<span>Buying disks?</span>
							<span class="text-sky-100">Plan RAID first</span>
						</a>
						<a href="/calculator/off-grid-solar/" data-tool-link data-tool-name="RV Off-Grid Solar & Battery Calculator" class="flex items-center justify-between rounded-xl border border-amber-300/25 bg-amber-300/10 px-3 py-2 transition hover:bg-amber-300/20">
							<span>Building off-grid?</span>
							<span class="text-amber-100">Size battery bank</span>
						</a>
					</div>
				</div>
			</div>
		</section>

		<section class="mt-7 rounded-2xl border border-white/12 bg-white/[0.02] p-4">
			<div class="flex flex-wrap items-center gap-2" id="domainFilterBar">
				<span class="mr-2 text-xs uppercase tracking-[0.14em] text-zinc-500">Filter</span>
				<button data-filter="all" class="rounded-full border border-white/20 bg-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-white">All</button>
				<button data-filter="ai" class="rounded-full border border-white/12 bg-black/30 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-zinc-300 transition hover:text-white">AI</button>
				<button data-filter="storage" class="rounded-full border border-white/12 bg-black/30 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-zinc-300 transition hover:text-white">Storage</button>
				<button data-filter="power" class="rounded-full border border-white/12 bg-black/30 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-zinc-300 transition hover:text-white">Power</button>
				<button data-filter="fabrication" class="rounded-full border border-white/12 bg-black/30 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-zinc-300 transition hover:text-white">Fabrication</button>
				<button data-filter="game" class="rounded-full border border-white/12 bg-black/30 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-zinc-300 transition hover:text-white">Game</button>
			</div>
		</section>

		<section class="mt-7 grid gap-5 lg:grid-cols-2 xl:grid-cols-5">
			<article data-domain="ai" class="group calculator-card rounded-3xl border border-cyan-300/25 bg-gradient-to-br from-cyan-300/12 to-blue-500/10 p-6 shadow-2xl shadow-cyan-900/15 transition hover:border-cyan-200/40 md:p-7">
				<div class="mb-4 flex items-center justify-between">
					<p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-cyan-100"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3v18M3 12h18"/></svg>AI / LLM</p>
					<span class="rounded-full border border-cyan-200/35 bg-cyan-100/10 px-2.5 py-0.5 text-xs font-semibold text-cyan-100">Priority</span>
				</div>
				<h2 class="text-2xl font-semibold tracking-tight text-white">LLM VRAM Calculator</h2>
				<p class="mt-3 text-sm leading-7 text-zinc-200">
					Fetch real Hugging Face configs and estimate VRAM for vLLM, Ollama, and LoRA scenarios with hardware matching.
				</p>
				<a href="/calculator/vram/" data-tool-link data-tool-name="LLM VRAM Calculator" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-cyan-200/35 bg-cyan-100/10 px-4 py-2 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-100/20">
					Open VRAM Calculator
					<span>→</span>
				</a>
			</article>

			<article data-domain="storage" class="group calculator-card rounded-3xl border border-sky-300/25 bg-gradient-to-br from-sky-300/12 to-indigo-500/10 p-6 shadow-2xl shadow-sky-900/15 transition hover:border-sky-200/40 md:p-7">
				<div class="mb-4 flex items-center justify-between">
					<p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-sky-100"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M4 12h16M4 17h16"/></svg>NAS / Homelab</p>
					<span class="rounded-full border border-sky-200/35 bg-sky-100/10 px-2.5 py-0.5 text-xs font-semibold text-sky-100">Live</span>
				</div>
				<h2 class="text-2xl font-semibold tracking-tight text-white">NAS & RAID Storage Calculator</h2>
				<p class="mt-3 text-sm leading-7 text-zinc-200">
					Estimate usable capacity, fault tolerance, and efficiency for RAID 0/1/5/6/10 and ZFS RAID-Z arrays before buying drives.
				</p>
				<a href="/calculator/nas-raid/" data-tool-link data-tool-name="NAS & RAID Storage Calculator" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-sky-200/35 bg-sky-100/10 px-4 py-2 text-sm font-semibold text-sky-100 transition hover:bg-sky-100/20">
					Open NAS / RAID Calculator
					<span>→</span>
				</a>
			</article>

			<article data-domain="power" class="group calculator-card rounded-3xl border border-amber-300/25 bg-gradient-to-br from-amber-300/12 to-yellow-500/10 p-6 shadow-2xl shadow-amber-900/15 transition hover:border-amber-200/40 md:p-7">
				<div class="mb-4 flex items-center justify-between">
					<p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-amber-100"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v20M5 9h14M7 16h10"/></svg>RV / Off-Grid</p>
					<span class="rounded-full border border-amber-200/35 bg-amber-100/10 px-2.5 py-0.5 text-xs font-semibold text-amber-100">SEO Scale</span>
				</div>
				<h2 class="text-2xl font-semibold tracking-tight text-white">RV Solar & Battery Calculator</h2>
				<p class="mt-3 text-sm leading-7 text-zinc-200">
					Estimate daily load, LiFePO4 battery Ah, panel wattage, and inverter baseline for 12V, 24V, and 48V off-grid systems.
				</p>
				<a href="/calculator/off-grid-solar/" data-tool-link data-tool-name="RV Off-Grid Solar & Battery Calculator" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-amber-200/35 bg-amber-100/10 px-4 py-2 text-sm font-semibold text-amber-100 transition hover:bg-amber-100/20">
					Open Off-Grid Calculator
					<span>→</span>
				</a>
			</article>

			<article data-domain="fabrication" class="group calculator-card rounded-3xl border border-emerald-300/25 bg-gradient-to-br from-emerald-300/12 to-lime-500/10 p-6 shadow-2xl shadow-emerald-900/15 transition hover:border-emerald-200/40 md:p-7">
				<div class="mb-4 flex items-center justify-between">
					<p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-emerald-100"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 8h12v8H6z"/><path d="M8 8V5h8v3"/></svg>3D Printing</p>
					<span class="rounded-full border border-emerald-200/35 bg-emerald-100/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-100">Live</span>
				</div>
				<h2 class="text-2xl font-semibold tracking-tight text-white">Filament Length Navigator</h2>
				<p class="mt-3 text-sm leading-7 text-zinc-200">
					Jump into dedicated profiles by material and diameter to estimate remaining printable length in real time, with print temperature guidance.
				</p>
				<a href="/calculator/3d-printing/" data-tool-link data-tool-name="3D Printing Filament Navigator" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-emerald-200/35 bg-emerald-100/10 px-4 py-2 text-sm font-semibold text-emerald-100 transition hover:bg-emerald-100/20">
					Open 3D Printing Calculators
					<span>→</span>
				</a>
				<ul class="mt-5 space-y-2 text-sm text-zinc-200">
					{filamentFeatured.map((item) => (
						<li>
							<a href={item.href} class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white">
								<span class="h-1.5 w-1.5 rounded-full bg-emerald-200"></span>
								<span>{item.name}</span>
							</a>
						</li>
					))}
				</ul>
			</article>

			<article data-domain="game" class="group calculator-card rounded-3xl border border-amber-300/25 bg-gradient-to-br from-amber-300/12 to-orange-500/10 p-6 shadow-2xl shadow-amber-900/15 transition hover:border-amber-200/40 md:p-7">
				<div class="mb-4 flex items-center justify-between">
					<p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-amber-100"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 18h16"/><path d="M6 18v-6h4v6M14 18v-9h4v9"/></svg>Satisfactory</p>
					<span class="rounded-full border border-amber-200/35 bg-amber-100/10 px-2.5 py-0.5 text-xs font-semibold text-amber-100">Live</span>
				</div>
				<h2 class="text-2xl font-semibold tracking-tight text-white">Factory Reverse Planner</h2>
				<p class="mt-3 text-sm leading-7 text-zinc-200">
					Set a target output rate and automatically reverse-calculate machine counts, power demand, and raw inputs across multi-level dependency chains.
				</p>
				<a href="/calculator/satisfactory/" data-tool-link data-tool-name="Satisfactory Factory Reverse Planner" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-amber-200/35 bg-amber-100/10 px-4 py-2 text-sm font-semibold text-amber-100 transition hover:bg-amber-100/20">
					Open Satisfactory Calculators
					<span>→</span>
				</a>
				<ul class="mt-5 space-y-2 text-sm text-zinc-200">
					{satFeatured.map((item) => (
						<li>
							<a href={`/calculator/satisfactory/${item.id}`} class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white">
								<span class="h-1.5 w-1.5 rounded-full bg-amber-200"></span>
								<span>{item.name}</span>
							</a>
						</li>
					))}
				</ul>
			</article>
		</section>

		<section class="mt-7 rounded-3xl border border-white/12 bg-white/[0.02] p-6 md:p-7">
			<div class="mb-4 flex items-center justify-between gap-3">
				<h3 class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-zinc-300"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-cyan-200" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 12h16"/><path d="M12 4v16"/></svg>Discover More Calculators</h3>
				<span class="text-xs uppercase tracking-[0.14em] text-zinc-500">Cross-Domain</span>
			</div>
			<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
				<a href="/calculator/vram/" data-tool-link data-tool-name="LLM VRAM Calculator" class="rounded-xl border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm font-medium text-cyan-100 transition hover:bg-cyan-300/20">LLM VRAM Capacity Planning</a>
				<a href="/calculator/nas-raid/" data-tool-link data-tool-name="NAS & RAID Storage Calculator" class="rounded-xl border border-sky-300/25 bg-sky-300/10 px-4 py-3 text-sm font-medium text-sky-100 transition hover:bg-sky-300/20">NAS RAID Capacity & Tolerance</a>
				<a href="/calculator/off-grid-solar/" data-tool-link data-tool-name="RV Off-Grid Solar & Battery Calculator" class="rounded-xl border border-amber-300/25 bg-amber-300/10 px-4 py-3 text-sm font-medium text-amber-100 transition hover:bg-amber-300/20">Off-Grid Solar & Battery Sizing</a>
				<a href="/calculator/satisfactory/" data-tool-link data-tool-name="Satisfactory Factory Reverse Planner" class="rounded-xl border border-orange-300/25 bg-orange-300/10 px-4 py-3 text-sm font-medium text-orange-100 transition hover:bg-orange-300/20">Satisfactory Reverse Planning</a>
			</div>
		</section>

		<section class="mt-7 rounded-3xl border border-white/12 bg-white/[0.02] p-6 md:p-7" id="recentToolsSection">
			<div class="mb-4 flex items-center justify-between gap-3">
				<h3 class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-zinc-300"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-cyan-200" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 6v6l4 2"/><circle cx="12" cy="12" r="9"/></svg>Recently Visited Tools</h3>
				<button id="clearRecentTools" class="text-xs uppercase tracking-[0.12em] text-zinc-500 transition hover:text-zinc-300">Clear</button>
			</div>
			<div id="recentToolsList" class="flex flex-wrap gap-2"></div>
		</section>

	</main>
</Layout>

<script>
	(() => {
		const RECENT_KEY = 'recent_calculator_tools';
		const filterBar = document.getElementById('domainFilterBar');
		const cards = Array.from(document.querySelectorAll<HTMLElement>('.calculator-card'));
		const recentToolsList = document.getElementById('recentToolsList');
		const clearRecentTools = document.getElementById('clearRecentTools');

		if (!(filterBar instanceof HTMLElement) || !(recentToolsList instanceof HTMLElement) || !(clearRecentTools instanceof HTMLButtonElement)) return;

		type RecentTool = { name: string; href: string };

		const getRecent = (): RecentTool[] => {
			try {
				const parsed = JSON.parse(localStorage.getItem(RECENT_KEY) ?? '[]');
				if (!Array.isArray(parsed)) return [];
				return parsed.filter((item) => item && typeof item.name === 'string' && typeof item.href === 'string').slice(0, 8);
			} catch {
				return [];
			}
		};

		const setRecent = (items: RecentTool[]) => {
			localStorage.setItem(RECENT_KEY, JSON.stringify(items.slice(0, 8)));
		};

		const renderRecent = () => {
			const items = getRecent();
			if (!items.length) {
				recentToolsList.innerHTML = '<p class="text-sm text-zinc-500">No tools visited yet. Open any calculator card to build your quick history.</p>';
				return;
			}
			recentToolsList.innerHTML = items.map((item) => (
				`<a href="${item.href}" class="rounded-full border border-white/15 bg-black/30 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-zinc-200 transition hover:text-white">${item.name}</a>`
			)).join('');
		};

		const applyFilter = (domain: string) => {
			cards.forEach((card) => {
				const matches = domain === 'all' || card.dataset.domain === domain;
				card.classList.toggle('hidden', !matches);
			});
			Array.from(filterBar.querySelectorAll<HTMLButtonElement>('button[data-filter]')).forEach((btn) => {
				const active = btn.dataset.filter === domain;
				btn.classList.toggle('bg-white/10', active);
				btn.classList.toggle('border-white/20', active);
				btn.classList.toggle('text-white', active);
				btn.classList.toggle('bg-black/30', !active);
				btn.classList.toggle('border-white/12', !active);
				btn.classList.toggle('text-zinc-300', !active);
			});
			const url = new URL(window.location.href);
			if (domain === 'all') url.searchParams.delete('domain');
			else url.searchParams.set('domain', domain);
			history.replaceState({}, '', `${url.pathname}${url.search}${url.hash}`);
		};

		filterBar.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;
			const button = target.closest('button[data-filter]');
			if (!(button instanceof HTMLButtonElement)) return;
			applyFilter(button.dataset.filter ?? 'all');
		});

		document.querySelectorAll<HTMLAnchorElement>('a[data-tool-link]').forEach((link) => {
			link.addEventListener('click', () => {
				const name = link.dataset.toolName?.trim() || link.textContent?.trim() || 'Calculator Tool';
				const href = link.getAttribute('href') || '/calculator/';
				const next = getRecent().filter((item) => item.href !== href);
				next.unshift({ name, href });
				setRecent(next);
			});
		});

		clearRecentTools.addEventListener('click', () => {
			localStorage.removeItem(RECENT_KEY);
			renderRecent();
		});

		const initialDomain = new URL(window.location.href).searchParams.get('domain') ?? 'all';
		const validDomain = ['all', 'ai', 'storage', 'power', 'fabrication', 'game'].includes(initialDomain) ? initialDomain : 'all';
		applyFilter(validDomain);
		renderRecent();
	})();
</script>
