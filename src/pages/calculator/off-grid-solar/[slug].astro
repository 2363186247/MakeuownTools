---
import Layout from '../../../layouts/Layout.astro';
import {
  CHEMISTRY_DEFAULTS,
  estimateOffGridSystem,
  getOffGridSolarSeoEntries,
  getSolarKeywordEntries,
  getSolarScenarioEntries,
  type OffGridSeoEntry,
  type SolarKeywordEntry,
  type SolarComparisonEntry,
  type SolarScenarioEntry,
  type SolarVoltage
} from '../../../data/offGridSolarSeo';

export function getStaticPaths() {
  return getOffGridSolarSeoEntries().map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

type Props = { entry: OffGridSeoEntry };
const { entry } = Astro.props as Props;

const allSolarEntries = getOffGridSolarSeoEntries();
const currentSolarIndex = allSolarEntries.findIndex((item) => item.slug === entry.slug);
const prevSolarEntry = currentSolarIndex >= 0
  ? allSolarEntries[(currentSolarIndex - 1 + allSolarEntries.length) % allSolarEntries.length]
  : null;
const nextSolarEntry = currentSolarIndex >= 0
  ? allSolarEntries[(currentSolarIndex + 1) % allSolarEntries.length]
  : null;

const pageTitle = entry.title;
const pageDescription = entry.description;
const siteOrigin = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://makeyourowntools.com';
const canonicalUrl = `${siteOrigin}/calculator/off-grid-solar/${entry.slug}/`;

function fmt(v: number, d = 2): string {
  return v.toFixed(d);
}

function roundUp(value: number, step: number): number {
  return Math.ceil(value / step) * step;
}

function buildAmazonSearch(query: string): string {
  return `https://www.amazon.com/s?k=${encodeURIComponent(query)}`;
}

let scenarioCalc: ReturnType<typeof estimateOffGridSystem> | null = null;
let voltageRows: Array<{ voltage: SolarVoltage; calc: ReturnType<typeof estimateOffGridSystem> }> = [];
let faqItems: Array<{ question: string; answer: string }> = [];
const keywordEntry = entry.type === 'keyword' ? (entry as SolarKeywordEntry) : null;
const scenarioLikeEntry = (entry.type === 'scenario' || entry.type === 'keyword')
  ? (entry as SolarScenarioEntry | SolarKeywordEntry)
  : null;

function hashSeed(value: string): number {
  let hash = 0;
  for (let i = 0; i < value.length; i += 1) {
    hash = ((hash << 5) - hash + value.charCodeAt(i)) | 0;
  }
  return Math.abs(hash);
}

function rotateTake<T>(pool: T[], count: number, seed: number): T[] {
  if (pool.length <= count) return pool;
  const start = seed % pool.length;
  const result: T[] = [];
  for (let i = 0; i < count; i += 1) {
    result.push(pool[(start + i) % pool.length]);
  }
  return result;
}

if (scenarioLikeEntry) {
  const s = scenarioLikeEntry;
  const chemistryDefaults = CHEMISTRY_DEFAULTS[s.batteryChemistry];
  scenarioCalc = estimateOffGridSystem({
    appliances: s.appliances,
    voltage: s.voltage,
    sunHours: s.sunHours,
    autonomyDays: s.autonomyDays,
    batteryChemistry: s.batteryChemistry,
    ...chemistryDefaults
  });

  const scenarioFaqPool: Array<{ question: string; answer: string }> = [
    {
      question: `${s.voltage}V solar setup: how many battery Ah do I need?`,
      answer: `For this load profile, estimated ${s.batteryChemistry.toUpperCase()} bank sizing is ${fmt(scenarioCalc.batteryAh, 1)} Ah at ${s.voltage}V with ${s.autonomyDays}-day autonomy.`
    },
    {
      question: `How many watts of solar panels are required for ${s.sunHours} peak sun hours?`,
      answer: `The calculator estimates ${fmt(scenarioCalc.panelW, 0)} W panel capacity after charge and derate factors.`
    },
    {
      question: 'Why does lower battery voltage usually require higher Ah?',
      answer: 'For the same energy demand, lower voltage systems need more current. That translates into larger Ah requirements and often thicker cabling.'
    },
    {
      question: 'Should I oversize panels or batteries first?',
      answer: 'In low-sun conditions, panel oversizing usually improves daily recovery. In high-cloud windows, additional battery autonomy reduces outage risk.'
    },
    {
      question: `Is ${s.batteryChemistry.toUpperCase()} efficient for this load profile?`,
      answer: `Yes, the model applies chemistry-specific assumptions for DoD and charging to keep estimates closer to practical planning ranges.`
    },
    {
      question: 'Can this replace a full electrical audit?',
      answer: 'Use this for planning and shortlist decisions, then validate with measured appliance duty cycles and local irradiance history.'
    }
  ];

  faqItems = rotateTake(scenarioFaqPool, 4, hashSeed(entry.slug));
}

if (entry.type === 'comparison') {
  const c = entry as SolarComparisonEntry;
  voltageRows = ([12, 24, 48] as SolarVoltage[]).map((voltage) => ({
    voltage,
    calc: estimateOffGridSystem({
      appliances: c.appliances,
      voltage,
      sunHours: 4.5,
      autonomyDays: 1,
      batteryChemistry: 'lifepo4',
      ...CHEMISTRY_DEFAULTS.lifepo4
    })
  }));

  const comparisonFaqPool: Array<{ question: string; answer: string }> = [
    {
      question: '12V vs 24V vs 48V: which is better for off-grid systems?',
      answer: 'Higher-voltage architectures reduce current for the same power, which can improve wiring efficiency and scalability. Final choice depends on load size and equipment compatibility.'
    },
    {
      question: 'Does changing voltage change daily energy use?',
      answer: 'Daily energy in Wh stays the same for the same appliances. Voltage mainly changes current, wiring stress, and battery Ah sizing.'
    },
    {
      question: 'Can I use this calculator before buying hardware?',
      answer: 'Yes. Use these estimates for pre-purchase planning, then validate with real appliance duty cycles and local irradiance data.'
    },
    {
      question: 'Which voltage reduces cable losses in longer runs?',
      answer: 'For the same power, 24V and 48V systems run lower current than 12V, usually reducing copper losses and cable sizing pressure.'
    },
    {
      question: 'Is 48V always the best choice?',
      answer: 'Not always. 48V helps larger systems, but compatibility and budget may favor 24V or 12V for small and medium builds.'
    },
    {
      question: 'How should inverter surge be considered?',
      answer: 'Use startup surge requirements from appliances and verify inverter surge ratings, especially for compressor and microwave loads.'
    }
  ];

  faqItems = rotateTake(comparisonFaqPool, 4, hashSeed(entry.slug));
}

const relatedSeed = hashSeed(entry.slug);
const relatedPool = allSolarEntries.filter((item) => item.slug !== entry.slug);
const related = rotateTake(relatedPool, 18, relatedSeed);

const keywordGuides: Record<string, { title: string; lines: string[] }> = {
  region: {
    title: 'Regional Sun-Window Guidance',
    lines: [
      'Use local monthly irradiance data to tune peak-sun-hour assumptions before procurement.',
      'Cloud-prone months usually benefit from higher autonomy targets and larger reserve buffers.',
      'For winter-heavy climates, panel overbuild is often cheaper than repeated battery deep cycles.'
    ]
  },
  chemistry: {
    title: 'Battery Chemistry Planning Notes',
    lines: [
      'LiFePO4 generally supports higher usable DoD and stable cycle life for daily off-grid cycling.',
      'AGM requires more conservative DoD planning, often increasing required nominal Ah.',
      'NMC can reduce volume and mass but should be evaluated against thermal and lifecycle targets.'
    ]
  },
  brand: {
    title: 'Brand-Oriented Load Architecture',
    lines: [
      'Brand keyword pages map typical duty-cycle patterns to speed up first-pass sizing decisions.',
      'Validate actual appliance telemetry after install and update sizing margins if runtime differs.',
      'Use the interactive calculator to test alternative voltage and autonomy assumptions quickly.'
    ]
  }
};

const keywordGuide = keywordEntry ? keywordGuides[keywordEntry.keywordCategory] : null;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `${siteOrigin}/`
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Calculator Hub',
      item: `${siteOrigin}/calculator/`
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'RV Off-Grid Solar & Battery Sizing Calculator',
      item: `${siteOrigin}/calculator/off-grid-solar/`
    },
    {
      '@type': 'ListItem',
      position: 4,
      name: pageTitle,
      item: canonicalUrl
    }
  ]
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};

const scenarioShopping = scenarioLikeEntry && scenarioCalc
  ? {
      batteryAh: roundUp(Math.max(50, scenarioCalc.batteryAh), 50),
      panelW: roundUp(Math.max(100, scenarioCalc.panelW), 100),
      controllerA: roundUp((roundUp(Math.max(100, scenarioCalc.panelW), 100) / scenarioLikeEntry.voltage) * 1.25, 10),
      inverterW: roundUp(Math.max(500, scenarioCalc.recommendedInverterW), 500),
      voltage: scenarioLikeEntry.voltage
    }
  : null;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
  includeBackground={false}
  bodyClass="solar-page min-h-screen bg-[#f6f2ea] text-slate-950 antialiased [font-family:Inter,ui-sans-serif,system-ui,sans-serif]"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>
  </Fragment>

  <main class="solar-band">
    <section class="mx-auto w-full max-w-7xl px-6 py-8 md:px-8 md:py-12">
      <a href="/calculator/off-grid-solar/" class="mb-6 inline-flex w-fit items-center gap-2 rounded-full border border-slate-200 bg-white/80 px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-slate-600 transition hover:border-amber-300 hover:text-slate-950">
        <span>←</span>
        <span>Off-Grid Solar Calculator</span>
      </a>

      <header class="solar-seo-hero">
        <p>Solar planning page</p>
        <h1>{pageTitle}</h1>
        <span>{pageDescription}</span>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a href="/calculator/off-grid-solar/#calculator" class="solar-button-primary">Customize this system</a>
          <a href="/calculator/off-grid-solar/#recommendations" class="solar-button-secondary">See buying tiers</a>
        </div>
      </header>

      {scenarioLikeEntry && scenarioCalc && (
        <section class="mt-6 grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
          <article class="solar-result-panel p-5 text-white md:p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-amber-200">Sizing snapshot</p>
            <h2 class="mt-1 text-2xl font-semibold tracking-tight">Recommended baseline for this load profile</h2>
            <div class="mt-5 grid gap-3 sm:grid-cols-2">
              <article class="solar-metric-card">
                <p>Daily energy</p>
                <strong>{fmt(scenarioCalc.whDaily, 0)} Wh</strong>
              </article>
              <article class="solar-metric-card">
                <p>Battery bank</p>
                <strong>{fmt(scenarioCalc.batteryAh, 1)} Ah</strong>
              </article>
              <article class="solar-metric-card">
                <p>Solar array</p>
                <strong>{fmt(scenarioCalc.panelW, 0)} W</strong>
              </article>
              <article class="solar-metric-card">
                <p>Inverter baseline</p>
                <strong>{fmt(scenarioCalc.recommendedInverterW, 0)} W</strong>
              </article>
            </div>
          </article>

          <article class="solar-panel p-5 md:p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Load breakdown</p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">What this estimate is based on</h2>
            <div class="mt-5 overflow-x-auto">
              <table class="solar-data-table">
                <thead>
                  <tr>
                    <th>Appliance</th>
                    <th>Power</th>
                    <th>Daily runtime</th>
                    <th>Wh/day</th>
                  </tr>
                </thead>
                <tbody>
                  {scenarioLikeEntry.appliances.map((a) => (
                    <tr>
                      <td>{a.name}</td>
                      <td>{a.powerW} W</td>
                      <td>{fmt(a.hoursPerDay, 2)} h</td>
                      <td>{fmt(a.powerW * a.hoursPerDay, 0)} Wh</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </article>
        </section>
      )}

      {scenarioShopping && (
        <section class="mt-6 solar-panel p-5 md:p-6">
          <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-amber-700">Non-affiliate buying baseline</p>
              <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">Use these as comparison searches</h2>
            </div>
            <p class="max-w-2xl text-sm leading-7 text-slate-600">
              These are plain search links with no affiliate tag. Verify voltage, current, BMS limits, surge rating, fuses, and wiring before purchase.
            </p>
          </div>
          <div class="solar-tier-actions">
            <a href={buildAmazonSearch(`${scenarioShopping.voltage}V ${scenarioShopping.batteryAh}Ah LiFePO4 battery`)} target="_blank" rel="nofollow noopener" class="solar-search-link">Battery: {scenarioShopping.batteryAh}Ah</a>
            <a href={buildAmazonSearch(`${scenarioShopping.panelW}W solar panel kit RV`)} target="_blank" rel="nofollow noopener" class="solar-search-link">Panels: {scenarioShopping.panelW}W</a>
            <a href={buildAmazonSearch(`${scenarioShopping.controllerA}A MPPT solar charge controller ${scenarioShopping.voltage}V`)} target="_blank" rel="nofollow noopener" class="solar-search-link">MPPT: {scenarioShopping.controllerA}A</a>
            <a href={buildAmazonSearch(`${scenarioShopping.inverterW}W pure sine inverter ${scenarioShopping.voltage}V`)} target="_blank" rel="nofollow noopener" class="solar-search-link">Inverter: {scenarioShopping.inverterW}W</a>
          </div>
        </section>
      )}

      {keywordEntry && keywordGuide && (
        <section class="mt-6 solar-panel p-5 md:p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">{keywordGuide.title}</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">{keywordEntry.highlight}</h2>
          <div class="mt-5 grid gap-3 md:grid-cols-3">
            {keywordGuide.lines.map((line) => (
              <article class="solar-trust-card"><span>{line}</span></article>
            ))}
          </div>
        </section>
      )}

      {entry.type === 'comparison' && (
        <section class="mt-6 solar-panel p-5 md:p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Voltage architecture comparison</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">Compare battery Ah, solar watts, and inverter baseline</h2>
          <div class="mt-5 overflow-x-auto">
            <table class="solar-data-table">
              <thead>
                <tr>
                  <th>Voltage</th>
                  <th>Battery Ah</th>
                  <th>Solar W</th>
                  <th>Inverter W</th>
                </tr>
              </thead>
              <tbody>
                {voltageRows.map((row) => (
                  <tr>
                    <td>{row.voltage}V</td>
                    <td>{fmt(row.calc.batteryAh, 1)} Ah</td>
                    <td>{fmt(row.calc.panelW, 0)} W</td>
                    <td>{fmt(row.calc.recommendedInverterW, 0)} W</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      <section class="mt-6 grid gap-6 lg:grid-cols-[1fr_1fr]">
        <article class="solar-panel p-5 md:p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Trust notes</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">Before turning this into a cart</h2>
          <ul class="solar-check-list mt-5">
            <li>Use this page for first-pass planning, then validate real appliance duty cycles.</li>
            <li>Confirm MPPT input voltage, controller current, BMS current, fuse sizing, and wire gauge.</li>
            <li>Open the full calculator to test cloudy weather, autonomy days, and alternate system voltages.</li>
          </ul>
        </article>

        <article class="solar-panel p-5 md:p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">FAQ</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">Quick buyer questions</h2>
          <div class="mt-5 grid gap-3">
            {faqItems.map((item) => (
              <details class="solar-faq-item">
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </article>
      </section>

      <section class="mt-6 solar-panel p-5 md:p-6">
        <div class="mb-4 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Related long-tail solar calculators</p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">Keep comparing realistic setups</h2>
          </div>
          <a href="/calculator/off-grid-solar/" class="text-sm font-semibold text-amber-700 transition hover:text-slate-950">Open main calculator →</a>
        </div>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((item) => (
            <a href={`/calculator/off-grid-solar/${item.slug}/`} class="solar-link-tile">
              {item.type === 'keyword'
                ? `${item.keywordLabel} · ${item.voltage}V · ${item.sunHours}h sun`
                : item.type === 'scenario'
                  ? `${item.voltage}V · ${item.sunHours}h sun · ${item.autonomyDays} day`
                  : `${item.compareBy === 'sun-hours' ? 'Sun-hours compare' : 'Voltage compare'} · ${item.appliances.length} loads`}
            </a>
          ))}
        </div>
      </section>

      {(prevSolarEntry && nextSolarEntry) && (
        <section class="mt-6 grid gap-3 sm:grid-cols-2">
          <a href={`/calculator/off-grid-solar/${prevSolarEntry.slug}/`} class="solar-profile-card">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-amber-700">Previous</p>
            <h2 class="mt-2 text-lg font-semibold text-slate-950">{prevSolarEntry.title}</h2>
          </a>
          <a href={`/calculator/off-grid-solar/${nextSolarEntry.slug}/`} class="solar-profile-card">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-amber-700">Next</p>
            <h2 class="mt-2 text-lg font-semibold text-slate-950">{nextSolarEntry.title}</h2>
          </a>
        </section>
      )}
    </section>
  </main>
</Layout>
