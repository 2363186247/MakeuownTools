---
import Layout from '../../../layouts/Layout.astro';
import { pickSeoTitle } from '../../../data/seoExperiment';

const vramTitle = pickSeoTitle(
  'LLM VRAM Calculator | Inference & LoRA GPU Memory Estimator',
  'GPU Memory Calculator for LLMs | VRAM for Inference and LoRA'
);
---

<Layout
  title={vramTitle}
  description="Estimate GPU memory for LLM inference and LoRA training using live Hugging Face configs, context length, quantization, and hardware matching."
>
  <main class="mx-auto w-full max-w-7xl px-6 py-10 md:px-8 md:py-14">
    <a href="/calculator/" class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-300 transition hover:bg-white/10">
      <span>←</span>
      <span>All Calculators</span>
    </a>

    <header class="mb-10">
      <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-cyan-500/30 bg-cyan-500/10 px-3 py-1 text-xs font-medium uppercase tracking-widest text-cyan-200">
        <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M12 5v14"/></svg>
        AI Infrastructure Console
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-white md:text-6xl">LLM VRAM Calculator</h1>
      <p class="mt-4 max-w-3xl text-zinc-400">
        Fetch model config from Hugging Face, parse architecture parameters, and compute realistic VRAM usage for deployment and LoRA workflows.
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <section class="rounded-3xl border border-white/10 bg-white/[0.02] p-6 backdrop-blur md:p-8 lg:h-full">
          <h2 class="mb-4 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-widest text-zinc-300"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-cyan-200" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12h18M12 3v18"/></svg>1. Model Source</h2>

          <label class="mb-4 block">
            <span class="mb-1 block text-xs text-zinc-400">Hugging Face Model ID</span>
            <div class="flex gap-2">
              <input id="modelIdInput" type="text" placeholder="e.g. Qwen/Qwen2.5-7B-Instruct" class="w-full rounded-xl border border-white/15 bg-black/40 px-4 py-3 font-mono text-sm text-white outline-none transition focus:border-cyan-500/50" />
              <button id="fetchBtn" class="rounded-xl bg-cyan-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-cyan-500">Fetch Config</button>
            </div>
          </label>

          <div class="mb-4">
            <p class="mb-2 text-xs uppercase tracking-[0.12em] text-zinc-500">Quick Picks</p>
            <div id="quickModelPicks" class="flex flex-wrap gap-2"></div>
          </div>

          <div class="mb-4 rounded-xl border border-white/10 bg-black/30 p-3">
            <div class="mb-2 flex items-center justify-between gap-3">
              <p class="text-xs uppercase tracking-[0.12em] text-zinc-500">Recent Models</p>
              <button id="clearRecentModelsBtn" class="text-xs text-zinc-400 transition hover:text-zinc-200">Clear</button>
            </div>
            <div id="recentModelsList" class="flex flex-wrap gap-2"></div>
          </div>

          <label class="mb-2 block">
            <span class="mb-1 block text-xs text-zinc-400">Hugging Face Token (Optional)</span>
            <input id="hfTokenInput" type="password" placeholder="hf_..." class="w-full rounded-xl border border-white/15 bg-black/40 px-4 py-3 font-mono text-xs text-white outline-none transition focus:border-cyan-500/50" />
          </label>
          <p class="text-xs text-zinc-500">
            Needed only for gated models such as Llama 3. Token is stored only in localStorage and never sent to any server except direct Hugging Face requests from your browser.
          </p>

          <div id="statusMessage" class="mt-4 hidden rounded-lg border p-3 text-xs font-mono"></div>

          <div id="configSummaryCard" class="mt-4 hidden rounded-xl border border-white/10 bg-black/35 p-4">
            <p class="mb-3 text-xs uppercase tracking-[0.12em] text-zinc-500">Parsed Summary</p>
            <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-xs">
              <div>
                <dt class="text-zinc-500">Model Type</dt>
                <dd id="summaryModelType" class="font-mono text-zinc-200">-</dd>
              </div>
              <div>
                <dt class="text-zinc-500">Parameters</dt>
                <dd id="summaryParams" class="font-mono text-zinc-200">-</dd>
              </div>
              <div>
                <dt class="text-zinc-500">Hidden / Layers</dt>
                <dd id="summaryHiddenLayers" class="font-mono text-zinc-200">-</dd>
              </div>
              <div>
                <dt class="text-zinc-500">Heads / KV Heads</dt>
                <dd id="summaryHeads" class="font-mono text-zinc-200">-</dd>
              </div>
              <div>
                <dt class="text-zinc-500">Max Context</dt>
                <dd id="summaryContext" class="font-mono text-zinc-200">-</dd>
              </div>
              <div>
                <dt class="text-zinc-500">Attention Pattern</dt>
                <dd id="summaryAttention" class="font-mono text-zinc-200">-</dd>
              </div>
            </dl>
          </div>
      </section>

      <section class="rounded-3xl border border-white/10 bg-white/[0.02] p-6 backdrop-blur md:p-8 lg:h-full">
          <h2 class="mb-4 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-widest text-zinc-300"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-cyan-200" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M4 12h16M4 17h16"/></svg>2. Scenario</h2>
          <p class="mb-4 text-xs text-zinc-500">
            If you are unsure about some architecture parameters, you can leave them empty. We will estimate when possible, but accuracy may decrease.
          </p>

          <div class="mb-4 grid grid-cols-2 gap-2 rounded-xl border border-white/10 bg-black/30 p-1">
            <button id="modeInference" class="rounded-lg bg-cyan-500/20 px-3 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-cyan-100">Inference</button>
            <button id="modeTraining" class="rounded-lg px-3 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-zinc-300">Training / LoRA</button>
          </div>

          <div class="mb-3 flex items-center justify-between">
            <span class="text-xs uppercase tracking-[0.12em] text-zinc-400">Context Length</span>
            <span id="contextValue" class="font-mono text-xs text-cyan-200">8192 tokens</span>
          </div>
          <input id="contextRange" type="range" min="2048" max="131072" step="1024" value="8192" class="w-full accent-cyan-500" />

          <div class="mt-5 grid grid-cols-2 gap-3">
            <label>
              <span class="mb-1 block text-xs text-zinc-400">Parameters (Billions)</span>
              <input id="paramsInput" type="number" step="0.1" placeholder="e.g. 7" class="w-full rounded-xl border border-white/15 bg-black/40 px-3 py-2 font-mono text-sm text-white outline-none focus:border-cyan-500/50" />
            </label>
            <label>
              <span class="mb-1 block text-xs text-zinc-400">Hidden Size</span>
              <input id="hiddenSizeInput" type="number" placeholder="e.g. 4096" class="w-full rounded-xl border border-white/15 bg-black/40 px-3 py-2 font-mono text-sm text-white outline-none focus:border-cyan-500/50" />
            </label>
            <label>
              <span class="mb-1 block text-xs text-zinc-400">Layers</span>
              <input id="layersInput" type="number" placeholder="e.g. 32" class="w-full rounded-xl border border-white/15 bg-black/40 px-3 py-2 font-mono text-sm text-white outline-none focus:border-cyan-500/50" />
            </label>
            <label>
              <span class="mb-1 block text-xs text-zinc-400">Attention Heads</span>
              <input id="headsInput" type="number" placeholder="e.g. 32" class="w-full rounded-xl border border-white/15 bg-black/40 px-3 py-2 font-mono text-sm text-white outline-none focus:border-cyan-500/50" />
            </label>
            <label>
              <span class="mb-1 block text-xs text-zinc-400">KV Heads</span>
              <input id="kvHeadsInput" type="number" placeholder="e.g. 8" class="w-full rounded-xl border border-white/15 bg-black/40 px-3 py-2 font-mono text-sm text-white outline-none focus:border-cyan-500/50" />
            </label>
            <label>
              <span class="mb-1 block text-xs text-zinc-400">Vocab Size</span>
              <input id="vocabInput" type="number" placeholder="e.g. 32000" class="w-full rounded-xl border border-white/15 bg-black/40 px-3 py-2 font-mono text-sm text-white outline-none focus:border-cyan-500/50" />
            </label>
          </div>

          <div class="mt-4 rounded-xl border border-white/10 bg-black/30 p-3">
            <p class="text-xs uppercase tracking-[0.12em] text-zinc-500">Architecture Signal</p>
            <div class="mt-2 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
              <p id="archSignal" class="font-mono text-sm text-cyan-200">Auto detect from head ratio</p>
              <label class="flex items-center gap-2 text-xs text-zinc-400">
                <span>Mode</span>
                <select id="archModeSelect" class="rounded-lg border border-white/15 bg-black/50 px-2 py-1 text-xs text-white outline-none focus:border-cyan-500/50">
                  <option value="auto">Auto</option>
                  <option value="gqa">Force GQA</option>
                  <option value="mqa">Force MQA</option>
                  <option value="mha">Force MHA</option>
                </select>
              </label>
            </div>
          </div>

          <div class="mt-4 rounded-xl border border-white/10 bg-black/30 p-3">
            <div class="flex items-center justify-between gap-3">
              <p class="text-xs uppercase tracking-[0.12em] text-zinc-500">MoE Signal</p>
              <label class="flex items-center gap-2 text-xs text-zinc-300">
                <input id="moeEnabledInput" type="checkbox" class="h-4 w-4 accent-cyan-500" />
                <span>Enable MoE profile</span>
              </label>
            </div>
            <div class="mt-3 grid grid-cols-2 gap-3">
              <label>
                <span class="mb-1 block text-xs text-zinc-400">Total Experts</span>
                <input id="moeExpertsInput" type="number" min="1" step="1" placeholder="e.g. 8" class="w-full rounded-xl border border-white/15 bg-black/40 px-3 py-2 font-mono text-sm text-white outline-none focus:border-cyan-500/50" />
              </label>
              <label>
                <span class="mb-1 block text-xs text-zinc-400">Active Experts / Token</span>
                <input id="moeActiveExpertsInput" type="number" min="1" step="1" placeholder="e.g. 2" class="w-full rounded-xl border border-white/15 bg-black/40 px-3 py-2 font-mono text-sm text-white outline-none focus:border-cyan-500/50" />
              </label>
            </div>
            <div class="mt-3">
              <div class="mb-1 flex items-center justify-between text-xs text-zinc-400">
                <span>Shared Parameters Ratio</span>
                <span id="moeSharedRatioValue" class="font-mono text-cyan-200">25%</span>
              </div>
              <input id="moeSharedRatioInput" type="range" min="0" max="100" step="1" value="25" class="w-full accent-cyan-500" />
            </div>
            <p id="moeSignal" class="mt-2 font-mono text-xs text-zinc-400">Dense mode (MoE disabled)</p>
          </div>
      </section>

      <section class="space-y-6 lg:col-span-2">
        <div class="rounded-3xl border border-cyan-500/20 bg-gradient-to-br from-cyan-500/10 to-blue-500/5 p-6 backdrop-blur md:p-8">
          <h2 class="mb-4 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-widest text-cyan-200"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 17h14M8 14h8M10 11h4"/></svg>3. VRAM Matrix + Hardware Match</h2>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[620px] text-left text-sm">
              <thead>
                <tr class="border-b border-white/10 text-xs uppercase tracking-[0.12em] text-zinc-400">
                  <th class="py-3">Runtime</th>
                  <th class="py-3">Quantization</th>
                  <th class="py-3">Weights</th>
                  <th class="py-3">KV / Activations</th>
                  <th class="py-3">Total</th>
                  <th class="py-3">Dense vs MoE</th>
                </tr>
              </thead>
              <tbody id="resultTableBody" class="text-zinc-200"></tbody>
            </table>
          </div>
          <div class="mt-6 rounded-2xl border border-white/10 bg-black/35 p-5">
            <p class="mb-3 text-xs uppercase tracking-widest text-zinc-400">Hardware Match</p>
            <div class="flex flex-wrap gap-2" id="hardwareTags"></div>
            <p id="hardwareHint" class="mt-3 text-sm text-zinc-400"></p>
          </div>
        </div>
      </section>
    </div>

    <section class="mt-8 rounded-3xl border border-white/10 bg-white/[0.02] p-6 md:p-8">
      <h3 class="mb-4 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-zinc-300"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-cyan-200" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 12h16"/><path d="M12 4v16"/></svg>Explore Other Calculators</h3>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/calculator/nas-raid/" data-tool-link data-tool-name="NAS & RAID Storage Calculator" class="rounded-xl border border-sky-300/25 bg-sky-300/10 px-4 py-3 text-sm font-medium text-sky-100 transition hover:bg-sky-300/20">NAS & RAID Capacity</a>
        <a href="/calculator/off-grid-solar/" data-tool-link data-tool-name="RV Off-Grid Solar & Battery Calculator" class="rounded-xl border border-amber-300/25 bg-amber-300/10 px-4 py-3 text-sm font-medium text-amber-100 transition hover:bg-amber-300/20">Off-Grid Solar Sizing</a>
        <a href="/calculator/3d-printing/" data-tool-link data-tool-name="3D Printing Filament Navigator" class="rounded-xl border border-emerald-300/25 bg-emerald-300/10 px-4 py-3 text-sm font-medium text-emerald-100 transition hover:bg-emerald-300/20">3D Printing Profiles</a>
        <a href="/calculator/satisfactory/" data-tool-link data-tool-name="Satisfactory Factory Reverse Planner" class="rounded-xl border border-orange-300/25 bg-orange-300/10 px-4 py-3 text-sm font-medium text-orange-100 transition hover:bg-orange-300/20">Satisfactory Planner</a>
      </div>
    </section>

    <section class="mt-8 rounded-3xl border border-white/10 bg-white/[0.02] p-6 md:p-8" id="recentToolsSection">
      <div class="mb-4 flex items-center justify-between gap-3">
        <h3 class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-zinc-300"><svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-cyan-200" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 6v6l4 2"/><circle cx="12" cy="12" r="9"/></svg>Recently Visited Tools</h3>
        <button id="clearRecentTools" class="text-xs uppercase tracking-[0.12em] text-zinc-500 transition hover:text-zinc-300">Clear</button>
      </div>
      <div id="recentToolsList" class="flex flex-wrap gap-2"></div>
    </section>
  </main>

  <script>
    const modelIdInput = document.getElementById('modelIdInput');
    const hfTokenInput = document.getElementById('hfTokenInput');
    const fetchBtn = document.getElementById('fetchBtn');
    const statusMessage = document.getElementById('statusMessage');
    const quickModelPicks = document.getElementById('quickModelPicks');
    const recentModelsList = document.getElementById('recentModelsList');
    const clearRecentModelsBtn = document.getElementById('clearRecentModelsBtn');
    const configSummaryCard = document.getElementById('configSummaryCard');
    const summaryModelType = document.getElementById('summaryModelType');
    const summaryParams = document.getElementById('summaryParams');
    const summaryHiddenLayers = document.getElementById('summaryHiddenLayers');
    const summaryHeads = document.getElementById('summaryHeads');
    const summaryContext = document.getElementById('summaryContext');
    const summaryAttention = document.getElementById('summaryAttention');

    const paramsInput = document.getElementById('paramsInput');
    const hiddenSizeInput = document.getElementById('hiddenSizeInput');
    const layersInput = document.getElementById('layersInput');
    const headsInput = document.getElementById('headsInput');
    const kvHeadsInput = document.getElementById('kvHeadsInput');
    const vocabInput = document.getElementById('vocabInput');

    const contextRange = document.getElementById('contextRange');
    const contextValue = document.getElementById('contextValue');

    const modeInference = document.getElementById('modeInference');
    const modeTraining = document.getElementById('modeTraining');

    const archSignal = document.getElementById('archSignal');
    const resultTableBody = document.getElementById('resultTableBody');
    const hardwareTags = document.getElementById('hardwareTags');
    const hardwareHint = document.getElementById('hardwareHint');
    const archModeSelect = document.getElementById('archModeSelect');
    const moeEnabledInput = document.getElementById('moeEnabledInput');
    const moeExpertsInput = document.getElementById('moeExpertsInput');
    const moeActiveExpertsInput = document.getElementById('moeActiveExpertsInput');
    const moeSignal = document.getElementById('moeSignal');
    const moeSharedRatioInput = document.getElementById('moeSharedRatioInput');
    const moeSharedRatioValue = document.getElementById('moeSharedRatioValue');

    if (
      !(modelIdInput instanceof HTMLInputElement) ||
      !(hfTokenInput instanceof HTMLInputElement) ||
      !(fetchBtn instanceof HTMLButtonElement) ||
      !(statusMessage instanceof HTMLElement) ||
      !(quickModelPicks instanceof HTMLElement) ||
      !(recentModelsList instanceof HTMLElement) ||
      !(clearRecentModelsBtn instanceof HTMLButtonElement) ||
      !(configSummaryCard instanceof HTMLElement) ||
      !(summaryModelType instanceof HTMLElement) ||
      !(summaryParams instanceof HTMLElement) ||
      !(summaryHiddenLayers instanceof HTMLElement) ||
      !(summaryHeads instanceof HTMLElement) ||
      !(summaryContext instanceof HTMLElement) ||
      !(summaryAttention instanceof HTMLElement) ||
      !(paramsInput instanceof HTMLInputElement) ||
      !(hiddenSizeInput instanceof HTMLInputElement) ||
      !(layersInput instanceof HTMLInputElement) ||
      !(headsInput instanceof HTMLInputElement) ||
      !(kvHeadsInput instanceof HTMLInputElement) ||
      !(vocabInput instanceof HTMLInputElement) ||
      !(contextRange instanceof HTMLInputElement) ||
      !(contextValue instanceof HTMLElement) ||
      !(modeInference instanceof HTMLButtonElement) ||
      !(modeTraining instanceof HTMLButtonElement) ||
      !(archSignal instanceof HTMLElement) ||
      !(resultTableBody instanceof HTMLElement) ||
      !(hardwareTags instanceof HTMLElement) ||
      !(hardwareHint instanceof HTMLElement) ||
      !(archModeSelect instanceof HTMLSelectElement) ||
      !(moeEnabledInput instanceof HTMLInputElement) ||
      !(moeExpertsInput instanceof HTMLInputElement) ||
      !(moeActiveExpertsInput instanceof HTMLInputElement) ||
      !(moeSignal instanceof HTMLElement) ||
      !(moeSharedRatioInput instanceof HTMLInputElement) ||
      !(moeSharedRatioValue instanceof HTMLElement)
    ) {
      throw new Error('VRAM calculator UI is missing required elements.');
    }

    const modelIdInputEl = modelIdInput as HTMLInputElement;
    const hfTokenInputEl = hfTokenInput as HTMLInputElement;
    const fetchBtnEl = fetchBtn as HTMLButtonElement;
    const statusMessageEl = statusMessage as HTMLElement;
    const quickModelPicksEl = quickModelPicks as HTMLElement;
    const recentModelsListEl = recentModelsList as HTMLElement;
    const clearRecentModelsBtnEl = clearRecentModelsBtn as HTMLButtonElement;
    const configSummaryCardEl = configSummaryCard as HTMLElement;
    const summaryModelTypeEl = summaryModelType as HTMLElement;
    const summaryParamsEl = summaryParams as HTMLElement;
    const summaryHiddenLayersEl = summaryHiddenLayers as HTMLElement;
    const summaryHeadsEl = summaryHeads as HTMLElement;
    const summaryContextEl = summaryContext as HTMLElement;
    const summaryAttentionEl = summaryAttention as HTMLElement;
    const paramsInputEl = paramsInput as HTMLInputElement;
    const hiddenSizeInputEl = hiddenSizeInput as HTMLInputElement;
    const layersInputEl = layersInput as HTMLInputElement;
    const headsInputEl = headsInput as HTMLInputElement;
    const kvHeadsInputEl = kvHeadsInput as HTMLInputElement;
    const vocabInputEl = vocabInput as HTMLInputElement;
    const contextRangeEl = contextRange as HTMLInputElement;
    const contextValueEl = contextValue as HTMLElement;
    const modeInferenceEl = modeInference as HTMLButtonElement;
    const modeTrainingEl = modeTraining as HTMLButtonElement;
    const archSignalEl = archSignal as HTMLElement;
    const resultTableBodyEl = resultTableBody as HTMLElement;
    const hardwareTagsEl = hardwareTags as HTMLElement;
    const hardwareHintEl = hardwareHint as HTMLElement;
    const archModeSelectEl = archModeSelect as HTMLSelectElement;
    const moeEnabledInputEl = moeEnabledInput as HTMLInputElement;
    const moeExpertsInputEl = moeExpertsInput as HTMLInputElement;
    const moeActiveExpertsInputEl = moeActiveExpertsInput as HTMLInputElement;
    const moeSignalEl = moeSignal as HTMLElement;
    const moeSharedRatioInputEl = moeSharedRatioInput as HTMLInputElement;
    const moeSharedRatioValueEl = moeSharedRatioValue as HTMLElement;

    let mode = 'inference';
    const RECENT_MODELS_KEY = 'vram_recent_models';

    const QUICK_MODEL_IDS = [
      'Qwen/Qwen2.5-7B-Instruct',
      'meta-llama/Llama-3.1-8B-Instruct',
      'mistralai/Mistral-7B-Instruct-v0.3',
      'mistralai/Mixtral-8x7B-Instruct-v0.1',
      'deepseek-ai/DeepSeek-R1-Distill-Qwen-7B'
    ];

    const savedToken = localStorage.getItem('hf_token');
    if (savedToken) hfTokenInputEl.value = savedToken;

    function showStatus(message: string, isError = false): void {
      statusMessageEl.classList.remove('hidden', 'border-red-500/30', 'bg-red-500/10', 'text-red-300', 'border-emerald-500/30', 'bg-emerald-500/10', 'text-emerald-300');
      if (isError) {
        statusMessageEl.classList.add('border-red-500/30', 'bg-red-500/10', 'text-red-300');
      } else {
        statusMessageEl.classList.add('border-emerald-500/30', 'bg-emerald-500/10', 'text-emerald-300');
      }
      statusMessageEl.textContent = message;
    }

    function readRecentModels(): string[] {
      try {
        const raw = localStorage.getItem(RECENT_MODELS_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return [];
        return parsed.filter((item) => typeof item === 'string' && item.trim().length > 0).slice(0, 5);
      } catch {
        return [];
      }
    }

    function writeRecentModels(models: string[]): void {
      localStorage.setItem(RECENT_MODELS_KEY, JSON.stringify(models.slice(0, 5)));
    }

    function pushRecentModel(modelId: string): void {
      const normalized = modelId.trim();
      if (!normalized) return;
      const current = readRecentModels().filter((item) => item !== normalized);
      writeRecentModels([normalized, ...current]);
      renderRecentModels();
    }

    function renderRecentModels(): void {
      const models = readRecentModels();
      if (models.length === 0) {
        recentModelsListEl.innerHTML = '<span class="text-xs text-zinc-500">No recent models yet.</span>';
        return;
      }

      recentModelsListEl.innerHTML = '';
      models.forEach((modelId) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'rounded-full border border-white/15 bg-black/40 px-3 py-1 text-xs font-mono text-zinc-200 transition hover:border-cyan-400/60 hover:text-cyan-100';
        btn.textContent = modelId;
        btn.addEventListener('click', () => {
          modelIdInputEl.value = modelId;
          fetchModelConfig();
        });
        recentModelsListEl.appendChild(btn);
      });
    }

    function renderQuickPicks(): void {
      quickModelPicksEl.innerHTML = '';
      QUICK_MODEL_IDS.forEach((modelId) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-xs font-semibold text-cyan-100 transition hover:border-cyan-300/70 hover:bg-cyan-300/20';
        btn.textContent = modelId;
        btn.addEventListener('click', () => {
          modelIdInputEl.value = modelId;
          fetchModelConfig();
        });
        quickModelPicksEl.appendChild(btn);
      });
    }

    function renderConfigSummary(modelId: string, config: any, paramsB: number): void {
      const heads = Number(config.num_attention_heads) || 0;
      const kvHeads = Number(config.num_key_value_heads) || heads;
      let pattern = 'Unknown';
      if (kvHeads <= 1) pattern = 'MQA';
      else if (heads > 0 && kvHeads < heads) pattern = 'GQA';
      else if (heads > 0) pattern = 'MHA';

      const contextCandidates = [
        config.max_position_embeddings,
        config.max_sequence_length,
        config.model_max_length
      ].filter((v) => typeof v === 'number' && Number.isFinite(v));

      summaryModelTypeEl.textContent = String(config.model_type || modelId || '-');
      summaryParamsEl.textContent = paramsB > 0 ? `${paramsB.toFixed(2)}B` : '-';
      summaryHiddenLayersEl.textContent = `${Number(config.hidden_size) || '-'} / ${Number(config.num_hidden_layers) || '-'}`;
      summaryHeadsEl.textContent = `${heads || '-'} / ${kvHeads || '-'}`;
      summaryContextEl.textContent = contextCandidates.length > 0 ? `${contextCandidates[0]} tokens` : '-';
      summaryAttentionEl.textContent = pattern;
      configSummaryCardEl.classList.remove('hidden');
    }

    function toGB(bytes: number): number {
      return bytes / (1024 ** 3);
    }

    function readNum(el: HTMLInputElement, fallback = 0): number {
      const v = Number(el.value);
      return Number.isFinite(v) ? v : fallback;
    }

    function estimateParamsFromArch(hidden: number, layers: number, vocab: number): number {
      return ((layers * (12 * hidden * hidden)) + (vocab * hidden)) / 1e9;
    }

    function kvBytesPerToken(hidden: number, layers: number, attentionHeads: number, kvHeads: number): number {
      const safeHeads = Math.max(1, attentionHeads);
      const safeKvHeads = Math.max(1, kvHeads);
      const headDim = hidden / safeHeads;
      const kvHidden = headDim * safeKvHeads;
      return 2 * 2 * layers * kvHidden;
    }

    function getEffectiveKvHeads(heads: number, kvHeads: number): number {
      const selected = archModeSelectEl.value;
      if (selected === 'mqa') return 1;
      if (selected === 'mha') return Math.max(1, heads);
      if (selected === 'gqa') return Math.max(1, Math.min(kvHeads, Math.max(1, heads - 1)));
      return Math.max(1, kvHeads);
    }

    type RuntimeRow = { runtime: string; quant: string; weights: number; dyn: number; total: number };

    type ModelProfile = {
      totalParamsB: number;
      activeParamsB: number;
      isMoe: boolean;
      totalExperts: number;
      activeExperts: number;
      sharedRatio: number;
    };

    function runtimeRows(profile: ModelProfile, contextTokens: number, hidden: number, layers: number, heads: number, kvHeads: number): RuntimeRow[] {
      const weightFp16 = profile.totalParamsB * 2;
      const weight8 = profile.totalParamsB * 1;
      const weight4 = profile.totalParamsB * 0.56;
      const activeWeightFp16 = profile.activeParamsB * 2;

      const kvGB = toGB(kvBytesPerToken(hidden, layers, heads, kvHeads) * contextTokens);
      const inferOverhead = 1.5 + Math.max(0.5, activeWeightFp16 * 0.02);
      const loraActivation = Math.max(4, (activeWeightFp16 * 0.15) + kvGB * 0.5);
      const loraOptimizer = profile.activeParamsB * 0.2;

      if (mode === 'inference') {
        return [
          { runtime: 'vLLM', quant: 'FP16/BF16', weights: weightFp16, dyn: kvGB + inferOverhead, total: weightFp16 + kvGB + inferOverhead },
          { runtime: 'HuggingFace Transformers', quant: '8-bit', weights: weight8, dyn: kvGB + inferOverhead, total: weight8 + kvGB + inferOverhead },
          { runtime: 'Ollama / GGUF', quant: 'Q4_K_M', weights: weight4, dyn: kvGB + inferOverhead, total: weight4 + kvGB + inferOverhead }
        ];
      }

      return [
        { runtime: 'LoRA (QLoRA)', quant: '4-bit base + adapters', weights: weight4 + (profile.activeParamsB * 0.03), dyn: loraActivation, total: weight4 + (profile.activeParamsB * 0.03) + loraActivation },
        { runtime: 'LoRA (8-bit base)', quant: '8-bit base + adapters', weights: weight8 + (profile.activeParamsB * 0.03), dyn: loraActivation + loraOptimizer, total: weight8 + (profile.activeParamsB * 0.03) + loraActivation + loraOptimizer },
        { runtime: 'Full Fine-tune', quant: 'FP16', weights: weightFp16 * 2, dyn: loraActivation + (weightFp16 * 2), total: (weightFp16 * 2) + loraActivation + (weightFp16 * 2) }
      ];
    }

    function buildModelProfile(totalParamsB: number): ModelProfile {
      if (!moeEnabledInputEl.checked) {
        moeSignalEl.textContent = 'Dense mode (MoE disabled)';
        return { totalParamsB, activeParamsB: totalParamsB, isMoe: false, totalExperts: 1, activeExperts: 1, sharedRatio: 1 };
      }

      const totalExperts = Math.max(1, Math.round(readNum(moeExpertsInputEl, 8)));
      const activeExperts = Math.max(1, Math.min(totalExperts, Math.round(readNum(moeActiveExpertsInputEl, 2))));

      const sharedRatio = Math.max(0, Math.min(1, readNum(moeSharedRatioInputEl, 25) / 100));
      const routedRatio = 1 - sharedRatio;
      const activeRatio = activeExperts / totalExperts;
      const activeParamsB = totalParamsB * (sharedRatio + routedRatio * activeRatio);

      moeSignalEl.textContent = `MoE active: ${activeExperts}/${totalExperts} experts | shared ${(sharedRatio * 100).toFixed(0)}% (~${activeParamsB.toFixed(2)}B active params)`;
      return { totalParamsB, activeParamsB, isMoe: true, totalExperts, activeExperts, sharedRatio };
    }

    function setHardwareMatch(requiredGb: number): void {
      hardwareTagsEl.innerHTML = '';

      const choices = [
        { label: 'RTX 4060 8GB', gb: 8 },
        { label: 'RTX 4070 12GB', gb: 12 },
        { label: 'RTX 4090 24GB', gb: 24 },
        { label: 'RTX A6000 48GB', gb: 48 },
        { label: 'H100 80GB', gb: 80 }
      ];

      const viable = choices.filter((c) => c.gb >= requiredGb);
      const primary = viable[0] || choices[choices.length - 1];

      const tags = [];
      if (requiredGb <= 24) {
        tags.push(`1x ${primary.label}`);
      } else if (requiredGb <= 48) {
        tags.push('2x RTX 3090/4090 (24GB)');
        tags.push('or 1x RTX A6000 48GB');
      } else if (requiredGb <= 80) {
        tags.push('1x H100 80GB');
        tags.push('or multi-GPU 4090 setup');
      } else {
        tags.push('Multi-GPU datacenter setup required');
      }

      tags.forEach((text) => {
        const el = document.createElement('span');
        el.className = 'rounded-full border border-cyan-300/35 bg-cyan-300/10 px-3 py-1 text-xs font-semibold text-cyan-100';
        el.textContent = `Requires: ${text}`;
        hardwareTagsEl.appendChild(el);
      });

      hardwareHintEl.textContent = `Estimated requirement uses ${mode === 'inference' ? 'inference' : 'training'} profile and selected context length.`;
    }

    function updateArchSignal(heads: number, kvHeads: number): void {
      const selected = archModeSelectEl.value;
      if (selected === 'mqa') {
        archSignalEl.textContent = 'MQA forced (single KV head)';
        return;
      }
      if (selected === 'mha') {
        archSignalEl.textContent = 'MHA forced (KV heads = attention heads)';
        return;
      }
      if (selected === 'gqa') {
        archSignalEl.textContent = `GQA forced (${kvHeads} KV heads / ${heads} attention heads)`;
        return;
      }

      if (kvHeads <= 1) {
        archSignalEl.textContent = 'MQA detected (single KV head)';
      } else if (kvHeads < heads) {
        archSignalEl.textContent = `GQA detected (${kvHeads} KV heads / ${heads} attention heads)`;
      } else {
        archSignalEl.textContent = 'MHA style attention (KV heads = attention heads)';
      }
    }

    function render(): void {
      const paramsBManual = Math.max(0, readNum(paramsInputEl, 0));
      const hidden = Math.max(64, readNum(hiddenSizeInputEl, 4096));
      const layers = Math.max(1, readNum(layersInputEl, 32));
      const heads = Math.max(1, readNum(headsInputEl, 32));
      const kvHeads = Math.max(1, readNum(kvHeadsInputEl, 8));
      const effectiveKvHeads = getEffectiveKvHeads(heads, kvHeads);
      const vocab = Math.max(1000, readNum(vocabInputEl, 32000));
      const context = Math.max(2048, readNum(contextRangeEl, 8192));

      contextValueEl.textContent = `${context} tokens`;

      const heuristics = estimateParamsFromArch(hidden, layers, vocab);
      const paramsB = paramsBManual > 0 ? paramsBManual : Math.max(0.1, heuristics * 0.8);
      const profile = buildModelProfile(paramsB);

      const rows = runtimeRows(profile, context, hidden, layers, heads, effectiveKvHeads);
      const denseRows = runtimeRows(
        { totalParamsB: profile.totalParamsB, activeParamsB: profile.totalParamsB, isMoe: false, totalExperts: 1, activeExperts: 1, sharedRatio: 1 },
        context,
        hidden,
        layers,
        heads,
        effectiveKvHeads
      );
      updateArchSignal(heads, effectiveKvHeads);
      moeSharedRatioValueEl.textContent = `${Math.round(readNum(moeSharedRatioInputEl, 25))}%`;

      resultTableBodyEl.innerHTML = rows.map((row, index) => {
        const denseTotal = denseRows[index]?.total ?? row.total;
        const savingPct = denseTotal > 0 ? ((denseTotal - row.total) / denseTotal) * 100 : 0;
        const savingText = profile.isMoe ? `${savingPct >= 0 ? '+' : ''}${savingPct.toFixed(2)}%` : '-';
        const savingClass = profile.isMoe
          ? savingPct >= 0
            ? 'text-emerald-200'
            : 'text-amber-200'
          : 'text-zinc-500';

        return `
          <tr class="border-b border-white/5">
            <td class="py-3 font-medium text-white">${row.runtime}</td>
            <td class="py-3 text-zinc-300">${row.quant}</td>
            <td class="py-3 font-mono text-zinc-200">${row.weights.toFixed(2)} GB</td>
            <td class="py-3 font-mono text-zinc-300">${row.dyn.toFixed(2)} GB</td>
            <td class="py-3 font-mono text-cyan-200">${row.total.toFixed(2)} GB</td>
            <td class="py-3 font-mono ${savingClass}">${savingText}</td>
          </tr>
        `;
      }).join('');

      const anchor = rows[rows.length - 1];
      setHardwareMatch(anchor.total);
    }

    async function fetchModelConfig(): Promise<void> {
      const modelId = modelIdInputEl.value.trim();
      if (!modelId) {
        showStatus('Please provide a valid Hugging Face model ID.', true);
        return;
      }

      const token = hfTokenInputEl.value.trim();
      if (token) {
        localStorage.setItem('hf_token', token);
      } else {
        localStorage.removeItem('hf_token');
      }

      showStatus(`Fetching config for ${modelId} ...`);
      fetchBtnEl.textContent = 'Loading...';

      try {
        const headers: Record<string, string> = {};
        if (token) headers.Authorization = `Bearer ${token}`;
        const [configRes, modelRes] = await Promise.all([
          fetch(`https://huggingface.co/${modelId}/resolve/main/config.json`, { headers }),
          fetch(`https://huggingface.co/api/models/${modelId}`, { headers })
        ]);

        if (!configRes.ok) {
          throw new Error(`Cannot fetch config.json (${configRes.status}). If this is a gated model, provide your HF token.`);
        }

        const config = await configRes.json();
        const modelInfo = modelRes.ok ? await modelRes.json() : null;

        if (typeof config.hidden_size === 'number') hiddenSizeInputEl.value = String(config.hidden_size);
        if (typeof config.num_hidden_layers === 'number') layersInputEl.value = String(config.num_hidden_layers);
        if (typeof config.num_attention_heads === 'number') headsInputEl.value = String(config.num_attention_heads);
        if (typeof config.num_key_value_heads === 'number') {
          kvHeadsInputEl.value = String(config.num_key_value_heads);
          if (typeof config.num_attention_heads === 'number' && config.num_key_value_heads < config.num_attention_heads) {
            archModeSelectEl.value = 'gqa';
          }
        }
        else if (typeof config.num_attention_heads === 'number') kvHeadsInputEl.value = String(config.num_attention_heads);
        if (typeof config.vocab_size === 'number') vocabInputEl.value = String(config.vocab_size);

        const moeExperts = Number(
          config.num_local_experts ??
          config.num_experts ??
          config.n_routed_experts ??
          modelInfo?.config?.num_local_experts ??
          modelInfo?.config?.num_experts ??
          0
        );
        const moeActiveExperts = Number(
          config.num_experts_per_tok ??
          config.n_activated_experts ??
          modelInfo?.config?.num_experts_per_tok ??
          0
        );

        if (Number.isFinite(moeExperts) && moeExperts > 1) {
          moeEnabledInputEl.checked = true;
          moeExpertsInputEl.value = String(Math.round(moeExperts));
          moeActiveExpertsInputEl.value = String(Math.max(1, Math.round(moeActiveExperts) || 2));
        }

        const contextCandidates = [
          config.max_position_embeddings,
          config.max_sequence_length,
          config.model_max_length
        ].filter((v) => typeof v === 'number' && Number.isFinite(v));
        if (contextCandidates.length > 0) {
          const clamped = Math.max(2048, Math.min(131072, contextCandidates[0]));
          contextRangeEl.value = String(Math.round(clamped / 1024) * 1024);
        }

        let paramsB = 0;
        if (modelInfo?.safetensors?.total) {
          paramsB = modelInfo.safetensors.total / 1e9;
        }
        if (!paramsB && modelInfo?.config?.num_parameters) {
          paramsB = modelInfo.config.num_parameters / 1e9;
        }
        if (!paramsB && typeof config.hidden_size === 'number' && typeof config.num_hidden_layers === 'number') {
          paramsB = estimateParamsFromArch(
            config.hidden_size,
            config.num_hidden_layers,
            Number(config.vocab_size) || 32000
          );
        }

        if (paramsB > 0) {
          paramsInputEl.value = paramsB.toFixed(2);
        }

        renderConfigSummary(modelId, config, paramsB);
        pushRecentModel(modelId);

        showStatus(`Loaded config for ${modelId}. Parsed architecture and refreshed estimates.`);
        render();
      } catch (error: unknown) {
        const message = error instanceof Error ? error.message : String(error);
        showStatus(message, true);
      } finally {
        fetchBtnEl.textContent = 'Fetch Config';
      }
    }

    function setMode(nextMode: 'inference' | 'training'): void {
      mode = nextMode;
      if (mode === 'inference') {
        modeInferenceEl.classList.add('bg-cyan-500/20', 'text-cyan-100');
        modeInferenceEl.classList.remove('text-zinc-300');
        modeTrainingEl.classList.remove('bg-cyan-500/20', 'text-cyan-100');
        modeTrainingEl.classList.add('text-zinc-300');
      } else {
        modeTrainingEl.classList.add('bg-cyan-500/20', 'text-cyan-100');
        modeTrainingEl.classList.remove('text-zinc-300');
        modeInferenceEl.classList.remove('bg-cyan-500/20', 'text-cyan-100');
        modeInferenceEl.classList.add('text-zinc-300');
      }
      render();
    }

    fetchBtnEl.addEventListener('click', fetchModelConfig);
    modelIdInputEl.addEventListener('keypress', (event) => {
      if (event.key === 'Enter') fetchModelConfig();
    });

    modeInferenceEl.addEventListener('click', () => setMode('inference'));
    modeTrainingEl.addEventListener('click', () => setMode('training'));

    [paramsInputEl, hiddenSizeInputEl, layersInputEl, headsInputEl, kvHeadsInputEl, vocabInputEl, contextRangeEl].forEach((el) => {
      el.addEventListener('input', render);
    });
    archModeSelectEl.addEventListener('change', render);
    moeEnabledInputEl.addEventListener('change', render);
    moeExpertsInputEl.addEventListener('input', render);
    moeActiveExpertsInputEl.addEventListener('input', render);
    moeSharedRatioInputEl.addEventListener('input', render);
    clearRecentModelsBtnEl.addEventListener('click', () => {
      localStorage.removeItem(RECENT_MODELS_KEY);
      renderRecentModels();
    });

    renderQuickPicks();
    renderRecentModels();

    const queryParams = new URLSearchParams(window.location.search);
    const modelParam = queryParams.get('model');
    const modeParam = queryParams.get('mode');
    if (modelParam) modelIdInputEl.value = modelParam;

    setMode(modeParam === 'training' ? 'training' : 'inference');
    render();
    if (modelParam) fetchModelConfig();
  </script>

  <script>
    (() => {
      const RECENT_KEY = 'recent_calculator_tools';
      const recentToolsList = document.getElementById('recentToolsList');
      const clearRecentTools = document.getElementById('clearRecentTools');
      if (!(recentToolsList instanceof HTMLElement) || !(clearRecentTools instanceof HTMLButtonElement)) return;

      type RecentTool = { name: string; href: string };

      const getRecent = (): RecentTool[] => {
        try {
          const parsed = JSON.parse(localStorage.getItem(RECENT_KEY) ?? '[]');
          if (!Array.isArray(parsed)) return [];
          return parsed.filter((item) => item && typeof item.name === 'string' && typeof item.href === 'string').slice(0, 8);
        } catch {
          return [];
        }
      };

      const setRecent = (items: RecentTool[]) => {
        localStorage.setItem(RECENT_KEY, JSON.stringify(items.slice(0, 8)));
      };

      const renderRecent = () => {
        const items = getRecent();
        if (!items.length) {
          recentToolsList.innerHTML = '<p class="text-sm text-zinc-500">No tools visited yet. Use the links above to build quick history.</p>';
          return;
        }
        recentToolsList.innerHTML = items.map((item) => (`
          <a href="${item.href}" class="rounded-full border border-white/15 bg-black/30 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-zinc-200 transition hover:text-white">${item.name}</a>
        `)).join('');
      };

      document.querySelectorAll<HTMLAnchorElement>('a[data-tool-link]').forEach((link) => {
        link.addEventListener('click', () => {
          const name = link.dataset.toolName?.trim() || link.textContent?.trim() || 'Calculator Tool';
          const href = link.getAttribute('href') || '/calculator/';
          const next = getRecent().filter((item) => item.href !== href);
          next.unshift({ name, href });
          setRecent(next);
        });
      });

      clearRecentTools.addEventListener('click', () => {
        localStorage.removeItem(RECENT_KEY);
        renderRecent();
      });

      renderRecent();
    })();
  </script>
</Layout>
