---
import '../styles/global.css';
import services from '../data/services.json';

type App = (typeof services.apps)[number];
type Database = (typeof services.databases)[number];
type Proxy = (typeof services.proxies)[number];

// Generate all valid combinations
const combinations: Array<{ app: App; db: Database; proxy: Proxy }> = [];

services.apps.forEach(app => {
  services.databases.forEach(db => {
    if (!Array.isArray(app.supported_dbs) || !app.supported_dbs.includes(db.id)) return;
    
    services.proxies.forEach(proxy => {
      combinations.push({ app, db, proxy });
    });
  });
});

// Group by app for better navigation
const appGroups = services.apps.map(app => ({
  app,
  combinations: combinations.filter(c => c.app.id === app.id)
})).filter(g => g.combinations.length > 0);

// Calculate total combinations for SEO statement
const totalCombinations = combinations.length;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Docker Compose Generator • {totalCombinations}+ Self-Hosted App Presets</title>
    <meta name="description" content={`Generate production-ready docker-compose.yml for ${totalCombinations}+ combinations of popular self-hosted apps, databases, and reverse proxies. Ghost, WordPress, Nextcloud, Gitea, and more.`} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="/" />
  </head>
  <body class="min-h-screen bg-gradient-to-br from-zinc-900 via-zinc-800 to-zinc-900 text-zinc-50 antialiased [font-family:Geist,ui-sans-serif,system-ui,sans-serif]">
    <main class="mx-auto w-full max-w-7xl px-6 py-16 md:px-8 md:py-24">
      <!-- Hero Section -->
      <div class="mb-16 text-center">
        <div class="mb-4 inline-block px-4 py-2 rounded-full border border-zinc-700 bg-zinc-800/50 backdrop-blur-sm">
          <span class="text-xs font-medium uppercase tracking-[0.16em] text-zinc-300">
            🚀 Docker Compose Generator
          </span>
        </div>
        <h1 class="mb-4 text-5xl md:text-7xl font-bold tracking-tight text-white">
          Deploy Self-Hosted Apps <br />
          <span class="bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
            in Minutes
          </span>
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-zinc-300 md:text-xl leading-relaxed">
          Generate production-ready <span class="font-mono text-zinc-200">docker-compose.yml</span> for {totalCombinations}+ combinations
          of your favorite self-hosted applications, databases, and reverse proxies.
        </p>
      </div>

      <!-- Stats -->
      <div class="mb-16 grid grid-cols-3 gap-4 md:gap-8">
        <div class="rounded-xl border border-zinc-700 bg-zinc-800/30 backdrop-blur-sm p-6 text-center">
          <div class="text-3xl md:text-4xl font-bold text-blue-400">{services.apps.length}</div>
          <div class="mt-2 text-sm text-zinc-400">Apps</div>
        </div>
        <div class="rounded-xl border border-zinc-700 bg-zinc-800/30 backdrop-blur-sm p-6 text-center">
          <div class="text-3xl md:text-4xl font-bold text-amber-400">{services.databases.length}</div>
          <div class="mt-2 text-sm text-zinc-400">Databases</div>
        </div>
        <div class="rounded-xl border border-zinc-700 bg-zinc-800/30 backdrop-blur-sm p-6 text-center">
          <div class="text-3xl md:text-4xl font-bold text-purple-400">{services.proxies.length}</div>
          <div class="mt-2 text-sm text-zinc-400">Proxies</div>
        </div>
      </div>

      <!-- Apps Navigation -->
      <div class="space-y-12">
        {appGroups.map(group => (
          <section class="rounded-2xl border border-zinc-700/50 bg-zinc-900/50 backdrop-blur-sm overflow-hidden">
            <!-- App Header -->
            <div class="px-6 md:px-8 py-6 md:py-8 border-b border-zinc-700/50 bg-gradient-to-r from-zinc-800/50 to-transparent">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0">
                  <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-blue-500/20 border border-blue-500/30">
                    <span class="text-lg">📦</span>
                  </div>
                </div>
                <div class="flex-1">
                  <h2 class="text-2xl md:text-3xl font-bold text-white">{group.app.name}</h2>
                  <p class="mt-2 text-sm text-zinc-400 font-mono">{group.app.image}</p>
                  <p class="mt-1 text-sm text-zinc-400">
                    {group.combinations.length} {group.combinations.length === 1 ? 'configuration' : 'configurations'} available
                  </p>
                </div>
              </div>
            </div>

            <!-- Combinations Grid -->
            <div class="p-6 md:p-8">
              <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {group.combinations.map(combo => (
                  <a
                    href={`/${combo.app.id}-${combo.db.id}-${combo.proxy.id}/`}
                    class="group relative rounded-lg border border-zinc-700 bg-zinc-800/30 hover:bg-zinc-800/60 px-4 py-4 transition-all duration-200 hover:border-zinc-600"
                  >
                    <!-- Glow on Hover -->
                    <div class="absolute inset-0 rounded-lg bg-gradient-to-r from-blue-500/0 to-purple-500/0 group-hover:from-blue-500/10 group-hover:to-purple-500/10 transition duration-200"></div>
                    
                    <!-- Content -->
                    <div class="relative">
                      <div class="flex items-center justify-between mb-3">
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-zinc-700/50 text-xs font-semibold text-zinc-300">
                          <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>
                          {combo.db.name}
                        </span>
                        <span class="text-xs text-zinc-500 group-hover:text-zinc-400 transition">→</span>
                      </div>
                      <div class="flex items-center justify-between mb-2">
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-zinc-700/50 text-xs font-semibold text-zinc-300">
                          <span class="w-1.5 h-1.5 rounded-full bg-purple-400"></span>
                          {combo.proxy.name}
                        </span>
                      </div>
                      <p class="text-xs text-zinc-500 group-hover:text-zinc-400 transition font-mono mt-3">
                        {combo.app.id}-{combo.db.id}-{combo.proxy.id}
                      </p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </section>
        ))}
      </div>

      <!-- Footer CTA -->
      <div class="mt-16 rounded-2xl border border-zinc-700/50 bg-gradient-to-r from-blue-500/10 to-purple-500/10 backdrop-blur-sm p-8 md:p-12 text-center">
        <h3 class="text-2xl md:text-3xl font-bold text-white mb-3">Ready to Deploy?</h3>
        <p class="text-zinc-300 mb-6">
          Pick any combination above to generate your production-ready docker-compose configuration.
        </p>
        <p class="text-sm text-zinc-400">
          All presets include environment variables for seamless .env integration and best practices for self-hosted deployments.
        </p>
      </div>

      <!-- Footer -->
      <footer class="mt-16 pt-8 border-t border-zinc-700/30 text-center text-sm text-zinc-500">
        <p>
          Generate {totalCombinations}+ unique deployment configurations. 
          <br />
          Perfect for pSEO and self-hosted infrastructure documentation.
        </p>
      </footer>
    </main>
  </body>
</html>
