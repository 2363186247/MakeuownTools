---
import '../styles/global.css';
import services from '../data/services.json';
import filaments from '../data/filaments.json';

type App = {
  id: string;
  name: string;
  supported_dbs: string[];
};
type Db = { id: string; name: string };
type Proxy = { id: string; name: string };
type Material = { id: string; name: string };
type Diameter = { id: string; name: string; common?: boolean };

type ServicesData = {
  apps: App[];
  databases: Db[];
  proxies: Proxy[];
};
type FilamentsData = {
  materials: Material[];
  diameters: Diameter[];
};

const servicesData = services as ServicesData;
const filamentsData = filaments as FilamentsData;

const dockerRoutes = servicesData.apps.reduce((total, app) => {
  const compatibleCount = servicesData.databases.filter((db) => app.supported_dbs.includes(db.id)).length;
  return total + compatibleCount * servicesData.proxies.length;
}, 0);

const calculatorRoutes = filamentsData.materials.length * filamentsData.diameters.length;

const featuredDocker = servicesData.apps.slice(0, 3).flatMap((app) => {
  const db = servicesData.databases.find((d) => app.supported_dbs.includes(d.id));
  const proxy = servicesData.proxies[0];
  if (!db || !proxy) return [];

  return [{
    name: `${app.name} + ${db.name} + ${proxy.name}`,
    href: `/docker/${app.id}-${db.id}-${proxy.id}/`
  }];
});

const preferredDiameter = filamentsData.diameters.find((d) => d.common) ?? filamentsData.diameters[0];
const featuredCalculator = filamentsData.materials.slice(0, 3).map((material) => ({
  name: `${material.name} · ${preferredDiameter.name}`,
  href: `/calculator/${material.id}-${preferredDiameter.id}`
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Make Your Own Tools | Docker & 3D Printing Utilities</title>
    <meta
      name="description"
      content="Premium utility hub for Docker Compose generation and 3D printing filament calculations. Fast, practical, and production-ready."
    />
    <meta name="google-site-verification" content="xxGFCr12kZ-UHYt3HzhmkN4lqPvZRTMc91ftmIXsXik" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
  </head>

  <body class="min-h-screen text-zinc-100 antialiased [font-family:Geist,ui-sans-serif,system-ui,sans-serif]">
    <div class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_18%_12%,rgba(14,165,233,0.22),transparent_34%),radial-gradient(circle_at_84%_14%,rgba(244,114,182,0.2),transparent_36%),radial-gradient(circle_at_50%_88%,rgba(34,197,94,0.14),transparent_35%),linear-gradient(130deg,#05070f,#0f172a,#111827)]"></div>
    <div class="fixed inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.045)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.045)_1px,transparent_1px)] bg-[size:30px_30px] [mask-image:radial-gradient(circle_at_center,black_42%,transparent_100%)]"></div>

    <main class="mx-auto w-full max-w-7xl px-6 py-12 md:px-8 md:py-16">
      <section class="mb-10 grid items-start gap-8 lg:grid-cols-[1.2fr_0.8fr]">
        <div>
          <p class="mb-4 inline-flex items-center rounded-full border border-cyan-300/35 bg-cyan-300/10 px-4 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-cyan-100">
            Utility Studio
          </p>
          <h1 class="text-4xl font-semibold tracking-tight text-white md:text-6xl">
            Make Your Own Tools
          </h1>
          <p class="mt-5 max-w-3xl text-sm leading-7 text-zinc-300 md:text-base">
            Two focused products, one polished experience. Generate production-ready Docker Compose stacks and calculate exact filament length for 3D printing workflows.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
          <div class="rounded-2xl border border-white/15 bg-white/[0.04] p-4 backdrop-blur">
            <p class="text-xs uppercase tracking-[0.16em] text-zinc-400">Docker Routes</p>
            <p class="mt-1 text-3xl font-semibold text-white">{dockerRoutes}</p>
          </div>
          <div class="rounded-2xl border border-white/15 bg-white/[0.04] p-4 backdrop-blur">
            <p class="text-xs uppercase tracking-[0.16em] text-zinc-400">Calculator Routes</p>
            <p class="mt-1 text-3xl font-semibold text-white">{calculatorRoutes}</p>
          </div>
        </div>
      </section>

      <section class="grid gap-5 lg:grid-cols-2">
        <article class="group rounded-3xl border border-cyan-300/25 bg-gradient-to-br from-cyan-300/12 to-blue-500/10 p-6 shadow-2xl shadow-cyan-900/15 transition hover:border-cyan-200/40 md:p-7">
          <div class="mb-4 flex items-center justify-between">
            <p class="text-xs uppercase tracking-[0.16em] text-cyan-100">Docker Compose Generator</p>
            <span class="rounded-full border border-cyan-200/35 bg-cyan-100/10 px-2.5 py-0.5 text-xs font-semibold text-cyan-100">Live</span>
          </div>
          <h2 class="text-2xl font-semibold tracking-tight text-white">Build Valid App-DB-Proxy Stacks</h2>
          <p class="mt-3 text-sm leading-7 text-zinc-200">
            Generate reliable Compose templates from compatibility-aware combinations. No invalid stacks, no guesswork.
          </p>
          <a href="/docker/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-cyan-200/35 bg-cyan-100/10 px-4 py-2 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-100/20">
            Open Generator
            <span>→</span>
          </a>
          <ul class="mt-5 space-y-2 text-sm text-zinc-200">
            {featuredDocker.map((item) => (
              <li>
                <a href={item.href} class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white">
                  <span class="h-1.5 w-1.5 rounded-full bg-cyan-200"></span>
                  <span>{item.name}</span>
                </a>
              </li>
            ))}
          </ul>
        </article>

        <article class="group rounded-3xl border border-emerald-300/25 bg-gradient-to-br from-emerald-300/12 to-lime-500/10 p-6 shadow-2xl shadow-emerald-900/15 transition hover:border-emerald-200/40 md:p-7">
          <div class="mb-4 flex items-center justify-between">
            <p class="text-xs uppercase tracking-[0.16em] text-emerald-100">3D Printing Calculator</p>
            <span class="rounded-full border border-emerald-200/35 bg-emerald-100/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-100">Live</span>
          </div>
          <h2 class="text-2xl font-semibold tracking-tight text-white">Estimate Filament Length Precisely</h2>
          <p class="mt-3 text-sm leading-7 text-zinc-200">
            Pick material and diameter to get real-time filament length, plus print and bed temperature recommendations.
          </p>
          <a href="/calculator/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-emerald-200/35 bg-emerald-100/10 px-4 py-2 text-sm font-semibold text-emerald-100 transition hover:bg-emerald-100/20">
            Open Calculators
            <span>→</span>
          </a>
          <ul class="mt-5 space-y-2 text-sm text-zinc-200">
            {featuredCalculator.map((item) => (
              <li>
                <a href={item.href} class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-200"></span>
                  <span>{item.name}</span>
                </a>
              </li>
            ))}
          </ul>
        </article>
      </section>
    </main>
  </body>
</html>
