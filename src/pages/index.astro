---
import '../styles/global.css';
import services from '../data/services.json';

type App = (typeof services.apps)[number];
type Database = (typeof services.databases)[number];
type Proxy = (typeof services.proxies)[number];

// Generate all valid combinations
const combinations: Array<{ app: App; db: Database; proxy: Proxy }> = [];

services.apps.forEach(app => {
  services.databases.forEach(db => {
    if (!Array.isArray(app.supported_dbs) || !app.supported_dbs.includes(db.id)) return;
    
    services.proxies.forEach(proxy => {
      combinations.push({ app, db, proxy });
    });
  });
});

// Group by app for better navigation
const appGroups = services.apps.map(app => ({
  app,
  combinations: combinations.filter(c => c.app.id === app.id)
})).filter(g => g.combinations.length > 0);

// Calculate total combinations for SEO statement
const totalCombinations = combinations.length;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The Ultimate Docker Compose Generator • {totalCombinations}+ Presets</title>
    <meta name="description" content={`The Ultimate Docker Compose Generator: ${totalCombinations}+ production-ready docker-compose configurations. Deploy Ghost, WordPress, Nextcloud, Gitea, Metabase, and more with any database and reverse proxy.`} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="/" />
  </head>
  <body class="min-h-screen bg-gradient-to-br from-zinc-900 via-zinc-800 to-zinc-900 text-zinc-50 antialiased [font-family:Geist,ui-sans-serif,system-ui,sans-serif]">
    <main class="mx-auto w-full max-w-7xl px-6 py-16 md:px-8 md:py-24">
      <!-- Hero Section -->
      <div class="mb-20 text-center">
        <div class="mb-6 inline-block px-4 py-2 rounded-full border border-zinc-700 bg-zinc-800/50 backdrop-blur-sm">
          <span class="text-xs font-medium uppercase tracking-[0.16em] text-zinc-300">
            🚀 Deploy Self-Hosted Apps
          </span>
        </div>
        <h1 class="mb-6 text-6xl md:text-7xl font-bold tracking-tight text-white leading-tight">
          The Ultimate <br />
          <span class="bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
            Docker Compose Generator
          </span>
        </h1>
        <p class="mx-auto max-w-3xl text-lg text-zinc-300 md:text-xl leading-relaxed mb-8">
          Generate {totalCombinations}+ production-ready <span class="font-mono text-zinc-200">docker-compose.yml</span> configurations.
          <br />
          Choose any combination of app, database, and reverse proxy—we'll generate the perfect setup for you.
        </p>
        <div class="flex justify-center gap-4 text-sm">
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg border border-zinc-700 bg-zinc-800/30">
            <span class="text-blue-400 font-bold">{services.apps.length}</span>
            <span class="text-zinc-400">Apps</span>
          </div>
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg border border-zinc-700 bg-zinc-800/30">
            <span class="text-amber-400 font-bold">{services.databases.length}</span>
            <span class="text-zinc-400">Databases</span>
          </div>
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg border border-zinc-700 bg-zinc-800/30">
            <span class="text-purple-400 font-bold">{services.proxies.length}</span>
            <span class="text-zinc-400">Proxies</span>
          </div>
        </div>
      </div>

      <!-- Apps Grid -->
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 mb-16">
        {appGroups.map(group => (
          <div
            class="app-card group relative rounded-2xl border border-zinc-700/50 bg-zinc-900/50 backdrop-blur-sm overflow-hidden hover:border-zinc-600/50 transition-all duration-300 cursor-pointer"
            data-app-id={group.app.id}
          >
            <!-- Card Header / Clickable Area -->
            <div class="app-header px-6 py-6 md:py-8 border-b border-zinc-700/30 hover:bg-zinc-800/50 transition-colors">
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">
                    {group.app.name}
                  </h2>
                  <p class="text-sm text-zinc-400 font-mono mb-3">
                    {group.app.image}
                  </p>
                  <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded-lg bg-zinc-800/50 border border-zinc-700/50">
                    <span class="text-xs text-zinc-400">
                      {group.combinations.length} {group.combinations.length === 1 ? 'preset' : 'presets'}
                    </span>
                  </div>
                </div>
                <div class="flex-shrink-0">
                  <div class="toggle-icon w-8 h-8 rounded-lg bg-blue-500/20 border border-blue-500/30 flex items-center justify-center transition-transform duration-300">
                    <span class="text-lg">▼</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Expandable Combinations (Hidden by default) -->
            <div class="app-content hidden max-h-0 overflow-hidden transition-all duration-300">
              <div class="px-6 py-6 md:py-8 space-y-3 border-t border-zinc-700/30 bg-zinc-900/80">
                {group.combinations.map(combo => (
                  <a
                    href={`/${combo.app.id}-${combo.db.id}-${combo.proxy.id}/`}
                    class="flex items-center justify-between p-4 rounded-lg border border-zinc-700/30 bg-zinc-800/30 hover:bg-zinc-800/60 hover:border-zinc-600/50 transition-all duration-200 group/link"
                  >
                    <div class="flex items-center gap-3 flex-1">
                      <div class="flex items-center gap-2">
                        <span class="text-xs px-2 py-1 rounded-md bg-blue-500/20 border border-blue-500/30 text-blue-300 font-mono font-semibold">
                          {combo.db.name}
                        </span>
                        <span class="text-zinc-600">+</span>
                        <span class="text-xs px-2 py-1 rounded-md bg-purple-500/20 border border-purple-500/30 text-purple-300 font-mono font-semibold">
                          {combo.proxy.name}
                        </span>
                      </div>
                    </div>
                    <span class="text-zinc-500 group-hover/link:text-zinc-300 transition">→</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- SEO Footer Note -->
      <div class="rounded-2xl border border-zinc-700/50 bg-gradient-to-r from-blue-500/10 to-purple-500/10 backdrop-blur-sm p-8 md:p-12 text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Ready to Deploy?</h3>
        <p class="text-zinc-300 max-w-2xl mx-auto">
          Select your favorite app, database, and reverse proxy combination above to generate a production-ready docker-compose.yml file. 
          All presets include environment variable templates and best practices for self-hosted deployments.
        </p>
      </div>

      <!-- Footer -->
      <footer class="mt-16 pt-8 border-t border-zinc-700/30 text-center text-sm text-zinc-500">
        <p>
          🔗 {totalCombinations}+ unique combinations • 📝 SEO-friendly sitemap • ⚙️ Production-ready configs
        </p>
      </footer>
    </main>

    <script>
      // Interactive app card expansion
      document.querySelectorAll('[data-app-id]').forEach(card => {
        const header = card.querySelector('.app-header');
        const content = card.querySelector('.app-content');
        const icon = card.querySelector('.toggle-icon span');

        header?.addEventListener('click', () => {
          const isOpen = !content?.classList.contains('hidden');
          
          if (isOpen) {
            content?.classList.add('hidden');
            content?.classList.remove('max-h-full');
            content?.classList.add('max-h-0');
            icon && (icon.textContent = '▼');
          } else {
            content?.classList.remove('hidden');
            content?.classList.add('max-h-full');
            content?.classList.remove('max-h-0');
            icon && (icon.textContent = '▲');
          }
        });
      });
    </script>
  </body>
</html>
        <h1 class="mb-4 text-5xl md:text-7xl font-bold tracking-tight text-white">
          Deploy Self-Hosted Apps <br />
          <span class="bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
            in Minutes
          </span>
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-zinc-300 md:text-xl leading-relaxed">
          Generate production-ready <span class="font-mono text-zinc-200">docker-compose.yml</span> for {totalCombinations}+ combinations
          of your favorite self-hosted applications, databases, and reverse proxies.
        </p>
      </div>

      <!-- Stats -->
      <div class="mb-16 grid grid-cols-3 gap-4 md:gap-8">
        <div class="rounded-xl border border-zinc-700 bg-zinc-800/30 backdrop-blur-sm p-6 text-center">
          <div class="text-3xl md:text-4xl font-bold text-blue-400">{services.apps.length}</div>
          <div class="mt-2 text-sm text-zinc-400">Apps</div>
        </div>
        <div class="rounded-xl border border-zinc-700 bg-zinc-800/30 backdrop-blur-sm p-6 text-center">
          <div class="text-3xl md:text-4xl font-bold text-amber-400">{services.databases.length}</div>
          <div class="mt-2 text-sm text-zinc-400">Databases</div>
        </div>
        <div class="rounded-xl border border-zinc-700 bg-zinc-800/30 backdrop-blur-sm p-6 text-center">
          <div class="text-3xl md:text-4xl font-bold text-purple-400">{services.proxies.length}</div>
          <div class="mt-2 text-sm text-zinc-400">Proxies</div>
        </div>
      </div>

      <!-- Apps Navigation -->
      <div class="space-y-12">
        {appGroups.map(group => (
          <section class="rounded-2xl border border-zinc-700/50 bg-zinc-900/50 backdrop-blur-sm overflow-hidden">
            <!-- App Header -->
            <div class="px-6 md:px-8 py-6 md:py-8 border-b border-zinc-700/50 bg-gradient-to-r from-zinc-800/50 to-transparent">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0">
                  <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-blue-500/20 border border-blue-500/30">
                    <span class="text-lg">📦</span>
                  </div>
                </div>
                <div class="flex-1">
                  <h2 class="text-2xl md:text-3xl font-bold text-white">{group.app.name}</h2>
                  <p class="mt-2 text-sm text-zinc-400 font-mono">{group.app.image}</p>
                  <p class="mt-1 text-sm text-zinc-400">
                    {group.combinations.length} {group.combinations.length === 1 ? 'configuration' : 'configurations'} available
                  </p>
                </div>
              </div>
            </div>

            <!-- Combinations Grid -->
            <div class="p-6 md:p-8">
              <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {group.combinations.map(combo => (
                  <a
                    href={`/${combo.app.id}-${combo.db.id}-${combo.proxy.id}/`}
                    class="group relative rounded-lg border border-zinc-700 bg-zinc-800/30 hover:bg-zinc-800/60 px-4 py-4 transition-all duration-200 hover:border-zinc-600"
                  >
                    <!-- Glow on Hover -->
                    <div class="absolute inset-0 rounded-lg bg-gradient-to-r from-blue-500/0 to-purple-500/0 group-hover:from-blue-500/10 group-hover:to-purple-500/10 transition duration-200"></div>
                    
                    <!-- Content -->
                    <div class="relative">
                      <div class="flex items-center justify-between mb-3">
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-zinc-700/50 text-xs font-semibold text-zinc-300">
                          <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>
                          {combo.db.name}
                        </span>
                        <span class="text-xs text-zinc-500 group-hover:text-zinc-400 transition">→</span>
                      </div>
                      <div class="flex items-center justify-between mb-2">
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-zinc-700/50 text-xs font-semibold text-zinc-300">
                          <span class="w-1.5 h-1.5 rounded-full bg-purple-400"></span>
                          {combo.proxy.name}
                        </span>
                      </div>
                      <p class="text-xs text-zinc-500 group-hover:text-zinc-400 transition font-mono mt-3">
                        {combo.app.id}-{combo.db.id}-{combo.proxy.id}
                      </p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </section>
        ))}
      </div>

      <!-- Footer CTA -->
      <div class="mt-16 rounded-2xl border border-zinc-700/50 bg-gradient-to-r from-blue-500/10 to-purple-500/10 backdrop-blur-sm p-8 md:p-12 text-center">
        <h3 class="text-2xl md:text-3xl font-bold text-white mb-3">Ready to Deploy?</h3>
        <p class="text-zinc-300 mb-6">
          Pick any combination above to generate your production-ready docker-compose configuration.
        </p>
        <p class="text-sm text-zinc-400">
          All presets include environment variables for seamless .env integration and best practices for self-hosted deployments.
        </p>
      </div>

      <!-- Footer -->
      <footer class="mt-16 pt-8 border-t border-zinc-700/30 text-center text-sm text-zinc-500">
        <p>
          Generate {totalCombinations}+ unique deployment configurations. 
          <br />
          Perfect for pSEO and self-hosted infrastructure documentation.
        </p>
      </footer>
    </main>
  </body>
</html>
