---
import Layout from '../layouts/Layout.astro';
import services from '../data/services.json';
import filaments from '../data/filaments.json';
import satisfactoryData from '../data/satisfactory.json';
import { NAS_RAID_TOTAL_ROUTES } from '../data/nasRaidSeo';
import { OFFGRID_SOLAR_TOTAL_ROUTES } from '../data/offGridSolarSeo';
import { REVERSE_PROXY_TOTAL_ROUTES } from '../data/reverseProxySeo';

type App = {
  id: string;
  name: string;
  supported_dbs: string[];
};
type Db = { id: string; name: string };
type Proxy = { id: string; name: string };
type Material = { id: string; name: string };
type Diameter = { id: string; name: string; common?: boolean };

type ServicesData = {
  apps: App[];
  databases: Db[];
  proxies: Proxy[];
};
type FilamentsData = {
  materials: Material[];
  diameters: Diameter[];
};
type SatisfactoryItem = {
  id: string;
  name: string;
};
type SatisfactoryDataset = {
  items: SatisfactoryItem[];
  mvp_targets: string[];
};

const servicesData = services as ServicesData;
const filamentsData = filaments as FilamentsData;
const satData = satisfactoryData as SatisfactoryDataset;

const dockerRoutes = servicesData.apps.reduce((total, app) => {
  const compatibleCount = servicesData.databases.filter((db) => app.supported_dbs.includes(db.id)).length;
  return total + compatibleCount * servicesData.proxies.length;
}, 0);

const filamentRoutes = filamentsData.materials.length * filamentsData.diameters.length;
const satisfactoryRoutes = satData.items.length;
const nasRaidRoutes = NAS_RAID_TOTAL_ROUTES;
const offGridSolarRoutes = OFFGRID_SOLAR_TOTAL_ROUTES;
const reverseProxyRoutes = REVERSE_PROXY_TOTAL_ROUTES;
const vramRoutes = 1;
const calculatorRoutes = filamentRoutes + satisfactoryRoutes + nasRaidRoutes + offGridSolarRoutes + vramRoutes;

const featuredDocker = servicesData.apps.slice(0, 3).flatMap((app) => {
  const db = servicesData.databases.find((d) => app.supported_dbs.includes(d.id));
  const proxy = servicesData.proxies[0];
  if (!db || !proxy) return [];

  return [{
    name: `${app.name} + ${db.name} + ${proxy.name}`,
    href: `/docker/${app.id}-${db.id}-${proxy.id}/`
  }];
});

const preferredDiameter = filamentsData.diameters.find((d) => d.common) ?? filamentsData.diameters[0];
const featuredVram = {
  name: 'LLM VRAM Calculator',
  href: '/calculator/vram/'
};
const featuredNasRaid = {
  name: 'NAS & RAID Storage Calculator',
  href: '/calculator/nas-raid/'
};
const featuredOffGrid = {
  name: 'RV Off-Grid Solar & Battery Calculator',
  href: '/calculator/off-grid-solar/'
};
const featuredReverseProxy = {
  name: 'Reverse Proxy Config Generator',
  href: '/reverse-proxy/'
};
const featuredFilament = filamentsData.materials.slice(0, 2).map((material) => ({
  name: `${material.name} · ${preferredDiameter.name}`,
  href: `/calculator/3d-printing/${material.id}-${preferredDiameter.id}`
}));

const featuredSatisfactory = satData.mvp_targets.slice(0, 2)
  .map((id) => satData.items.find((item) => item.id === id))
  .filter((item): item is SatisfactoryItem => Boolean(item))
  .map((item) => ({
    name: item.name,
    href: `/calculator/satisfactory/${item.id}`
  }));

const featuredCalculator = [featuredVram, featuredNasRaid, featuredOffGrid, ...featuredFilament, ...featuredSatisfactory];

const longTailAnchors = {
  ai: [
    { href: '/calculator/vram/?model=meta-llama/Meta-Llama-3-8B-Instruct', label: 'Llama 3 8B VRAM calculator' },
    { href: '/calculator/vram/?model=Qwen/Qwen2.5-7B-Instruct', label: 'Qwen 7B VRAM calculator' },
    { href: '/calculator/vram/?mode=training', label: 'LoRA training VRAM calculator' }
  ],
  storage: [
    { href: '/calculator/nas-raid/4x-8tb-raid5-calculator/', label: '4x 8TB RAID 5 calculator' },
    { href: '/calculator/nas-raid/raid10-vs-raid5-storage-capacity/', label: 'RAID 10 vs RAID 5 calculator' },
    { href: '/calculator/nas-raid/uk-6x-12tb-raidz2-calculator/', label: 'UK RAID-Z2 calculator' }
  ],
  power: [
    { href: '/calculator/off-grid-solar/60w-24h-plus-1000w-10m-12v-3sunh-1day-off-grid-solar-battery-calculator/', label: '12V fridge and microwave solar calculator' },
    { href: '/calculator/off-grid-solar/12v-vs-24v-vs-48v-off-grid-solar-battery-calculator-24v-profile-2/', label: '12V vs 24V vs 48V solar calculator' },
    { href: '/calculator/off-grid-solar/arizona-24v-off-grid-solar-battery-calculator/', label: 'Arizona off-grid solar calculator' }
  ],
  fabrication: [
    { href: '/calculator/3d-printing/pla-1-75mm', label: 'PLA filament length calculator' },
    { href: '/calculator/3d-printing/petg-1-75mm', label: 'PETG filament length calculator' },
    { href: '/calculator/3d-printing/', label: '3D printing filament navigator' }
  ],
  game: [
    { href: '/calculator/satisfactory/', label: 'Satisfactory production calculator' },
    { href: '/calculator/satisfactory/heavy-modular-frame', label: 'Heavy Modular Frame calculator' },
    { href: '/calculator/satisfactory/computer', label: 'Computer production planner' }
  ]
} as const;
---

<Layout
  title="Make Your Own Tools | Docker & Calculator Utilities"
  description="Premium utility hub for Docker Compose generation and multi-domain calculators including 3D printing and Satisfactory planning."
>
  <main class="mx-auto w-full max-w-7xl px-6 py-12 md:px-8 md:py-16">
      <section class="mb-10 grid items-start gap-8 lg:grid-cols-[1.2fr_0.8fr]">
        <div>
          <p class="mb-4 inline-flex items-center rounded-full border border-cyan-300/35 bg-cyan-300/10 px-4 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-cyan-100">
            Utility Studio
          </p>
          <h1 class="text-4xl font-semibold tracking-tight text-white md:text-6xl">
            Make Your Own Tools
          </h1>
          <p class="mt-5 max-w-3xl text-sm leading-7 text-zinc-300 md:text-base">
            Three focused products, one polished experience. Generate Docker Compose stacks, build reverse proxy configs, and run production calculators across multiple domains.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
          <div class="rounded-2xl border border-white/15 bg-white/[0.04] p-4 backdrop-blur">
            <p class="text-xs uppercase tracking-[0.16em] text-zinc-400">Docker Routes</p>
            <p class="mt-1 text-3xl font-semibold text-white" data-countup data-target={dockerRoutes}>0</p>
          </div>
          <div class="rounded-2xl border border-white/15 bg-white/[0.04] p-4 backdrop-blur">
            <p class="text-xs uppercase tracking-[0.16em] text-zinc-400">Reverse Proxy Routes</p>
            <p class="mt-1 text-3xl font-semibold text-white" data-countup data-target={reverseProxyRoutes}>0</p>
          </div>
          <div class="rounded-2xl border border-white/15 bg-white/[0.04] p-4 backdrop-blur">
            <p class="text-xs uppercase tracking-[0.16em] text-zinc-400">Calculator Routes</p>
            <p class="mt-1 text-3xl font-semibold text-white" data-countup data-target={calculatorRoutes}>0</p>
          </div>
        </div>
      </section>

      <section class="grid gap-5 lg:grid-cols-3">
        <article class="group rounded-3xl border border-cyan-300/25 bg-gradient-to-br from-cyan-300/12 to-blue-500/10 p-6 shadow-2xl shadow-cyan-900/15 transition hover:border-cyan-200/40 md:p-7">
          <div class="mb-4 flex items-center justify-between">
            <p class="text-xs uppercase tracking-[0.16em] text-cyan-100">Docker Compose Generator</p>
            <span class="rounded-full border border-cyan-200/35 bg-cyan-100/10 px-2.5 py-0.5 text-xs font-semibold text-cyan-100">Live</span>
          </div>
          <h2 class="text-2xl font-semibold tracking-tight text-white">Build Valid App-DB-Proxy Stacks</h2>
          <p class="mt-3 text-sm leading-7 text-zinc-200">
            Generate reliable Compose templates from compatibility-aware combinations. No invalid stacks, no guesswork.
          </p>
          <a href="/docker/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-cyan-200/35 bg-cyan-100/10 px-4 py-2 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-100/20">
            Open Generator
            <span>→</span>
          </a>
          <ul class="mt-5 space-y-2 text-sm text-zinc-200">
            <li>
              <a href={featuredReverseProxy.href} class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white">
                <span class="h-1.5 w-1.5 rounded-full bg-cyan-200"></span>
                <span>{featuredReverseProxy.name}</span>
              </a>
            </li>
            {featuredDocker.map((item) => (
              <li>
                <a href={item.href} class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white">
                  <span class="h-1.5 w-1.5 rounded-full bg-cyan-200"></span>
                  <span>{item.name}</span>
                </a>
              </li>
            ))}
          </ul>
        </article>

        <article class="group rounded-3xl border border-sky-300/25 bg-gradient-to-br from-sky-300/12 to-indigo-500/10 p-6 shadow-2xl shadow-sky-900/15 transition hover:border-sky-200/40 md:p-7">
          <div class="mb-4 flex items-center justify-between">
            <p class="text-xs uppercase tracking-[0.16em] text-sky-100">Reverse Proxy Generator</p>
            <span class="rounded-full border border-sky-200/35 bg-sky-100/10 px-2.5 py-0.5 text-xs font-semibold text-sky-100">Live</span>
          </div>
          <h2 class="text-2xl font-semibold tracking-tight text-white">Generate Nginx / Caddy / Traefik Configs</h2>
          <p class="mt-3 text-sm leading-7 text-zinc-200">
            Select app runtime and traffic requirements, then generate hardened reverse proxy configs with HTTPS, CORS, websocket, compression, and upload limits.
          </p>
          <a href="/reverse-proxy/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-sky-200/35 bg-sky-100/10 px-4 py-2 text-sm font-semibold text-sky-100 transition hover:bg-sky-100/20">
            Open Proxy Generator
            <span>→</span>
          </a>
          <ul class="mt-5 space-y-2 text-sm text-zinc-200">
            <li><a href="/reverse-proxy/nginx-for-node/" class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white"><span class="h-1.5 w-1.5 rounded-full bg-sky-200"></span><span>Nginx Reverse Proxy for Node.js</span></a></li>
            <li><a href="/reverse-proxy/caddy-for-react/" class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white"><span class="h-1.5 w-1.5 rounded-full bg-sky-200"></span><span>Caddy Reverse Proxy for React</span></a></li>
            <li><a href="/reverse-proxy/nginx-for-ghost/" class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white"><span class="h-1.5 w-1.5 rounded-full bg-sky-200"></span><span>Nginx Reverse Proxy for Ghost</span></a></li>
          </ul>
        </article>

        <article class="group rounded-3xl border border-emerald-300/25 bg-gradient-to-br from-emerald-300/12 to-lime-500/10 p-6 shadow-2xl shadow-emerald-900/15 transition hover:border-emerald-200/40 md:p-7">
          <div class="mb-4 flex items-center justify-between">
            <p class="text-xs uppercase tracking-[0.16em] text-emerald-100">Calculator Hub</p>
            <span class="rounded-full border border-emerald-200/35 bg-emerald-100/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-100">Live</span>
          </div>
          <h2 class="text-2xl font-semibold tracking-tight text-white">General-Purpose Production Calculators</h2>
          <p class="mt-3 text-sm leading-7 text-zinc-200">
            Start with LLM VRAM, NAS & RAID, or RV off-grid solar sizing, then move to 3D printing and Satisfactory production workflows in one unified calculator hub.
          </p>
          <a href="/calculator/" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-emerald-200/35 bg-emerald-100/10 px-4 py-2 text-sm font-semibold text-emerald-100 transition hover:bg-emerald-100/20">
            Open Calculators
            <span>→</span>
          </a>
          <ul class="mt-5 space-y-2 text-sm text-zinc-200">
            {featuredCalculator.map((item) => (
              <li>
                <a href={item.href} class="inline-flex items-center gap-2 text-zinc-200 transition hover:text-white">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-200"></span>
                  <span>{item.name}</span>
                </a>
              </li>
            ))}
          </ul>
        </article>
      </section>

      <section class="mt-8 rounded-3xl border border-white/12 bg-white/[0.02] p-6 md:p-8">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-300">Search Scenarios</h2>
            <p class="mt-2 text-sm text-zinc-400">Anchor text built for the exact queries people search before they reach a calculator or generator.</p>
          </div>
          <span class="text-xs uppercase tracking-[0.14em] text-zinc-500">Long-tail entry points</span>
        </div>

        <div class="mt-5 grid gap-5 md:grid-cols-2 xl:grid-cols-5">
          {Object.entries(longTailAnchors).map(([domain, links]) => (
            <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
              <p class="text-xs uppercase tracking-[0.14em] text-zinc-500">{domain}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {links.map((link) => (
                  <a href={link.href} class="rounded-full border border-white/12 bg-white/5 px-3 py-1.5 text-xs font-semibold text-zinc-200 transition hover:border-cyan-300/40 hover:bg-cyan-300/10 hover:text-white">
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
  </main>
</Layout>

<script>
  (() => {
    const counters = Array.from(document.querySelectorAll<HTMLElement>('[data-countup]'));
    if (!counters.length) return;

    const animateCounter = (node: HTMLElement) => {
      const target = Number(node.dataset.target ?? '0');
      const duration = 900;
      const start = performance.now();

      const step = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = Math.round(target * eased);
        node.textContent = String(value);
        if (progress < 1) requestAnimationFrame(step);
      };

      requestAnimationFrame(step);
    };

    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        animateCounter(entry.target as HTMLElement);
        obs.unobserve(entry.target);
      });
    }, { threshold: 0.4 });

    counters.forEach((counter) => observer.observe(counter));
  })();
</script>
