  "databases": [
    {
      "id": "mysql",
      "name": "MySQL",
      "image": "mysql:latest",
      "port": "3306",
      "volume_path": "/var/lib/mysql",
      "init_env_mapping": {
        "root_password": "MYSQL_ROOT_PASSWORD",
        "user": "MYSQL_USER",
        "password": "MYSQL_PASSWORD",
